concepts/traceability-95","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#conversion-pattern","content":"Step-by-step process for converting tracked entities (e.g., material → part):"},"456":{"id":"/concepts/traceability-96","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#conversion-pattern","content":"Create a trackedActivity record describing the transformation"},"457":{"id":"/concepts/traceability-97","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#conversion-pattern","content":"Create trackedActivityInput records for consumed entities"},"458":{"id":"/concepts/traceability-98","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#conversion-pattern","content":"Create trackedActivityOutput records for produced items"},"459":{"id":"/concepts/traceability-99","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#conversion-pattern","content":"Update item ledgers with deductions (inputs) and additions (outputs)"},"460":{"id":"/concepts/traceability-100","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#conversion-pattern","content":"Update entity statuses (consumed entities → 'Consumed')"},"461":{"id":"/concepts/traceability-101","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#conversion-pattern","content":"Example from revision-system.md:"},"462":{"id":"/concepts/traceability-102","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#erp-inventory-service","content":"apps/erp/app/modules/inventory/inventory.service.ts:"},"463":{"id":"/concepts/traceability-103","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#erp-inventory-service","content":"getTrackedEntities() - Get entities for an item"},"464":{"id":"/concepts/traceability-104","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#erp-inventory-service","content":"getTrackedEntitiesByMakeMethodId() - Get entities produced by a make method"},"465":{"id":"/concepts/traceability-105","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#erp-inventory-service","content":"getTrackedEntitiesByOperationId() - Get entities produced by an operation"},"466":{"id":"/concepts/traceability-106","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#mes-operations-service","content":"apps/mes/app/services/operations.service.ts:"},"467":{"id":"/concepts/traceability-107","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#mes-operations-service","content":"getTrackedEntitiesByMakeMethodId() - Get available entities for production"},"468":{"id":"/concepts/traceability-108","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#mes-operations-service","content":"getTrackedEntity() - Get specific entity details"},"469":{"id":"/concepts/traceability-109","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#mes-operations-service","content":"getTrackedInputs() - Get consumed inputs for an activity"},"470":{"id":"/concepts/traceability-110","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#mes-operations-service","content":"startProductionEvent() - Creates activities and links during production"},"471":{"id":"/concepts/traceability-111","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#qr-code-integration","content":"Tracked entities can have QR codes generated for labeling:"},"472":{"id":"/concepts/traceability-112","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#qr-code-integration","content":"ProductLabelPDF uses generateQRCode(item.trackedEntityId, size)"},"473":{"id":"/concepts/traceability-113","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#qr-code-integration","content":"Enables scanning for instant traceability lookup"},"474":{"id":"/concepts/traceability-114","page_id":"/concepts/traceability","tags":[],"type":"text","url":"/concepts/traceability#qr-code-integration","content":"Reference: llm/cache/pdf-generation-patterns.md:43"},"475":{"id":"/manual","page_id":"/manual","type":"page","content":"The Carbon Manual","tags":[],"url":"/manual"},"476":{"id":"/manual-0","page_id":"/manual","tags":[],"type":"text","url":"/manual","content":"A written, self-serve guide to running your manufacturing business on Carbon — from your first quote to a shipped, invoiced order."},"477":{"id":"/manual-1","page_id":"/manual","type":"heading","tags":[],"url":"/manual#who-this-manual-is-for","content":"Who this manual is for"},"478":{"id":"/manual-2","page_id":"/manual","type":"heading","tags":[],"url":"/manual#learn-with-a-real-company","content":"Learn with a real company"},"479":{"id":"/manual-3","page_id":"/manual","type":"heading","tags":[],"url":"/manual#the-shape-of-carbon","content":"The shape of Carbon"},"480":{"id":"/manual-4","page_id":"/manual","type":"heading","tags":[],"url":"/manual#browse-by-topic","content":"Browse by topic"},"481":{"id":"/manual-5","page_id":"/manual","type":"heading","tags":[],"url":"/manual#how-to-read-this-manual","content":"How to read this manual"},"482":{"id":"/manual-6","page_id":"/manual","tags":[],"type":"text","url":"/manual","content":"Welcome to the written Carbon manual — the read-at-your-own-pace companion to\nCarbon Academy. Same curriculum, no video required. If you\nhave ten minutes between jobs, you can learn a whole module right here."},"483":{"id":"/manual-7","page_id":"/manual","tags":[],"type":"text","url":"/manual","content":"Carbon is an open-source manufacturing system of record — it combines an ERP\n(the business: sales, purchasing, inventory, costing), an MES (the shop floor:\nrunning jobs and recording work), and a QMS (quality: inspections, non-conformances\nand traceability) into one connected system."},"484":{"id":"/manual-8","page_id":"/manual","tags":[],"type":"text","url":"/manual#who-this-manual-is-for","content":"This guide assumes no prior ERP or manufacturing-software experience. We define\nevery term the first time it appears (and collect them in the\nglossary), and every workflow is written as numbered\nsteps you can follow click-by-click. Whether you're an owner setting Carbon up, an\nestimator building quotes, a buyer cutting purchase orders, or an operator on the\nfloor — there's a path here for you."},"485":{"id":"/manual-9","page_id":"/manual","tags":[],"type":"text","url":"/manual#learn-with-a-real-company","content":"Every example in this manual uses Acme Inc., a real demo company that makes\nprecision parts and assemblies for aerospace, defense and energy customers. Instead\nof made-up screenshots, you'll see Acme's actual parts, customers, suppliers and jobs\n— so what you read here matches what you'll see in the app."},"486":{"id":"/manual-10","page_id":"/manual","tags":[],"type":"text","url":"/manual#learn-with-a-real-company","content":"type: info"},"487":{"id":"/manual-11","page_id":"/manual","tags":[],"type":"text","url":"/manual#learn-with-a-real-company","content":"About the pictures. Screens in this manual are rendered from Acme's real data in\nCarbon's own styling, so they stay crisp and match light or dark mode. They show the\nsame fields and layout you'll see in the live app at app.carbon.ms."},"488":{"id":"/manual-12","page_id":"/manual","tags":[],"type":"text","url":"/manual#the-shape-of-carbon","content":"Most work in Carbon follows one thread. A customer asks for a price (a quote); you\nwin the work (a sales order); you make it (a job on the shop floor) and buy the\nmaterials you need (a purchase order); you check it (quality); then you ship\nit and invoice it. Everything else hangs off that spine."},"489":{"id":"/manual-13","page_id":"/manual","tags":[],"type":"text","url":"/manual#the-shape-of-carbon","content":"The 15-minute walkthrough follows exactly this thread using one\nreal Acme part. After that, each section below goes deep on one stop along the way."},"490":{"id":"/manual-14","page_id":"/manual","tags":[],"type":"text","url":"/manual#how-to-read-this-manual","content":"Start with the walkthrough. It gives you the whole map before\nyou zoom in, so individual features make sense in context."},"491":{"id":"/manual-15","page_id":"/manual","tags":[],"type":"text","url":"/manual#how-to-read-this-manual","content":"Then read the section you need. Each one opens with “Where this fits” and ends with\n“Next steps”, so you always know where you are in the bigger flow."},"492":{"id":"/manual-16","page_id":"/manual","tags":[],"type":"text","url":"/manual#how-to-read-this-manual","content":"Try it in your own Carbon. Sign in at app.carbon.ms and follow\nalong. Don't have an account yet? Carbon is open source — see\nGetting Started."},"493":{"id":"/manual-17","page_id":"/manual","tags":[],"type":"text","url":"/manual#how-to-read-this-manual","content":"type: info"},"494":{"id":"/manual-18","page_id":"/manual","tags":[],"type":"text","url":"/manual#how-to-read-this-manual","content":"Looking for the developer documentation — the API, self-hosting and core concepts?\nSwitch to Developer Docs using the toggle at the top of the sidebar, or visit\nthe framework docs."},"495":{"id":"/manual/walkthrough","page_id":"/manual/walkthrough","type":"page","content":"Carbon in 15 minutes","tags":[],"url":"/manual/walkthrough"},"496":{"id":"/manual/walkthrough-0","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough","content":"Follow one real order from quote to cash — the whole Carbon flow, end to end, using a real Acme part."},"497":{"id":"/manual/walkthrough-1","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#step-1--a-customer-asks-for-a-price-the-quote","content":"Step 1 — A customer asks for a price (the Quote)"},"498":{"id":"/manual/walkthrough-2","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#step-2--you-win-the-work-the-sales-order","content":"Step 2 — You win the work (the Sales Order)"},"499":{"id":"/manual/walkthrough-3","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#step-3--carbon-knows-how-its-made-the-method","content":"Step 3 — Carbon knows how it's made (the Method)"},"500":{"id":"/manual/walkthrough-4","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#step-4--carbon-plans-the-work-the-job","content":"Step 4 — Carbon plans the work (the Job)"},"501":{"id":"/manual/walkthrough-5","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#step-5--buy-the-material-you-dont-have-the-purchase-order","content":"Step 5 — Buy the material you don't have (the Purchase Order)"},"502":{"id":"/manual/walkthrough-6","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#step-6--check-it-ship-it-quality--shipment","content":"Step 6 — Check it, ship it (Quality & Shipment)"},"503":{"id":"/manual/walkthrough-7","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#step-7--get-paid-the-invoice","content":"Step 7 — Get paid (the Invoice)"},"504":{"id":"/manual/walkthrough-8","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#the-whole-thread-in-one-place","content":"The whole thread, in one place"},"505":{"id":"/manual/walkthrough-9","page_id":"/manual/walkthrough","type":"heading","tags":[],"url":"/manual/walkthrough#go-deeper","content":"Go deeper"},"506":{"id":"/manual/walkthrough-10","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough","content":"The fastest way to understand Carbon is to watch one order move through it. This page\nfollows a single real part — a Counterweight Hook that Acme makes for Radiant\nAerospace — from the first price request all the way to a paid invoice. You don't need\nto do anything here; just read along and you'll have the whole map. Every later section\nzooms in on one of these stops."},"507":{"id":"/manual/walkthrough-11","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough","content":"type: info"},"508":{"id":"/manual/walkthrough-12","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough","content":"Meet the part. The Counterweight Hook (part number CWH-A36-15) is a heavy steel\nhook flame-cut from 1-inch A36 steel plate. Radiant Aerospace orders them 500 at a time.\nCarbon calls anything you make or buy an item — this one\nis a Part that Acme makes (rather than buys)."},"509":{"id":"/manual/walkthrough-13","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-1--a-customer-asks-for-a-price-the-quote","content":"It starts when Radiant Aerospace asks \"what would 500 of these cost?\" In Carbon you answer\nwith a quote: you add a line for the part, the quantity, and a price. Carbon adds up the\ncost of materials and shop time behind the scenes so you can price the work with confidence."},"510":{"id":"/manual/walkthrough-14","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-1--a-customer-asks-for-a-price-the-quote","content":"When the customer says yes, you convert the quote into a sales order with one click —\nno re-typing. Carbon keeps the quote and the order linked, so you can always trace a job\nback to the price you promised."},"511":{"id":"/manual/walkthrough-15","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-1--a-customer-asks-for-a-price-the-quote","content":"type: tip"},"512":{"id":"/manual/walkthrough-16","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-1--a-customer-asks-for-a-price-the-quote","content":"Quotes are also where Carbon's configurators shine — for made-to-order parts the\ncustomer's choices (size, material, finish) can drive the price automatically. More in\nQuoting & estimating."},"513":{"id":"/manual/walkthrough-17","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-2--you-win-the-work-the-sales-order","content":"The sales order is the customer's commitment: who's buying, what, how many, when it's\ndue, and at what price. It's the anchor everything else hangs off — the job that makes the\npart, the shipment that sends it, and the invoice that bills for it all point back here."},"514":{"id":"/manual/walkthrough-18","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-2--you-win-the-work-the-sales-order","content":"Notice the fulfillment method on the line: Make to Order. That single setting tells\nCarbon this part isn't sitting on a shelf — it has to be made — so the next step happens\nalmost automatically."},"515":{"id":"/manual/walkthrough-19","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-3--carbon-knows-how-its-made-the-method","content":"Every part you make has a method: a recipe with two halves."},"516":{"id":"/manual/walkthrough-20","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-3--carbon-knows-how-its-made-the-method","content":"The bill of materials (BOM) — what it's made of."},"517":{"id":"/manual/walkthrough-21","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-3--carbon-knows-how-its-made-the-method","content":"The routing — the steps to make it, and where each step happens."},"518":{"id":"/manual/walkthrough-22","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-3--carbon-knows-how-its-made-the-method","content":"For the Counterweight Hook, the recipe is short: take a slab of 1-inch A36 steel plate,\nthen run it through three shop operations."},"519":{"id":"/manual/walkthrough-23","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-3--carbon-knows-how-its-made-the-method","content":"Each hook needs 40 lb of steel, so a batch of 500 needs 20,000 lb. Carbon already\nknows that — and it knows Acme doesn't keep that much on hand. Watch what happens next."},"520":{"id":"/manual/walkthrough-24","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-4--carbon-plans-the-work-the-job","content":"Because the order is Make to Order, Carbon creates a job — a production order that\ncarries its own copy of the method. Acme releases job J000097 for 500 pieces and it's\nready for the shop floor."},"521":{"id":"/manual/walkthrough-25","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-4--carbon-plans-the-work-the-job","content":"On the shop floor, operators open the MES app,\nclock onto each operation, and record how many good pieces they finished. That's how the\n\"Done\" statuses above got there — and how the 282 seconds of recorded labor rolled up into\nthe job's real cost."},"522":{"id":"/manual/walkthrough-26","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-5--buy-the-material-you-dont-have-the-purchase-order","content":"Acme is short on 1-inch steel plate, so Carbon flags the shortage and Acme raises a\npurchase order to its steel supplier, Ryerson. Buying and making run in parallel —\nthe steel is on its way while the shop gets set up."},"523":{"id":"/manual/walkthrough-27","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-5--buy-the-material-you-dont-have-the-purchase-order","content":"When the steel arrives, a quick receipt adds it to inventory — and because A36 plate is\nbatch-tracked, Carbon records exactly which heat of steel went into this batch of hooks.\nThat's the start of full traceability: months later you\ncan answer \"which material went into Radiant's order?\" in seconds."},"524":{"id":"/manual/walkthrough-28","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-6--check-it-ship-it-quality--shipment","content":"The last operation on the job was Inspection — a quality gate. With the parts inspected\nand accepted, Acme creates a shipment, picks the 500 finished hooks, and sends them.\nCarbon marks the sales order line Shipped."},"525":{"id":"/manual/walkthrough-29","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#step-7--get-paid-the-invoice","content":"Finally, Acme bills the order. The sales invoice AR000025 pulls its lines straight\nfrom what shipped — no re-keying — and once Radiant pays, Carbon marks it Paid and posts\nthe revenue to the books."},"526":{"id":"/manual/walkthrough-30","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#the-whole-thread-in-one-place","content":"That's Carbon end to end. One part, one continuous chain of linked records — each one a tap\naway from the next:"},"527":{"id":"/manual/walkthrough-31","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#the-whole-thread-in-one-place","content":"type: info"},"528":{"id":"/manual/walkthrough-32","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#the-whole-thread-in-one-place","content":"Every record above linked itself to the next automatically. That's the whole idea of a\nsystem of record: enter information once, and it follows the work everywhere it goes."},"529":{"id":"/manual/walkthrough-33","page_id":"/manual/walkthrough","tags":[],"type":"text","url":"/manual/walkthrough#go-deeper","content":"Now that you've seen the whole flow, dive into any stop along the way:"},"530":{"id":"/manual/accounting/overview","page_id":"/manual/accounting/overview","type":"page","content":"Accounting & invoicing","tags":[],"url":"/manual/accounting/overview"},"531":{"id":"/manual/accounting/overview-0","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview","content":"Sales and purchase invoices, payments and finance integrations."},"532":{"id":"/manual/accounting/overview-1","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#the-two-kinds-of-invoice","content":"The two kinds of invoice"},"533":{"id":"/manual/accounting/overview-2","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#sales-invoices--billing-the-customer","content":"Sales invoices — billing the customer"},"534":{"id":"/manual/accounting/overview-3","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#creating-and-sending-a-sales-invoice","content":"Creating and sending a sales invoice"},"535":{"id":"/manual/accounting/overview-4","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#reading-the-invoice-statuses","content":"Reading the invoice statuses"},"536":{"id":"/manual/accounting/overview-5","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"Purchase invoices — recording what you owe"},"537":{"id":"/manual/accounting/overview-6","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#entering-a-purchase-invoice","content":"Entering a purchase invoice"},"538":{"id":"/manual/accounting/overview-7","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#recording-payments","content":"Recording payments"},"539":{"id":"/manual/accounting/overview-8","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#how-posting-flows-to-the-chart-of-accounts","content":"How posting flows to the chart of accounts"},"540":{"id":"/manual/accounting/overview-9","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#integrating-with-quickbooks","content":"Integrating with QuickBooks"},"541":{"id":"/manual/accounting/overview-10","page_id":"/manual/accounting/overview","type":"heading","tags":[],"url":"/manual/accounting/overview#next-steps","content":"Next steps"},"542":{"id":"/manual/accounting/overview-11","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview","content":"Manufacturing is where the money is earned; accounting is where it's counted. This page\ncovers the finance side of Carbon — the invoices that bill customers and record what you\nowe suppliers, the payments that settle them, and the chart of accounts that quietly\nkeeps score in the background. You don't need to be an accountant to follow along. The core\nidea is simple: when work happens in the shop, Carbon writes the matching numbers to the\nbooks for you, so the financials always match reality."},"543":{"id":"/manual/accounting/overview-12","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview","content":"type: info"},"544":{"id":"/manual/accounting/overview-13","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview","content":"Where this fits. Accounting is the last stop in the order-to-cash chain you've been\nfollowing: a shipment goes out, then a sales\ninvoice bills for it. On the buying side, a receipt\ncomes in, then a purchase invoice records what you owe. This page picks up right where\nthose two leave off."},"545":{"id":"/manual/accounting/overview-14","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#the-two-kinds-of-invoice","content":"There are only two flavors of invoice in Carbon, and they mirror each other:"},"546":{"id":"/manual/accounting/overview-15","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#the-two-kinds-of-invoice","content":"A sales invoice (the \"AR\" in AR000025 stands for Accounts Receivable — money owed\nto you) bills a customer for what you shipped them."},"547":{"id":"/manual/accounting/overview-16","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#the-two-kinds-of-invoice","content":"A purchase invoice (the \"AP\" stands for Accounts Payable — money you owe) records\nthe bill a supplier sends you for what they delivered."},"548":{"id":"/manual/accounting/overview-17","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#the-two-kinds-of-invoice","content":"Accounts Receivable and Accounts\nPayable are just the bookkeeping names for \"money coming in\" and\n\"money going out.\" Acme has 25 sales invoices (AR000001 through AR000025) and 27 purchase\ninvoices (AP000001 through AP000027) on file."},"549":{"id":"/manual/accounting/overview-18","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#the-two-kinds-of-invoice","content":"The thing that makes Carbon different from a standalone accounting app: the invoice doesn't\nstart from a blank page. It's built from what already happened in the system — what shipped,\nwhat was received — so the numbers can't drift apart from the work."},"550":{"id":"/manual/accounting/overview-19","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#sales-invoices--billing-the-customer","content":"A sales invoice is how you get paid. In Carbon you rarely type one from scratch; you\ncreate it from a shipment. The invoice copies the customer, the parts, the quantities and\nthe prices straight off what went out the door, so the bill always matches the delivery."},"551":{"id":"/manual/accounting/overview-20","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#sales-invoices--billing-the-customer","content":"Follow the hero thread to see it: when Acme shipped 500 Counterweight Hooks to Radiant\nAerospace, that shipment became sales invoice AR000025."},"552":{"id":"/manual/accounting/overview-21","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#sales-invoices--billing-the-customer","content":"type: tip"},"553":{"id":"/manual/accounting/overview-22","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#sales-invoices--billing-the-customer","content":"Why two totals? The subtotal ($36,570.00) is the parts alone — 500 × $73.14. The\ninvoice total ($36,820.00) adds the $250.00 shipping charge. Carbon keeps the two\nseparate so the parts revenue and the freight land in different accounts. There's no tax on\nthis one (totalTax is $0), since aerospace defense parts are often tax-exempt."},"554":{"id":"/manual/accounting/overview-23","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#creating-and-sending-a-sales-invoice","content":"Open the source. Go to Sales → Sales Invoices, click New, and pick the\nshipment (or sales order) to bill. For the hero thread that's the shipment behind\nSO000069. Carbon pulls in the customer, the line for 500 CWH-A36-15, the $73.14 price\nand the $250 shipping automatically — nothing is re-keyed."},"555":{"id":"/manual/accounting/overview-24","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#creating-and-sending-a-sales-invoice","content":"Review the lines. Check the quantities and prices match what actually shipped. This is\nyour last chance to catch a wrong price or a partial shipment before the customer sees it.\nYou can add a one-off charge (like a rush fee) as an extra line if needed."},"556":{"id":"/manual/accounting/overview-25","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#creating-and-sending-a-sales-invoice","content":"Post it. Posting changes the invoice from Draft to a live receivable and writes the\naccounting entries (more on that below). The invoice number — AR000025 — is assigned, and\nthe amount now counts as money the customer owes you."},"557":{"id":"/manual/accounting/overview-26","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#creating-and-sending-a-sales-invoice","content":"Send it. Email the PDF to the customer or download it to send yourself. Carbon stamps the\ndate issued and starts the payment-terms clock — here, Net 30, meaning payment is due\n30 days out."},"558":{"id":"/manual/accounting/overview-27","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#reading-the-invoice-statuses","content":"Every sales invoice carries a status so you can see at a glance what's outstanding. Acme's\ninvoices use three:"},"559":{"id":"/manual/accounting/overview-28","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#reading-the-invoice-statuses","content":"Here's a slice of Acme's real receivables ledger. Notice it's healthy — every posted invoice\nhere has been collected:"},"560":{"id":"/manual/accounting/overview-29","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"A purchase invoice is the mirror image: it's the bill a supplier sends you. When the\nsteel arrives from Ryerson, Ryerson emails Acme a bill, and Acme enters it as a purchase\ninvoice so the books know money is owed and when it's due."},"561":{"id":"/manual/accounting/overview-30","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"The key idea here is matching. A purchase invoice is checked against two things that\nalready exist in Carbon:"},"562":{"id":"/manual/accounting/overview-31","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"The purchase order — the price and quantity you agreed to."},"563":{"id":"/manual/accounting/overview-32","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"The receipt — what actually showed up on the dock."},"564":{"id":"/manual/accounting/overview-33","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"If the supplier's bill agrees with both, you approve it with confidence. If it doesn't —\nthey billed for 100 but you only received 90, or the price crept up — Carbon shows the\nmismatch so you can query it before you pay. This is the classic three-way match that\nstops a shop from overpaying."},"565":{"id":"/manual/accounting/overview-34","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"type: info"},"566":{"id":"/manual/accounting/overview-35","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"Tying back to the PO. Acme's purchase order PO000057 to Ryerson was for A36 steel\nplate at $0.25/LB. When that steel is received and Ryerson's bill comes in, the matching\npurchase invoice records the payable against that same PO — keeping buying and accounting\nin lockstep. See Purchasing basics for the receiving\nside."},"567":{"id":"/manual/accounting/overview-36","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"Unlike Acme's tidy receivables, the payables ledger is a realistic mix — some bills are\nstill drafts, some are open and waiting, and plenty are already paid:"},"568":{"id":"/manual/accounting/overview-37","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#purchase-invoices--recording-what-you-owe","content":"Purchase invoices add a couple of statuses the sales side doesn't have. Here's the full set\nAcme uses:"},"569":{"id":"/manual/accounting/overview-38","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#entering-a-purchase-invoice","content":"Start from the PO or receipt. Go to Purchasing → Purchase Invoices → New and\nselect the purchase order the bill relates to. Carbon pre-fills the supplier, lines and\nagreed prices — for example, Ryerson's A36 steel from PO000057."},"570":{"id":"/manual/accounting/overview-39","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#entering-a-purchase-invoice","content":"Match against the receipt. Confirm the billed quantities match what you actually\nreceived. Carbon highlights any gap between ordered, received and billed so a mismatch\ncan't slip through unnoticed."},"571":{"id":"/manual/accounting/overview-40","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#entering-a-purchase-invoice","content":"Enter the supplier's bill number. Type the supplier's own invoice reference and the date\nthey issued it. This is what you'll quote if you ever need to call them about the bill."},"572":{"id":"/manual/accounting/overview-41","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#entering-a-purchase-invoice","content":"Post it. Posting moves the invoice to Open, records the payable, and sets the due\ndate from the supplier's payment terms. It's now a live bill waiting to be paid."},"573":{"id":"/manual/accounting/overview-42","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#recording-payments","content":"An invoice tells you money should move; a payment records that it did. Posting an\ninvoice and paying it are two separate steps on purpose — that gap is exactly the period an\ninvoice is \"outstanding.\""},"574":{"id":"/manual/accounting/overview-43","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#recording-payments","content":"Open the invoice you're settling — say AR000025, or a supplier bill like AP000023."},"575":{"id":"/manual/accounting/overview-44","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#recording-payments","content":"Record the payment. Enter the amount received (or paid), the date, and the method —\ncheck, ACH, wire, card. For AR000025, Radiant paid the full $36,820.00 on 2026-06-11, the\nsame day it was issued."},"576":{"id":"/manual/accounting/overview-45","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#recording-payments","content":"Carbon applies it and updates the status. A full payment flips the invoice to Paid\nand clears its balance to zero. A partial payment leaves a remaining balance and (on the\npayables side) shows as Partially Paid. The matching cash entry posts to the books\nautomatically."},"577":{"id":"/manual/accounting/overview-46","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#recording-payments","content":"type: tip"},"578":{"id":"/manual/accounting/overview-47","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#recording-payments","content":"Payment terms drive the due date. Each invoice carries a payment\nterm that Carbon uses to calculate when payment is due. Acme has\nseven configured — Net 30 is the default — plus early-payment discounts like 2% 10 Net\n30 (take 2% off if you pay within 10 days) and COD. Terms flow down from the customer\nor supplier record onto every order and invoice, so you set them once."},"579":{"id":"/manual/accounting/overview-48","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#how-posting-flows-to-the-chart-of-accounts","content":"Here's the part that makes a non-accountant nervous — and it shouldn't. The chart of\naccounts is just a numbered list of buckets the business tracks money in: cash, what\ncustomers owe, what you owe suppliers, sales, cost of goods, and so on. Acme's chart has\n93 accounts. You don't post to them by hand. When you post an invoice or a payment,\nCarbon writes the entries to the right buckets for you, following rules set up once during\ncompany setup."},"580":{"id":"/manual/accounting/overview-49","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#how-posting-flows-to-the-chart-of-accounts","content":"A few of Acme's accounts, so the names aren't a mystery:"},"581":{"id":"/manual/accounting/overview-50","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#how-posting-flows-to-the-chart-of-accounts","content":"So what actually happens when Acme posts AR000025? In plain language, two things move at\nonce — that's the \"double entry\" idea, and it's nothing more than every change has a matching\nside so the books always balance:"},"582":{"id":"/manual/accounting/overview-51","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#how-posting-flows-to-the-chart-of-accounts","content":"When Radiant pays, a second pair of entries moves the $36,820 out of Accounts Receivable\nand into Bank - Cash (1010) — the receivable is cleared and the cash is real. On the\nbuying side it's the reverse: posting AP000023 increases Accounts Payable (2010) and\ninventory or expense; paying it draws down cash."},"583":{"id":"/manual/accounting/overview-52","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#how-posting-flows-to-the-chart-of-accounts","content":"type: info"},"584":{"id":"/manual/accounting/overview-53","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#how-posting-flows-to-the-chart-of-accounts","content":"You don't need to memorize any of this. The point is that every shipment, receipt and\npayment lands in the financial statements automatically and correctly. Your accountant\ncan open the books at month-end and trust that the numbers tie back to real shop activity —\nno spreadsheet reconciliation, no double data entry."},"585":{"id":"/manual/accounting/overview-54","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#integrating-with-quickbooks","content":"Plenty of shops already run their books in QuickBooks (or another accounting package) and\nwant to keep doing so. Carbon supports that. Rather than forcing you to abandon your existing\naccounting system, Carbon can sync the financial documents it generates — invoices,\npayments, and the accounts behind them — out to QuickBooks. For the step-by-step setup, see\nIntegrating with Carbon."},"586":{"id":"/manual/accounting/overview-55","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#integrating-with-quickbooks","content":"Use Carbon's built-in chart of accounts as your system of record. Everything posts in one\nplace, and your financial statements come straight out of Carbon. Best when you want a single\ntool from shop floor to balance sheet."},"587":{"id":"/manual/accounting/overview-56","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#integrating-with-quickbooks","content":"Keep QuickBooks as the books of record and let Carbon push sales and purchase invoices\nacross so your accountant works in the tool they know. Carbon stays the source of truth for\noperations (what shipped, what was received); QuickBooks owns the financials. Map Carbon's\naccounts to your QuickBooks accounts once, and the sync keeps them aligned."},"588":{"id":"/manual/accounting/overview-57","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#integrating-with-quickbooks","content":"type: warn"},"589":{"id":"/manual/accounting/overview-58","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#integrating-with-quickbooks","content":"Decide your books-of-record up front. Pick one place to be the financial source of\ntruth — Carbon or your accounting package — and configure the integration before you start\nposting real invoices. Switching mid-stream means reconciling two sets of numbers. Because\nCarbon is API-first, other accounting systems can be\nintegrated the same way; QuickBooks is just the most common."},"590":{"id":"/manual/accounting/overview-59","page_id":"/manual/accounting/overview","tags":[],"type":"text","url":"/manual/accounting/overview#next-steps","content":"You've now seen the full order-to-cash loop close. To revisit the two stops that feed\naccounting, head back up the chain:"},"591":{"id":"/manual/buying/advanced-purchasing","page_id":"/manual/buying/advanced-purchasing","type":"page","content":"Advanced purchasing","tags":[],"url":"/manual/buying/advanced-purchasing"},"592":{"id":"/manual/buying/advanced-purchasing-0","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing","content":"Outside processing, RFQs, drop-ship and the supplier portal."},"593":{"id":"/manual/buying/advanced-purchasing-1","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#the-five-tools-on-this-page","content":"The five tools on this page"},"594":{"id":"/manual/buying/advanced-purchasing-2","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#outside-processing","content":"Outside processing"},"595":{"id":"/manual/buying/advanced-purchasing-3","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#how-an-outside-operation-sits-in-a-routing","content":"How an outside operation sits in a routing"},"596":{"id":"/manual/buying/advanced-purchasing-4","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"Set up and run an outside operation"},"597":{"id":"/manual/buying/advanced-purchasing-5","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#supplier-quotes-rfqs","content":"Supplier quotes (RFQs)"},"598":{"id":"/manual/buying/advanced-purchasing-6","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"Send an RFQ and compare the replies"},"599":{"id":"/manual/buying/advanced-purchasing-7","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#drop-ship","content":"Drop-ship"},"600":{"id":"/manual/buying/advanced-purchasing-8","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#set-up-a-drop-ship","content":"Set up a drop-ship"},"601":{"id":"/manual/buying/advanced-purchasing-9","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#the-supplier-portal","content":"The supplier portal"},"602":{"id":"/manual/buying/advanced-purchasing-10","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#purchasing-planning","content":"Purchasing planning"},"603":{"id":"/manual/buying/advanced-purchasing-11","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#turn-suggestions-into-purchase-orders","content":"Turn suggestions into purchase orders"},"604":{"id":"/manual/buying/advanced-purchasing-12","page_id":"/manual/buying/advanced-purchasing","type":"heading","tags":[],"url":"/manual/buying/advanced-purchasing#next-steps","content":"Next steps"},"605":{"id":"/manual/buying/advanced-purchasing-13","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing","content":"Purchasing basics covered the everyday loop: raise a\npurchase order, send it, receive the goods. This page is for the trickier buying jobs that\nreal shops run into — sending a half-finished part out to a specialist for a coating,\ngetting competing prices before you commit, shipping straight from your supplier to your\ncustomer, and letting Carbon tell you what to buy before a shortage stalls a job. None of\nthese are exotic; you'll likely use all of them within your first month."},"606":{"id":"/manual/buying/advanced-purchasing-14","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing","content":"type: info"},"607":{"id":"/manual/buying/advanced-purchasing-15","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing","content":"Where this fits. Everything here sits inside the buying half of the flow —\nQuote → Sales Order →\nJob → Purchasing → Shipment\n→ Invoice. Make sure you're comfortable with\nPurchasing basics and Suppliers\nfirst — this page builds on both."},"608":{"id":"/manual/buying/advanced-purchasing-16","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#the-five-tools-on-this-page","content":"Each section stands on its own — skip to whichever one you need today."},"609":{"id":"/manual/buying/advanced-purchasing-17","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#outside-processing","content":"Sometimes a step in making a part isn't something you do in-house. A part comes off your\nsaw and CNC mill in great shape, but it still needs anodizing or painting — and you\ndon't own an anodizing line. So you send the parts to a specialist supplier, they perform\nthe service, and they ship the parts back to you to finish. That round trip is called\noutside processing (also \"outside service\" or \"subcontracting\")."},"610":{"id":"/manual/buying/advanced-purchasing-18","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#outside-processing","content":"The key idea in Carbon: outside processing is just an operation in a part's\nrouting, exactly like Flame Cut or Inspection — except its type\nis Outside instead of Inside. An Inside operation runs at one of your own\nwork centers and costs you shop time. An Outside operation\nruns at a supplier, and its cost is what the supplier charges you. When the job reaches\nthat operation, Carbon helps you raise a purchase order for the service and tracks the parts\nwhile they're off-site."},"611":{"id":"/manual/buying/advanced-purchasing-19","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#outside-processing","content":"Acme uses two outside-processing suppliers, both classed as Subcontractors and Service\nProviders:"},"612":{"id":"/manual/buying/advanced-purchasing-20","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#how-an-outside-operation-sits-in-a-routing","content":"Picture a part — say an aluminum bracket — that's milled in-house and then anodized at\nAllen's Anodizing before a final inspection. Its method tree mixes\ninside and outside steps in sequence:"},"613":{"id":"/manual/buying/advanced-purchasing-21","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#how-an-outside-operation-sits-in-a-routing","content":"Operation 20 has no work center, no labor minutes, and no machine time. Instead it points\nat a supplier and carries a price. Compare that to Acme's hero part, the\nCounterweight Hook — all three of its operations (Flame Cut,\nSandblasting, Inspection) are Inside, so the whole part is made under Acme's own roof."},"614":{"id":"/manual/buying/advanced-purchasing-22","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"Add the operation to the routing and set its type to Outside. Open the part's\nManufacturing tab, add an operation where the service belongs in the sequence, and\nchoose Outside as the operation type. (You can do the same on a one-off\njob without changing the part — handy for a rush order.)"},"615":{"id":"/manual/buying/advanced-purchasing-23","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"Point it at a supplier and a service item. Pick the supplier who performs the work —\nAllen's Anodizing — and link the operation to a Service item\nif you track services as items. Enter what the supplier charges (per piece or per lot). That\nprice becomes part of the part's rolled-up cost, just like in-house labor does."},"616":{"id":"/manual/buying/advanced-purchasing-24","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"Release the job. When you release the job, the outside operation appears in its\noperation list with status Todo, sitting in sequence between the inside steps before and\nafter it."},"617":{"id":"/manual/buying/advanced-purchasing-25","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"Raise a purchase order for the service. When production reaches the outside step, create\na purchase order to the supplier for the service. Because\nthe operation is linked to the job, the PO is tied back to it — Carbon knows these parts left\nthe building for anodizing, and which job they belong to."},"618":{"id":"/manual/buying/advanced-purchasing-26","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"Ship the parts out, then receive them back. Send the work-in-progress parts to the\nsupplier. When they come back finished, record a receipt\nagainst that PO. Receiving the service marks the outside operation complete, and the job\nmoves on to the next step — here, final Inspection."},"619":{"id":"/manual/buying/advanced-purchasing-27","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"type: tip"},"620":{"id":"/manual/buying/advanced-purchasing-28","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"One supplier can do many things. A subcontractor like Sendcutsend cuts and finishes\nparts, so it can appear on outside operations for several different services. Set the\nsupplier's supplier type to Subcontractors and Service\nProviders so it's easy to find when you're building a routing."},"621":{"id":"/manual/buying/advanced-purchasing-29","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"type: warn"},"622":{"id":"/manual/buying/advanced-purchasing-30","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-and-run-an-outside-operation","content":"Outside parts are still your inventory. While parts are at the anodizer, they haven't\nbeen scrapped or shipped to a customer — they're work-in-progress that's temporarily off-site.\nDon't close the job or promise the parts as finished until you've received them back and the\noutside operation reads complete. Otherwise your job costs and on-hand counts will be wrong."},"623":{"id":"/manual/buying/advanced-purchasing-31","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#supplier-quotes-rfqs","content":"Before you buy something expensive or new, you usually want more than one price. In Carbon\nyou do that with a Request for Quote (RFQ): you describe what you want to buy, send it to\nseveral suppliers, collect their supplier quotes back, and compare them. When you pick a\nwinner, you convert the chosen quote into a purchase order — no re-typing."},"624":{"id":"/manual/buying/advanced-purchasing-32","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#supplier-quotes-rfqs","content":"A supplier quote is the buying-side mirror of the sales quote\nyou send customers. Carbon creates one for each supplier you ask, so a single RFQ can spin\noff several supplier quotes you track side by side."},"625":{"id":"/manual/buying/advanced-purchasing-33","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#supplier-quotes-rfqs","content":"Say Acme needs a big lot of 1-inch A36 steel plate and wants to shop it around. Acme's metals\nsuppliers all carry it, so the RFQ goes to four of them at once:"},"626":{"id":"/manual/buying/advanced-purchasing-34","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"Create the RFQ and add what you want priced. In the Purchasing module, create a new\nRFQ and add a line for each item you want quoted — here, one line for A36 Steel Plate 1″\n(A36-STEEL-PLT-1\".96x240) at the quantity you're planning to buy. You can add notes,\ntarget dates, and attachments (drawings, specs) per line."},"627":{"id":"/manual/buying/advanced-purchasing-35","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"Choose the suppliers and send. Add the four suppliers above as recipients. Carbon\ngenerates a supplier quote for each one and sends a request — either by email or through\nthe supplier portal, so suppliers can type their prices in directly."},"628":{"id":"/manual/buying/advanced-purchasing-36","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"Collect the replies. As suppliers respond, their prices land back on each supplier quote.\nYou'll see quotes come in at different prices, lead times, and minimum quantities. The list\nview shows you which ones are still outstanding."},"629":{"id":"/manual/buying/advanced-purchasing-37","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"Compare side by side. Open the comparison view for the RFQ. Carbon lines the\nsuppliers up against each other so the cheapest price, the best lead time, and any quantity\nbreaks jump out. You're not just chasing the lowest number — a slightly higher price that\narrives a week sooner can be the right call when a job is waiting."},"630":{"id":"/manual/buying/advanced-purchasing-38","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"Convert the winner to a purchase order. Pick the quote you want and convert it to a\npurchase order in one click. The supplier, item, price,\nand quantity carry straight over — and the PO stays linked to the quote, so you always know\nwhy you paid what you paid. That's exactly how Acme's PO000057 to Ryerson came to be:\nA36 plate at $0.25/LB."},"631":{"id":"/manual/buying/advanced-purchasing-39","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"type: tip"},"632":{"id":"/manual/buying/advanced-purchasing-40","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#send-an-rfq-and-compare-the-replies","content":"Keep the prices for next time. A supplier quote can feed a supplier's price list for\nthat item, so the next time you buy it Carbon already knows the price and lead time — no RFQ\nneeded unless you want to re-shop it."},"633":{"id":"/manual/buying/advanced-purchasing-41","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#drop-ship","content":"Normally goods you buy come to you — you receive them, then ship from your own dock. But\nsometimes it makes more sense for the supplier to ship straight to your customer. Maybe\nyou're reselling a finished item, or the part is bulky and your shop is just a middleman. That\nshortcut is a drop-shipment: you still buy it and you still bill your customer, but the\ngoods never touch your building."},"634":{"id":"/manual/buying/advanced-purchasing-42","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#drop-ship","content":"In Carbon, drop-ship is a flag that links a sales order and a purchase order together.\nAcme's hero order SO000069 is a normal (non-drop-ship) order — its dropShipment flag is\nfalse, because Acme makes those hooks in-house and ships them itself. A drop-ship order\nsets that flag to true instead."},"635":{"id":"/manual/buying/advanced-purchasing-43","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-a-drop-ship","content":"Mark the sales order line as drop-ship. On the sales order,\nturn on drop-shipment for the line. This tells Carbon not to expect the part to come out\nof your own inventory."},"636":{"id":"/manual/buying/advanced-purchasing-44","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-a-drop-ship","content":"Generate the linked purchase order. Carbon creates a purchase order to your chosen\nsupplier for that line, with the ship-to set to your customer's address rather than\nyour own warehouse. Confirm the supplier, price, and quantity."},"637":{"id":"/manual/buying/advanced-purchasing-45","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-a-drop-ship","content":"Send the PO; the supplier ships your customer. The supplier fulfills the order directly\nto the customer's door. Nothing arrives at your shop, so there's no receipt to do and no\ninventory movement on your side."},"638":{"id":"/manual/buying/advanced-purchasing-46","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-a-drop-ship","content":"Invoice the customer as usual. You still bill your customer from the sales order, and you\nstill pay the supplier from the purchase order. Your margin is the difference — Carbon tracks\nboth sides even though the goods never passed through your hands."},"639":{"id":"/manual/buying/advanced-purchasing-47","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-a-drop-ship","content":"type: warn"},"640":{"id":"/manual/buying/advanced-purchasing-48","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#set-up-a-drop-ship","content":"Drop-ship skips your inventory on purpose. Because the part never comes through your\ndock, it never appears in your on-hand stock — by\ndesign. Only use drop-ship for lines you genuinely want fulfilled supplier-to-customer. If\nyou want the goods first (to inspect, kit, or combine with other items), buy it normally and\nship it yourself."},"641":{"id":"/manual/buying/advanced-purchasing-49","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#the-supplier-portal","content":"How do suppliers actually reply to an RFQ or confirm a PO? You don't want to chase prices\nover email and re-key them by hand. Carbon gives each supplier a portal — a secure web\nlink where they can see what you've sent them and respond online, without needing a Carbon\nlogin of their own."},"642":{"id":"/manual/buying/advanced-purchasing-50","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#the-supplier-portal","content":"When you send a supplier quote or purchase order through the portal, Carbon includes a\nprivate link. The supplier clicks it and can:"},"643":{"id":"/manual/buying/advanced-purchasing-51","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#the-supplier-portal","content":"Whatever the supplier types lands straight on the matching record in your Carbon — no copy-paste,\nno transcription mistakes. Each request carries its own link, so a supplier only ever sees the\ndocuments you sent them."},"644":{"id":"/manual/buying/advanced-purchasing-52","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#the-supplier-portal","content":"type: tip"},"645":{"id":"/manual/buying/advanced-purchasing-53","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#the-supplier-portal","content":"No account, no friction. The whole point of the portal is to make it easy for suppliers\nto respond — especially small shops like an anodizer or painter who'll never log in to a full\nERP. The link does the work. The faster they can reply, the faster your RFQ comparison fills in."},"646":{"id":"/manual/buying/advanced-purchasing-54","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#purchasing-planning","content":"So far you've been creating purchase orders by hand. But how do you know what to buy in the\nfirst place? On a busy shop floor, the answer is purchasing planning — Carbon watches your\ndemand and your stock, works out where you're going to run short, and hands you a list of\nbuy suggestions you can turn into purchase orders."},"647":{"id":"/manual/buying/advanced-purchasing-55","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#purchasing-planning","content":"Demand comes from two places:"},"648":{"id":"/manual/buying/advanced-purchasing-56","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#purchasing-planning","content":"Jobs. When you release a job, its\nmethod lists the materials it needs. If you don't have enough on\nhand, that's a shortage."},"649":{"id":"/manual/buying/advanced-purchasing-57","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#purchasing-planning","content":"MRP / replenishment. For stocked items with reorder points (see\nReplenishment), Carbon flags anything that's dipped below\nits minimum."},"650":{"id":"/manual/buying/advanced-purchasing-58","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#purchasing-planning","content":"This is exactly how Acme's hero purchase order was born. Job J000097 needed 40 LB of\nA36 steel plate per piece — 20,000 LB for the batch of 500 — and Acme didn't have that\nmuch in stock. Carbon flagged the shortage, and that suggestion became purchase order\nPO000057 to Ryerson."},"651":{"id":"/manual/buying/advanced-purchasing-59","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#turn-suggestions-into-purchase-orders","content":"Open the planning view. In the Purchasing module, open purchasing planning. Carbon\nlists every item where projected demand is about to outrun supply, the quantity it suggests\nbuying, and what's driving the need (a specific job, or a reorder point)."},"652":{"id":"/manual/buying/advanced-purchasing-60","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#turn-suggestions-into-purchase-orders","content":"Review and adjust. You're in control — bump a quantity to hit a price break, change the\nsuggested supplier, or skip a line you'll handle another way. Carbon's number is a starting\npoint, not a command."},"653":{"id":"/manual/buying/advanced-purchasing-61","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#turn-suggestions-into-purchase-orders","content":"Generate the purchase orders. Select the lines you want and let Carbon create the POs.\nIt groups lines by supplier, so one click can produce several tidy orders — all the Ryerson\nitems on one PO, all the Fastenal items on another."},"654":{"id":"/manual/buying/advanced-purchasing-62","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#turn-suggestions-into-purchase-orders","content":"Approve and send. The new POs land in Draft or Needs Approval (just like\nPO000057 did). From there it's the normal purchasing basics\nloop — approve, send, receive."},"655":{"id":"/manual/buying/advanced-purchasing-63","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#turn-suggestions-into-purchase-orders","content":"type: info"},"656":{"id":"/manual/buying/advanced-purchasing-64","page_id":"/manual/buying/advanced-purchasing","tags":[],"type":"text","url":"/manual/buying/advanced-purchasing#turn-suggestions-into-purchase-orders","content":"Planning closes the loop. This is the moment the buying side connects back to\nproduction: a job creates demand, planning surfaces the shortage, a PO fills it, the\nreceipt restocks the shelf, and the job pulls the material it needs. Run planning\nregularly and shortages stop sneaking up on you."},"657":{"id":"/manual/buying/purchasing-basics","page_id":"/manual/buying/purchasing-basics","type":"page","content":"Purchasing basics","tags":[],"url":"/manual/buying/purchasing-basics"},"658":{"id":"/manual/buying/purchasing-basics-0","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics","content":"Purchase orders, receiving and supplier quotes."},"659":{"id":"/manual/buying/purchasing-basics-1","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#the-shape-of-a-purchase-order","content":"The shape of a purchase order"},"660":{"id":"/manual/buying/purchasing-basics-2","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#create-the-purchase-order","content":"Create the purchase order"},"661":{"id":"/manual/buying/purchasing-basics-3","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#open-purchasing-and-start-a-new-order","content":"Open Purchasing and start a new order"},"662":{"id":"/manual/buying/purchasing-basics-4","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#pick-the-supplier","content":"Pick the supplier"},"663":{"id":"/manual/buying/purchasing-basics-5","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#set-the-header-dates-and-delivery-location","content":"Set the header dates and delivery location"},"664":{"id":"/manual/buying/purchasing-basics-6","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#add-the-lines","content":"Add the lines"},"665":{"id":"/manual/buying/purchasing-basics-7","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#add-a-line-and-choose-the-item","content":"Add a line and choose the item"},"666":{"id":"/manual/buying/purchasing-basics-8","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#enter-quantity-unit-price-and-required-date","content":"Enter quantity, unit price and required date"},"667":{"id":"/manual/buying/purchasing-basics-9","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#review-the-line-total","content":"Review the line total"},"668":{"id":"/manual/buying/purchasing-basics-10","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#approve-it-and-send-it","content":"Approve it and send it"},"669":{"id":"/manual/buying/purchasing-basics-11","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#submit-for-approval","content":"Submit for approval"},"670":{"id":"/manual/buying/purchasing-basics-12","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#approve","content":"Approve"},"671":{"id":"/manual/buying/purchasing-basics-13","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#send-it-to-the-supplier","content":"Send it to the supplier"},"672":{"id":"/manual/buying/purchasing-basics-14","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#receive-the-goods","content":"Receive the goods"},"673":{"id":"/manual/buying/purchasing-basics-15","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#start-a-receipt-from-the-po","content":"Start a receipt from the PO"},"674":{"id":"/manual/buying/purchasing-basics-16","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#confirm-what-actually-arrived","content":"Confirm what actually arrived"},"675":{"id":"/manual/buying/purchasing-basics-17","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#enter-the-batch-lot-number","content":"Enter the batch (lot) number"},"676":{"id":"/manual/buying/purchasing-basics-18","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#post-the-receipt","content":"Post the receipt"},"677":{"id":"/manual/buying/purchasing-basics-19","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#what-happens-next","content":"What happens next"},"678":{"id":"/manual/buying/purchasing-basics-20","page_id":"/manual/buying/purchasing-basics","type":"heading","tags":[],"url":"/manual/buying/purchasing-basics#next-steps","content":"Next steps"},"679":{"id":"/manual/buying/purchasing-basics-21","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics","content":"When a job needs material you don't have on the shelf, you buy it. In Carbon you do that\nwith a purchase order (PO): a document that tells a\nsupplier exactly what you want, how much, at what price, and when\nyou need it. This page walks you through raising one, getting it approved, sending it, and —\nthe part that actually puts material on your shelf — receiving the goods against it."},"680":{"id":"/manual/buying/purchasing-basics-22","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics","content":"We'll follow a real example from Acme: PO000057, a purchase order to Ryerson (Acme's\nsteel supplier) for the A36 Steel Plate that goes into the Counterweight Hooks on job\nJ000097. Each hook eats 40 lb of plate, and the batch of 500 needs 20,000 lb — far more\nthan Acme keeps in stock — so Carbon flagged the shortage and Acme bought the steel."},"681":{"id":"/manual/buying/purchasing-basics-23","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics","content":"type: info"},"682":{"id":"/manual/buying/purchasing-basics-24","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics","content":"Where this fits. Buying sits in the middle of the end-to-end flow. A job\n(or low stock) creates a need for material → you raise a purchase order here → you\nreceive the goods, which adds them to inventory →\nthe material is consumed by the job, and the order eventually gets billed by an\naccounts-payable invoice. This is the buy-side mirror of the\nsell-side flow you saw in Carbon in 15 minutes."},"683":{"id":"/manual/buying/purchasing-basics-25","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#the-shape-of-a-purchase-order","content":"A purchase order has two parts, and they map to the tabs you'll see on the record:"},"684":{"id":"/manual/buying/purchasing-basics-26","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#the-shape-of-a-purchase-order","content":"Header (the Details tab) — who you're buying from, the order date, where it's\ndelivered, the currency, and the payment terms. One supplier per PO."},"685":{"id":"/manual/buying/purchasing-basics-27","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#the-shape-of-a-purchase-order","content":"Lines (the Lines tab) — one row per thing you're buying. Each line names an\nitem, a quantity, a unit price, and a required date (when\nyou need it on site). Line totals add up to the order total."},"686":{"id":"/manual/buying/purchasing-basics-28","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#the-shape-of-a-purchase-order","content":"A Delivery tab holds the ship-to location and any delivery notes. Here is Acme's finished\nPO000057 so you can see the whole record before we build one:"},"687":{"id":"/manual/buying/purchasing-basics-29","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#the-shape-of-a-purchase-order","content":"type: tip"},"688":{"id":"/manual/buying/purchasing-basics-30","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#the-shape-of-a-purchase-order","content":"Get a price first (the supplier quote). Before committing, you can ask one or more\nsuppliers \"what would this cost?\" with a supplier quote (Carbon calls it a request for\nquote, or RFQ). You send the item and quantity, suppliers send back a price and lead time,\nand you turn the best response into a purchase order without re-typing the lines. Acme knows\nA36 plate runs about $0.25/LB at Ryerson because that price came from earlier quotes and\norders — Carbon remembers a supplier's last price on an item and pre-fills it for you."},"689":{"id":"/manual/buying/purchasing-basics-31","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#create-the-purchase-order","content":"You can start a PO three ways: by hand, from a job's material shortage, or straight from a\nsupplier quote. We'll do it by hand so you see every field, then point out the shortcuts."},"690":{"id":"/manual/buying/purchasing-basics-32","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#open-purchasing-and-start-a-new-order","content":"Go to the Purchasing module in the left rail and choose Purchase Orders. Click\nNew Purchase Order. Carbon assigns the next number automatically — Acme's became\nPO000057 — and opens it in Draft status. Nothing is committed yet; a draft is just a\nwork-in-progress you can edit or delete freely."},"691":{"id":"/manual/buying/purchasing-basics-33","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#pick-the-supplier","content":"Choose the supplier you're buying from. Acme selects Ryerson. Picking the supplier\ndoes a lot of quiet work: Carbon fills in that supplier's currency (USD), default\npayment terms (Net 30), and the contact and address on file, so you don't re-enter them."},"692":{"id":"/manual/buying/purchasing-basics-34","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#pick-the-supplier","content":"type: warn"},"693":{"id":"/manual/buying/purchasing-basics-35","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#pick-the-supplier","content":"If the supplier doesn't exist yet, create it first — see\nSuppliers. A PO must point at a real supplier record, because\nthat's where the payment terms, addresses, and the supplier's prices live."},"694":{"id":"/manual/buying/purchasing-basics-36","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#set-the-header-dates-and-delivery-location","content":"On the Details tab, confirm the order date (2026-06-12 for Acme) and pick the\ndeliver-to location — Acme ships to Headquarters (loc_CZUGEF…), the same location\nthe job runs at. The payment terms carried over from the supplier; leave Net 30 or\noverride it for this order."},"695":{"id":"/manual/buying/purchasing-basics-37","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#add-the-lines","content":"The lines are where you say what you're buying. Each line is one item at one price."},"696":{"id":"/manual/buying/purchasing-basics-38","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#add-a-line-and-choose-the-item","content":"On the Lines tab, click Add Line. Set the line type to Part (Carbon uses \"Part\"\nas the generic line type for any stocked item, including materials), then search for the item.\nAcme picks A36 Steel Plate 1\" — readable ID A36-STEEL-PLT-1\".96x240. Carbon pulls in the\ndescription and the purchase unit of measure (LB, pounds) from the item record."},"697":{"id":"/manual/buying/purchasing-basics-39","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-quantity-unit-price-and-required-date","content":"Fill in the three numbers that matter:"},"698":{"id":"/manual/buying/purchasing-basics-40","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-quantity-unit-price-and-required-date","content":"Quantity — how much to buy. Acme orders 54,001 LB (a round buy of plate that covers\nthis job's 20,000 lb need and tops up stock for the next ones)."},"699":{"id":"/manual/buying/purchasing-basics-41","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-quantity-unit-price-and-required-date","content":"Unit price — what the supplier charges per unit. Ryerson's price is $0.25/LB.\nCarbon pre-fills the supplier's last known price, so often you just confirm it."},"700":{"id":"/manual/buying/purchasing-basics-42","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-quantity-unit-price-and-required-date","content":"Required date — the date you need it on site. Acme sets 2026-06-21. This drives\nCarbon's planning and tells you which lines are at risk of being late."},"701":{"id":"/manual/buying/purchasing-basics-43","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-quantity-unit-price-and-required-date","content":"Carbon multiplies quantity × unit price into the extended price automatically:\n54,001 × $0.25 = $13,500.25."},"702":{"id":"/manual/buying/purchasing-basics-44","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#review-the-line-total","content":"Your single line now reads like this. Carbon rolls the line extended prices up into the\norder total in the header."},"703":{"id":"/manual/buying/purchasing-basics-45","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#review-the-line-total","content":"type: tip"},"704":{"id":"/manual/buying/purchasing-basics-46","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#review-the-line-total","content":"The shortcut: buy straight from a job. Acme didn't really type this line from scratch.\nWhen job J000097 was planned, Carbon saw it needed 20,000 lb of A36 plate that wasn't in\nstock and surfaced a shortage. From there you can generate the purchase order with the\nitem, quantity, and supplier already filled in — see Jobs and\nAdvanced purchasing. Buying and making then run in\nparallel: the steel is on its way while the shop gets set up."},"705":{"id":"/manual/buying/purchasing-basics-47","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#approve-it-and-send-it","content":"A draft PO commits Acme to nothing. Two steps turn it into a real order: approval, then sending."},"706":{"id":"/manual/buying/purchasing-basics-48","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#submit-for-approval","content":"When the order is ready, you submit it for approval. Carbon moves it from Draft to\nNeeds Approval — exactly where PO000057 sits in the screenshot above. This is a control:\nspending above a threshold can require a manager's sign-off before the order goes out, so\nnobody accidentally commits the company to a five-figure steel buy. Who needs to approve what\nis configured in company settings — see Users & permissions."},"707":{"id":"/manual/buying/purchasing-basics-49","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#submit-for-approval","content":"The PO status walks through these stages as it progresses:"},"708":{"id":"/manual/buying/purchasing-basics-50","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#approve","content":"An authorized approver opens the order, checks the lines and total, and approves it.\nApproval is what unlocks sending. If something's wrong, they can reject it back to Draft for\nedits instead."},"709":{"id":"/manual/buying/purchasing-basics-51","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#send-it-to-the-supplier","content":"Once approved, click Send. Carbon generates a clean PO document (PDF) and emails it to the\nsupplier's contact on file — for Acme, that's Ryerson's contact — using the PO number as the\nreference. The order moves to To Receive: Carbon is now waiting for the steel to show up.\nYou can also download the PDF to send yourself, or share a supplier portal link."},"710":{"id":"/manual/buying/purchasing-basics-52","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#send-it-to-the-supplier","content":"type: warn"},"711":{"id":"/manual/buying/purchasing-basics-53","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#send-it-to-the-supplier","content":"Sending is not receiving. Sending the PO tells the supplier what you want; it does not\nadd anything to your inventory. Material only lands on your shelf when you receive it\nagainst the PO — that's the next step, and it's the one beginners most often forget."},"712":{"id":"/manual/buying/purchasing-basics-54","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#receive-the-goods","content":"This is the step that actually changes your stock. When the truck arrives, you create a\nreceipt against the purchase order. Receiving does three things at once:"},"713":{"id":"/manual/buying/purchasing-basics-55","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#receive-the-goods","content":"Adds the material to inventory at the deliver-to location, so it's available for the\njob to consume."},"714":{"id":"/manual/buying/purchasing-basics-56","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#receive-the-goods","content":"Records how much arrived on each PO line (quantityReceived), so Carbon knows what's\nstill outstanding if the supplier ships short or in parts."},"715":{"id":"/manual/buying/purchasing-basics-57","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#receive-the-goods","content":"For batch-tracked items, records the lot — the supplier's batch or heat number — so\nyou keep full traceability from raw steel to finished part."},"716":{"id":"/manual/buying/purchasing-basics-58","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#receive-the-goods","content":"A36 Steel Plate is batch-tracked (requiresBatchTracking: true), so the receipt will ask\nyou for a lot number. That's not bureaucracy: months later, if a hook ever fails inspection,\nAcme can trace it back to the exact heat of steel it came from — and find every other part\nmade from that same batch."},"717":{"id":"/manual/buying/purchasing-basics-59","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#start-a-receipt-from-the-po","content":"Open PO000057 and choose Receive (you can also start from the Inventory → Receipts\nlist and pick the PO). Carbon opens a new receipt and pre-loads the open lines with the\nquantity still outstanding — here, the full 54,001 LB, since nothing has been received yet."},"718":{"id":"/manual/buying/purchasing-basics-60","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#confirm-what-actually-arrived","content":"Count what came off the truck and enter the received quantity per line. If the supplier\nshipped everything, accept the suggested amount. If they shipped part of it, enter the smaller\nnumber — Carbon leaves the remainder open on the PO so you can receive the rest later. Pick the\nlocation and shelf/bin the material goes to; Acme's A36 plate lives in bin\nR02-B01-01 at Headquarters."},"719":{"id":"/manual/buying/purchasing-basics-61","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-the-batch-lot-number","content":"Because A36 plate is batch-tracked, Carbon requires a lot number for the quantity you're\nreceiving. Type the supplier's heat or batch number from the mill certificate (the steel's\npaperwork). This lot is now permanently linked to this material — when the job pulls the plate,\nCarbon records which lot it consumed."},"720":{"id":"/manual/buying/purchasing-basics-62","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-the-batch-lot-number","content":"type: info"},"721":{"id":"/manual/buying/purchasing-basics-63","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#enter-the-batch-lot-number","content":"The lot number shown (HEAT-A36-0612) is illustrative — you enter whatever batch identifier\nthe supplier's mill certificate gives you. Items that aren't batch- or serial-tracked (most\nconsumables and hardware) skip this step entirely."},"722":{"id":"/manual/buying/purchasing-basics-64","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#post-the-receipt","content":"Click Post. At that moment Carbon:"},"723":{"id":"/manual/buying/purchasing-basics-65","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#post-the-receipt","content":"Increases on-hand stock of A36 plate at Headquarters by the received quantity."},"724":{"id":"/manual/buying/purchasing-basics-66","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#post-the-receipt","content":"Stamps the PO line's quantityReceived and flips the order to To Receive (still open if\npartial) or onward toward To Invoice once everything's in."},"725":{"id":"/manual/buying/purchasing-basics-67","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#post-the-receipt","content":"Posts the inventory value to your books at the purchase cost, so accounting reflects the\nnew asset."},"726":{"id":"/manual/buying/purchasing-basics-68","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#post-the-receipt","content":"The steel is now real, on the shelf, and ready for job J000097 to consume."},"727":{"id":"/manual/buying/purchasing-basics-69","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#what-happens-next","content":"With the material received, the loop closes on its own:"},"728":{"id":"/manual/buying/purchasing-basics-70","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#what-happens-next","content":"The job consumes the A36 plate as it runs, drawing down the stock you just received and\ncarrying the lot number forward into the finished hooks."},"729":{"id":"/manual/buying/purchasing-basics-71","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#what-happens-next","content":"The supplier sends a bill, which you match to the PO and receipt as an\naccounts-payable invoice. Three-way matching (PO ↔ receipt ↔\nbill) is what lets you catch a supplier overcharging before you pay."},"730":{"id":"/manual/buying/purchasing-basics-72","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#what-happens-next","content":"type: tip"},"731":{"id":"/manual/buying/purchasing-basics-73","page_id":"/manual/buying/purchasing-basics","tags":[],"type":"text","url":"/manual/buying/purchasing-basics#what-happens-next","content":"Receiving is the hinge between buying and inventory. Everything before the receipt is\npaperwork; the receipt is the moment material becomes real stock you can use and value. For\nthe full picture of stock, shelves, bins and receipts, see\nLocations & stock and\nShipping & receiving."},"732":{"id":"/manual/buying/suppliers","page_id":"/manual/buying/suppliers","type":"page","content":"Suppliers","tags":[],"url":"/manual/buying/suppliers"},"733":{"id":"/manual/buying/suppliers-0","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers","content":"Set up the vendors you buy materials and services from."},"734":{"id":"/manual/buying/suppliers-1","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#what-a-supplier-record-holds","content":"What a supplier record holds"},"735":{"id":"/manual/buying/suppliers-2","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#acmes-suppliers","content":"Acme's suppliers"},"736":{"id":"/manual/buying/suppliers-3","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#supplier-types-and-statuses","content":"Supplier types and statuses"},"737":{"id":"/manual/buying/suppliers-4","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#create-a-supplier","content":"Create a supplier"},"738":{"id":"/manual/buying/suppliers-5","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#open-the-new-supplier-form","content":"Open the new-supplier form"},"739":{"id":"/manual/buying/suppliers-6","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#fill-in-the-core-details","content":"Fill in the core details"},"740":{"id":"/manual/buying/suppliers-7","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#add-a-contact","content":"Add a contact"},"741":{"id":"/manual/buying/suppliers-8","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#add-a-location","content":"Add a location"},"742":{"id":"/manual/buying/suppliers-9","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#set-payment-terms","content":"Set payment terms"},"743":{"id":"/manual/buying/suppliers-10","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#link-supplier-part-numbers","content":"Link supplier part numbers"},"744":{"id":"/manual/buying/suppliers-11","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#the-finished-supplier","content":"The finished supplier"},"745":{"id":"/manual/buying/suppliers-12","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#how-a-purchase-order-pulls-it-together","content":"How a purchase order pulls it together"},"746":{"id":"/manual/buying/suppliers-13","page_id":"/manual/buying/suppliers","type":"heading","tags":[],"url":"/manual/buying/suppliers#next-steps","content":"Next steps"},"747":{"id":"/manual/buying/suppliers-14","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers","content":"A supplier (also called a vendor) is any company you buy from — the steel mill that\nsells you plate, the electronics distributor that ships you resistors, the anodizer that\nfinishes your parts. Before you can raise a purchase order,\nCarbon needs to know who the supplier is, how to reach them, where to send the order, and\nhow you've agreed to pay. This page walks you through creating a supplier and filling in\nthose details, using Acme's real vendor list as the example."},"748":{"id":"/manual/buying/suppliers-15","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers","content":"type: info"},"749":{"id":"/manual/buying/suppliers-16","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers","content":"Where this fits. Suppliers are the foundation of the whole buying flow. Once a\nsupplier exists, you can raise purchase orders against it\n(Purchasing basics), receive what they send, and pay\ntheir invoices. In the hero thread, Acme buys A36 steel plate from\nRyerson on purchase order PO000057 — and that only works because Ryerson was set up\nas a supplier first."},"750":{"id":"/manual/buying/suppliers-17","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#what-a-supplier-record-holds","content":"A supplier in Carbon is a small folder of related information. You don't have to fill it all\nin at once — a name is enough to start — but the more you add, the less you re-type later."},"751":{"id":"/manual/buying/suppliers-18","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#what-a-supplier-record-holds","content":"Carbon gives every supplier a short readable ID like SUP000013 so you can refer to it\nquickly, while still showing the friendly name everywhere. You'll see both throughout the app."},"752":{"id":"/manual/buying/suppliers-19","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#acmes-suppliers","content":"Here's the vendor list a real shop keeps. Notice the mix: metal mills, electronics\ndistributors, industrial-supply catalogs, fasteners, and outside-service shops. The\nType column groups them so you can filter the list later."},"753":{"id":"/manual/buying/suppliers-20","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#acmes-suppliers","content":"type: tip"},"754":{"id":"/manual/buying/suppliers-21","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#acmes-suppliers","content":"The supplier ID values shown here (SUP0000xx) follow Carbon's sequential numbering.\nYour own shop's IDs will differ — what matters is that each supplier has one, and that\nit stays stable even if you rename the company."},"755":{"id":"/manual/buying/suppliers-22","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#supplier-types-and-statuses","content":"Two small fields shape how a supplier behaves in the app."},"756":{"id":"/manual/buying/suppliers-23","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#supplier-types-and-statuses","content":"Supplier type is a label you assign so you can group and filter vendors. It's purely\norganizational — it doesn't change pricing or accounting. Acme uses five types:"},"757":{"id":"/manual/buying/suppliers-24","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#supplier-types-and-statuses","content":"Status controls whether you can buy from a vendor right now. An Active supplier is\navailable everywhere you pick a vendor; an Inactive one is hidden from new purchase\norders but kept for history. This is how you retire a supplier you no longer use without\ndeleting years of records."},"758":{"id":"/manual/buying/suppliers-25","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#supplier-types-and-statuses","content":"type: tip"},"759":{"id":"/manual/buying/suppliers-26","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#supplier-types-and-statuses","content":"You define the list of supplier types yourself in Settings, so you can make them\nmatch how your shop thinks about its vendors. There's no fixed list — these five are just\nthe ones Acme chose."},"760":{"id":"/manual/buying/suppliers-27","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#create-a-supplier","content":"Let's add a new vendor from scratch. We'll use Ryerson, Acme's steel mill, as the\nworked example."},"761":{"id":"/manual/buying/suppliers-28","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#open-the-new-supplier-form","content":"Go to Purchasing → Suppliers and click New. Carbon opens a short form. The only\nfield you must fill in is the Name — everything else can wait."},"762":{"id":"/manual/buying/suppliers-29","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#fill-in-the-core-details","content":"Give the supplier a name, pick its type, and confirm the currency you'll trade in.\nCarbon defaults the currency to your company's base currency (USD for Acme); change it only\nif you pay this vendor in another currency."},"763":{"id":"/manual/buying/suppliers-30","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#fill-in-the-core-details","content":"Click Save. Carbon assigns the next ID (SUP000013 for Ryerson) and opens the full\nrecord, where the remaining tabs — Contacts, Locations, Payment, and more — become available."},"764":{"id":"/manual/buying/suppliers-31","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#add-a-contact","content":"A contact is a person at the supplier you actually deal with — a salesperson who quotes\nyou steel, or an accounts-receivable clerk you send payment questions to. Open the\nContacts tab and click New to add one with a name, email, and phone."},"765":{"id":"/manual/buying/suppliers-32","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#add-a-contact","content":"The contact you mark as the purchasing contact is the one Carbon emails when you send a\npurchase order, so make sure it's the person who takes orders. A supplier can have as many\ncontacts as you like — keep the right people on file and you never have to dig through old\nemails for an address."},"766":{"id":"/manual/buying/suppliers-33","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#add-a-location","content":"A location is a supplier address — typically where they ship from, or where you send\nremittance. Open the Locations tab, click New, and enter the address. If a vendor\nships from several plants, add one location per site and pick the right one on each purchase\norder."},"767":{"id":"/manual/buying/suppliers-34","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#add-a-location","content":"type: tip"},"768":{"id":"/manual/buying/suppliers-35","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#add-a-location","content":"For Acme, Ryerson and most vendors have a single location, so Carbon fills it in\nautomatically on every purchase order. You only have to choose when a supplier has more\nthan one."},"769":{"id":"/manual/buying/suppliers-36","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#set-payment-terms","content":"Payment terms describe when you've agreed to pay — for example, Net 30 means the\ninvoice is due 30 days after it's issued. Setting a default here means every new purchase\norder and supplier invoice starts with the right terms, so your accounting team isn't\nguessing."},"770":{"id":"/manual/buying/suppliers-37","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#set-payment-terms","content":"Open the Payment tab and choose from the terms your company has defined:"},"771":{"id":"/manual/buying/suppliers-38","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#set-payment-terms","content":"Acme buys from Ryerson on Net 30 — the same terms that carry onto purchase order\nPO000057 in the hero thread."},"772":{"id":"/manual/buying/suppliers-39","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#link-supplier-part-numbers","content":"Your vendor almost never calls a part by your part number. Ryerson has its own catalog\nnumber for the steel plate that Acme knows as A36-STEEL-PLT-1\".96x240. A supplier part\nlinks the two: it records the supplier's part number and their price for one of your\nitems, so the right number prints on the purchase order and the\nprice fills in automatically."},"773":{"id":"/manual/buying/suppliers-40","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#link-supplier-part-numbers","content":"You can add supplier parts from either side:"},"774":{"id":"/manual/buying/suppliers-41","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#link-supplier-part-numbers","content":"From the supplier, on the Supplier Parts tab — useful when onboarding a vendor's\nfull catalog."},"775":{"id":"/manual/buying/suppliers-42","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#link-supplier-part-numbers","content":"From the item, on the item's Suppliers / Purchasing tab — useful when you want\nto know \"who can sell me this, and for how much?\""},"776":{"id":"/manual/buying/suppliers-43","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#link-supplier-part-numbers","content":"For each link you record the supplier, their part number, the price (and optional\nprice breaks for larger quantities), and the supplier's unit of measure. With that in\nplace, picking Ryerson on a purchase order line for A36 plate auto-fills the $0.25/LB\nprice Acme negotiated."},"777":{"id":"/manual/buying/suppliers-44","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#the-finished-supplier","content":"Here's what Ryerson looks like once it's fully set up — the record that the rest of the\nbuying flow leans on."},"778":{"id":"/manual/buying/suppliers-45","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#the-finished-supplier","content":"Once a supplier is this complete, raising a purchase order is mostly point-and-click: pick\nRyerson, pick the material, and Carbon already knows the contact to email, the address to\nship from, the terms to bill on, and the price to expect."},"779":{"id":"/manual/buying/suppliers-46","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#the-finished-supplier","content":"type: warn"},"780":{"id":"/manual/buying/suppliers-47","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#the-finished-supplier","content":"Don't create a second supplier record for a vendor you already have — for example a\nseparate \"Ryerson Inc.\" alongside \"Ryerson.\" Duplicates split your purchase history and\nspending across two records and make reporting unreliable. Search the supplier list first;\nif the vendor exists, reuse it."},"781":{"id":"/manual/buying/suppliers-48","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#how-a-purchase-order-pulls-it-together","content":"Every supplier field you fill in shows up downstream. When Acme raises PO000057, the\nsupplier record does the work:"},"782":{"id":"/manual/buying/suppliers-49","page_id":"/manual/buying/suppliers","tags":[],"type":"text","url":"/manual/buying/suppliers#how-a-purchase-order-pulls-it-together","content":"That's the payoff for setting suppliers up carefully: the data you enter once flows into\nevery order, receipt, and payment that follows."},"783":{"id":"/manual/developing/integrating","page_id":"/manual/developing/integrating","type":"page","content":"Integrating with Carbon","tags":[],"url":"/manual/developing/integrating"},"784":{"id":"/manual/developing/integrating-0","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating","content":"Webhooks, integrations and extending the platform."},"785":{"id":"/manual/developing/integrating-1","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#the-philosophy-carbon-is-a-platform-not-a-box","content":"The philosophy: Carbon is a platform, not a box"},"786":{"id":"/manual/developing/integrating-2","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#the-two-directions-data-flows","content":"The two directions data flows"},"787":{"id":"/manual/developing/integrating-3","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Webhooks: let Carbon tell you when things happen"},"788":{"id":"/manual/developing/integrating-4","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#building-your-own-apps-on-the-api","content":"Building your own apps on the API"},"789":{"id":"/manual/developing/integrating-5","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#example-integrations-clone-read-adapt","content":"Example integrations: clone, read, adapt"},"790":{"id":"/manual/developing/integrating-6","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#quote-configurator","content":"quote-configurator"},"791":{"id":"/manual/developing/integrating-7","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#upload-3d-model","content":"upload-3d-model"},"792":{"id":"/manual/developing/integrating-8","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"The QuickBooks sync: a real integration, end to end"},"793":{"id":"/manual/developing/integrating-9","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#putting-it-together","content":"Putting it together"},"794":{"id":"/manual/developing/integrating-10","page_id":"/manual/developing/integrating","type":"heading","tags":[],"url":"/manual/developing/integrating#next-steps","content":"Next steps"},"795":{"id":"/manual/developing/integrating-11","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating","content":"Most ERP systems are a closed box: you get the screens the vendor built, and that's the end\nof it. Carbon is the opposite — it's a platform you extend. Everything you see in the app\nis built on the same public API you can call yourself, so the\nfeatures you wish existed are ones you (or a developer) can add. This page is the map of the\nseams: the webhooks that tell other systems when something happens, the API you build\napps on, the open-source example integrations Carbon ships, and the QuickBooks sync\nthat keeps your books in step. You don't have to write code to read this — but by the end\nyou'll know exactly where the plugs are."},"796":{"id":"/manual/developing/integrating-12","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating","content":"type: info"},"797":{"id":"/manual/developing/integrating-13","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating","content":"Where this fits. This is the last stop in the Developing chapter. Read\nUsing the API first to create a key and make your first\ncall, then AI & the MCP server to let AI assistants operate\nCarbon. This page assembles those pieces into real connections to the outside world."},"798":{"id":"/manual/developing/integrating-14","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-philosophy-carbon-is-a-platform-not-a-box","content":"Before the how-to, it helps to understand why extending Carbon feels different from bolting\nonto a traditional ERP. Three design choices make it work."},"799":{"id":"/manual/developing/integrating-15","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-philosophy-carbon-is-a-platform-not-a-box","content":"A single API. There is no \"internal\" API the app gets and a weaker \"public\" one you're\nhanded. The Counterweight Hook order you followed in the\nwalkthrough — quote Q000061, sales order SO000069, job J000097 —\nwas created through the same endpoints your own code can call. If the app can do it, so can you."},"800":{"id":"/manual/developing/integrating-16","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-philosophy-carbon-is-a-platform-not-a-box","content":"Full-stack type safety. Carbon is written in TypeScript from the database schema up\nthrough the UI. The shape of a sales order is defined once and flows everywhere, so an\nitemId or a unitPrice means the same thing in the database, in the app, and in your\nintegration. Fewer surprises, fewer \"what does this field actually contain?\" guessing games."},"801":{"id":"/manual/developing/integrating-17","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-philosophy-carbon-is-a-platform-not-a-box","content":"Open source. The whole system lives on GitHub. When you're unsure how a feature behaves,\nyou can read the actual code instead of filing a support ticket — and the example integrations\nbelow are real, runnable repositories you can clone, study, and adapt."},"802":{"id":"/manual/developing/integrating-18","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-philosophy-carbon-is-a-platform-not-a-box","content":"type: tip"},"803":{"id":"/manual/developing/integrating-19","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-philosophy-carbon-is-a-platform-not-a-box","content":"The mental model: Carbon is the system of record, and integrations are conversations with\nit. Your code asks questions (\"what shipped today?\") and makes changes (\"create this quote\"),\nand webhooks let Carbon start the conversation too (\"hey, a sales order was just confirmed\")."},"804":{"id":"/manual/developing/integrating-20","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-two-directions-data-flows","content":"Every integration is some mix of two directions. Knowing which one you need tells you which\ntool to reach for."},"805":{"id":"/manual/developing/integrating-21","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-two-directions-data-flows","content":"Most real integrations use both of the first two: a webhook tells you something happened, and\nan API call then asks for the details. The QuickBooks sync later in this page is exactly that\npattern."},"806":{"id":"/manual/developing/integrating-22","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"A webhook is a way for Carbon to call you. Instead of your code constantly asking \"anything\nnew yet?\", you register a URL once, and Carbon sends an HTTP request to that URL whenever an\nevent you care about occurs. Think of it as Carbon tapping you on the shoulder."},"807":{"id":"/manual/developing/integrating-23","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Here's the chain for our hero order. When Acme marks sales order SO000069 confirmed, Carbon can\nfire an event; your endpoint receives it and does whatever you need — notify a Slack channel,\nupdate a customer portal, kick off a shipping label."},"808":{"id":"/manual/developing/integrating-24","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Decide what you want to hear about. Webhooks are organized around events — a record being\ncreated, updated, or reaching a certain status. Common ones for a shop like Acme: a quote sent, a\nsales order confirmed, a job completed, a shipment shipped, an invoice paid. You only subscribe to\nthe events you'll act on."},"809":{"id":"/manual/developing/integrating-25","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Stand up a URL to receive them. Your endpoint is just a small web service that accepts an\nHTTP POST. Carbon sends a JSON body describing what happened. The body identifies the record so\nyour code knows what to look up."},"810":{"id":"/manual/developing/integrating-26","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"type: warn"},"811":{"id":"/manual/developing/integrating-27","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Webhook payloads are deliberately lean — they tell you what and which record, not every\nfield. That's by design: it keeps payloads small and avoids stale data. When you receive one,\ncall the API with the recordId to fetch the current, authoritative details (see the next\nsection). Never treat the payload itself as the full picture."},"812":{"id":"/manual/developing/integrating-28","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Verify it really came from Carbon. Because your URL is public, anyone could POST to it.\nCarbon signs each request so you can confirm it's genuine. Always verify the signature before you\nact, and respond quickly with a 2xx status — do the slow work (looking things up, calling other\nsystems) after you've acknowledged receipt, so Carbon doesn't think delivery failed and retry."},"813":{"id":"/manual/developing/integrating-29","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Act on it. Now your handler does the useful part: enrich the event with an API call, then\npush the result wherever it needs to go. For SO000069, that might mean fetching the line for\n500 Counterweight Hooks at $73.14 and dropping a \"New order: $36,820 from Radiant Aerospace\"\nmessage into Slack."},"814":{"id":"/manual/developing/integrating-30","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"type: tip"},"815":{"id":"/manual/developing/integrating-31","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#webhooks-let-carbon-tell-you-when-things-happen","content":"Events vs. polling: if you find yourself running a script every five minutes that asks Carbon\n\"anything new?\", that's a job for a webhook. Polling wastes calls and adds delay; webhooks fire\nthe instant the thing happens."},"816":{"id":"/manual/developing/integrating-32","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#building-your-own-apps-on-the-api","content":"When you need to do something to Carbon — read data, create records, change a status — you use\nthe API. The same API powers the entire app, so anything you've done by clicking, you can do with\ncode. The Using the API page covers keys and your first call\nin detail; here's the shape of what's possible."},"817":{"id":"/manual/developing/integrating-33","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#building-your-own-apps-on-the-api","content":"A read against our hero data is as direct as it sounds — ask for sales order SO000069, get its\nlines back. This is the same official client you set up in\nUsing the API, so a webhook handler can fetch by the\nrecordId it received:"},"818":{"id":"/manual/developing/integrating-34","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#building-your-own-apps-on-the-api","content":"type: info"},"819":{"id":"/manual/developing/integrating-35","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#building-your-own-apps-on-the-api","content":"Because Carbon is type-safe end to end, the fields you see here — salesOrderId, customerId,\nunitPrice — are the exact same names used inside the app and in the example repos below. There's\nno separate \"integration data model\" to learn. Field names from this manual carry straight over\nto your code."},"820":{"id":"/manual/developing/integrating-36","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#example-integrations-clone-read-adapt","content":"Carbon publishes real, open-source integrations you can run yourself. They're the fastest way to\ngo from \"I think this is possible\" to a working pattern, because they show the whole loop — API\ncalls, webhooks, and a real UI — in code you can read."},"821":{"id":"/manual/developing/integrating-37","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#quote-configurator","content":"A configurator asks the customer a few questions — size, material, finish — and turns the\nanswers into a priced quote automatically. It's how a shop sells made-to-order parts without a\nsalesperson re-pricing every variation by hand. Acme already has one in its item list: the\nFlame Cut Part Configurator (FLAME CONFIG)."},"822":{"id":"/manual/developing/integrating-38","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#quote-configurator","content":"This example is a small web app: the customer makes choices in the browser, the app computes a\nprice, and it creates a quote in Carbon through the API — the same Q000061-style quote you'd\nbuild by hand in Quoting, just driven by configuration instead of\ntyping."},"823":{"id":"/manual/developing/integrating-39","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#upload-3d-model","content":"Parts aren't just numbers — they have geometry. This example lets you attach a 3D model to an\nitem so anyone looking at the part can see it. The Counterweight Hook\nalready carries one: its modelName is counterweight hook 3d.stl. The repo shows how to take a\nmodel file, upload it, and link it to the right item through the API — handy if your CAD system or\na customer portal needs to push models into Carbon automatically."},"824":{"id":"/manual/developing/integrating-40","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#upload-3d-model","content":"type: tip"},"825":{"id":"/manual/developing/integrating-41","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#upload-3d-model","content":"Treat these repos as templates, not products. Clone one, point it at your own Carbon company\nwith your API key, and reshape it. Because they're open source and use the same field names as\nthe app, the gap between \"example\" and \"the thing I actually need\" is usually small."},"826":{"id":"/manual/developing/integrating-42","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"The most common real-world integration is keeping your accounting system in step. Acme runs\nits books in QuickBooks, and the Carbon → QuickBooks sync is a\ntextbook example of the webhook-plus-API pattern: Carbon owns the operational truth (what was made,\nshipped, and billed), and QuickBooks owns the financial truth (the general ledger). The sync keeps\nthem agreeing without double data entry."},"827":{"id":"/manual/developing/integrating-43","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"Follow invoice AR000025 — the $36,820 bill for Radiant Aerospace's 500 hooks — from Carbon\ninto QuickBooks:"},"828":{"id":"/manual/developing/integrating-44","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"Connect the two systems once. You authorize Carbon to talk to your QuickBooks company. After\nthat, the link persists — you don't log in every time."},"829":{"id":"/manual/developing/integrating-45","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"Match the records that already exist. Both systems have customers and items, so the sync maps\nthem to each other: Carbon's Radiant Aerospace (cust_LxoH7AbowNVjTwGSoqkW1Q) links to the\nmatching QuickBooks customer, so amounts land on the right account. This mapping is the part worth\ngetting right — it's what stops the same customer appearing twice."},"830":{"id":"/manual/developing/integrating-46","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"Carbon posts an invoice. When Acme issues AR000025, that's the trigger. A webhook fires and\nthe sync service wakes up."},"831":{"id":"/manual/developing/integrating-47","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"The sync fetches the details and writes them across. Using the recordId from the webhook, it\npulls the full invoice — subtotal $36,570, $250 shipping, invoiceTotal $36,820 — and\ncreates the matching invoice in QuickBooks. When Radiant pays and Carbon marks it Paid, that\nstatus can flow over too."},"832":{"id":"/manual/developing/integrating-48","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"type: warn"},"833":{"id":"/manual/developing/integrating-49","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#the-quickbooks-sync-a-real-integration-end-to-end","content":"Decide who owns each piece of data before you connect anything. In Acme's setup Carbon is the\nsource of truth for invoices and QuickBooks just receives them — so nobody hand-keys an invoice\nin QuickBooks that Carbon doesn't know about. Two systems both editing the same field is the\nfastest way to create a reconciliation headache. Pick one owner per field and let the sync flow\none way."},"834":{"id":"/manual/developing/integrating-50","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#putting-it-together","content":"A complete integration usually wires all of these together. Here's the anatomy of Acme's setup,\nusing only records you've already met:"},"835":{"id":"/manual/developing/integrating-51","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#putting-it-together","content":"type: info"},"836":{"id":"/manual/developing/integrating-52","page_id":"/manual/developing/integrating","tags":[],"type":"text","url":"/manual/developing/integrating#putting-it-together","content":"Notice there's nothing magic here — every step is a normal API call or a normal HTTP request.\nThat's the whole point of an open platform: the same building blocks the QuickBooks sync uses are\nthe ones available to you for the integration you have in mind, whether that's a customer portal,\na webstore connector, or a TV dashboard on the shop floor."},"837":{"id":"/manual/developing/mcp-and-ai","page_id":"/manual/developing/mcp-and-ai","type":"page","content":"AI & the MCP server","tags":[],"url":"/manual/developing/mcp-and-ai"},"838":{"id":"/manual/developing/mcp-and-ai-0","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai","content":"Let AI assistants work in Carbon through the Model Context Protocol."},"839":{"id":"/manual/developing/mcp-and-ai-1","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#what-is-mcp","content":"What is MCP?"},"840":{"id":"/manual/developing/mcp-and-ai-2","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"The three meta-tools"},"841":{"id":"/manual/developing/mcp-and-ai-3","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#tool-safety-classes","content":"Tool safety classes"},"842":{"id":"/manual/developing/mcp-and-ai-4","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"What you can actually ask"},"843":{"id":"/manual/developing/mcp-and-ai-5","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#how-the-assistant-reaches-carbon","content":"How the assistant reaches Carbon"},"844":{"id":"/manual/developing/mcp-and-ai-6","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"Connect an assistant"},"845":{"id":"/manual/developing/mcp-and-ai-7","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#a-worked-example-end-to-end","content":"A worked example, end to end"},"846":{"id":"/manual/developing/mcp-and-ai-8","page_id":"/manual/developing/mcp-and-ai","type":"heading","tags":[],"url":"/manual/developing/mcp-and-ai#next-steps","content":"Next steps"},"847":{"id":"/manual/developing/mcp-and-ai-9","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai","content":"Carbon ships with a built-in MCP server — a standard way to let an AI assistant read\nand act inside your Carbon company using plain English. Instead of clicking through screens,\nyou can ask Claude, ChatGPT, or your code editor \"what's the on-hand quantity of A36 steel?\"\nor \"release every sales order stuck in Needs Approval for three days\" — and the assistant\ndoes it by calling the same Carbon API the app itself uses. This page explains what MCP is,\nhow Carbon's server is organized, how to keep it safe, and how to connect an assistant."},"848":{"id":"/manual/developing/mcp-and-ai-10","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai","content":"type: info"},"849":{"id":"/manual/developing/mcp-and-ai-11","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai","content":"Where this fits. This is the second of the three Developing pages. The\nAPI is the raw machinery — every action in Carbon as a\ncallable endpoint. MCP wraps that same machinery so an AI assistant can drive it for\nyou. If you'd rather wire Carbon to another system than talk to it, jump to\nIntegrating with other systems."},"850":{"id":"/manual/developing/mcp-and-ai-12","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-is-mcp","content":"MCP stands for the Model Context Protocol — an open\nstandard that lets AI assistants connect to outside tools and data in a consistent way. Think\nof it like a USB port for AI: any assistant that \"speaks MCP\" can plug into any system that\nexposes an MCP server, with no custom glue code in between."},"851":{"id":"/manual/developing/mcp-and-ai-13","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-is-mcp","content":"A Carbon MCP server is just a program that lists the things an assistant is allowed to do\n(these are called tools) and runs them on request. When you ask a connected assistant a\nquestion, it picks the right Carbon tools, fills in the details, and reports back — reading\nrecords, drafting documents, or making changes, depending on what you've allowed."},"852":{"id":"/manual/developing/mcp-and-ai-14","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-is-mcp","content":"Carbon's server exposes roughly 1,188 tools spanning 15 modules — Sales, Purchasing,\nItems, Production, Inventory, Quality, Accounting, Resources, and more. In practice that means\nnearly anything you can do by clicking in Carbon, an assistant can do through MCP."},"853":{"id":"/manual/developing/mcp-and-ai-15","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-is-mcp","content":"type: tip"},"854":{"id":"/manual/developing/mcp-and-ai-16","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-is-mcp","content":"Carbon hosts this for you at app.carbon.ms/mcp. The server you connect to is the same\none Carbon's own AI features use — there's nothing to install or run on your own machine."},"855":{"id":"/manual/developing/mcp-and-ai-17","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"A thousand-plus tools is far too many to hand an assistant all at once — it would overwhelm\nthe model's context before it answered a single question. So Carbon's server hides the full\ncatalog behind just three \"meta-tools\" that the assistant uses to discover and run\neverything else on demand."},"856":{"id":"/manual/developing/mcp-and-ai-18","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"The flow is always the same: search, then describe (optional), then call. Suppose you\nask \"what's the on-hand quantity of A36 steel?\" Behind the scenes the assistant:"},"857":{"id":"/manual/developing/mcp-and-ai-19","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"Searches for the right tool. It calls search_tools({ query: \"inventory quantity\" }) and\ngets back candidate tool names like inventory_getItemQuantities."},"858":{"id":"/manual/developing/mcp-and-ai-20","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"Checks the inputs. If it's unsure what parameters the tool needs, it calls\ndescribe_tool({ name: \"inventory_getItemQuantities\" }) to read the schema — which fields are\nrequired, what shape the response takes."},"859":{"id":"/manual/developing/mcp-and-ai-21","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"Calls the tool. It runs call_tool with the item ID for A36 Steel Plate\n(A36-STEEL-PLT-1\".96x240) and reads the result back to you in a sentence: \"There's none on\nhand at Headquarters right now — every pound is committed to open jobs.\""},"860":{"id":"/manual/developing/mcp-and-ai-22","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"You never see these three steps — you just see the answer. But knowing the pattern helps you\nunderstand what your assistant is doing and why an answer occasionally takes a couple of\nround-trips."},"861":{"id":"/manual/developing/mcp-and-ai-23","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"type: info"},"862":{"id":"/manual/developing/mcp-and-ai-24","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#the-three-meta-tools","content":"Every result comes back in the same envelope: { data, error?, count? }. The assistant\nreads data for the answer, checks error if something went wrong, and uses count to know\nhow many records matched. IDs like companyId are filled in automatically from your\ncredentials, so you never have to specify which company you're working in."},"863":{"id":"/manual/developing/mcp-and-ai-25","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#tool-safety-classes","content":"Not every tool is equal. Reading the on-hand quantity of steel is harmless; deleting a sales\norder is not. So Carbon tags every tool with one of three safety classifications, and\nyou can filter by them — for example, search_tools({ classification: \"READ\" }) to surface\nonly the look-but-don't-touch tools."},"864":{"id":"/manual/developing/mcp-and-ai-26","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#tool-safety-classes","content":"type: warn"},"865":{"id":"/manual/developing/mcp-and-ai-27","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#tool-safety-classes","content":"Treat WRITE and DESTRUCTIVE tools like a teammate with edit access. An assistant calling\nthem is making real changes to your live company data — the same as if a colleague clicked\nthe buttons. When you're exploring or learning, keep your assistant to READ tools only.\nTurn on WRITE access deliberately, for a specific task, with a human reviewing the result."},"866":{"id":"/manual/developing/mcp-and-ai-28","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"The point of MCP isn't to memorize tool names — it's to describe what you want in plain\nlanguage and let the assistant find the tools. Here are realistic asks against Acme's data, and\nroughly what happens under the hood."},"867":{"id":"/manual/developing/mcp-and-ai-29","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"What's the on-hand quantity of A36 steel?\""},"868":{"id":"/manual/developing/mcp-and-ai-30","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"A pure READ request. The assistant searches for an inventory tool, calls it with the A36\nplate's item ID, and answers in a sentence. Nothing changes. Other safe reads:"},"869":{"id":"/manual/developing/mcp-and-ai-31","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"Show me every job for Radiant Aerospace that isn't finished yet.\""},"870":{"id":"/manual/developing/mcp-and-ai-32","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"What did we invoice Radiant on AR000025, and is it paid?\""},"871":{"id":"/manual/developing/mcp-and-ai-33","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"List open purchase orders to Ryerson.\""},"872":{"id":"/manual/developing/mcp-and-ai-34","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"Which sales orders have been stuck in Needs Approval for three or more days?\""},"873":{"id":"/manual/developing/mcp-and-ai-35","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"The assistant reads the sales-order list (a READ call), filters by status and date, and\nhands you the offenders. This is the sweet spot for MCP — turning a question that would take\nseveral filtered screens into one sentence. Similar triage asks:"},"874":{"id":"/manual/developing/mcp-and-ai-36","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"Any purchase orders sitting in Draft older than a week?\" (PO000056 to Ryerson would surface.)"},"875":{"id":"/manual/developing/mcp-and-ai-37","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"List jobs past their due date that aren't complete.\""},"876":{"id":"/manual/developing/mcp-and-ai-38","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"Which invoices are overdue and unpaid?\""},"877":{"id":"/manual/developing/mcp-and-ai-39","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"Release every sales order stuck in Needs Approval for three or more days.\""},"878":{"id":"/manual/developing/mcp-and-ai-40","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"Now the assistant first reads to find the stuck orders, then issues a WRITE call per\norder to release each one. Because these tools change live data, you'll want to have approved\nWRITE access and to review the list before it acts. Other action asks:"},"879":{"id":"/manual/developing/mcp-and-ai-41","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"Create a quote for 500 Counterweight Hooks for Radiant Aerospace at $73.14 each.\""},"880":{"id":"/manual/developing/mcp-and-ai-42","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"\"Bump the priority on job J000099 to the top of the queue.\""},"881":{"id":"/manual/developing/mcp-and-ai-43","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"type: tip"},"882":{"id":"/manual/developing/mcp-and-ai-44","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#what-you-can-actually-ask","content":"Good prompts are specific. \"Release the stuck orders\" is fine; \"Release sales orders in\nNeeds Approval with an order date 3+ days ago, and show me the list first\" gives the\nassistant a clean target and you a checkpoint before anything changes."},"883":{"id":"/manual/developing/mcp-and-ai-45","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#how-the-assistant-reaches-carbon","content":"When you connect an assistant, two things happen on every request: the assistant authenticates\nas a real Carbon user, and Carbon enforces that user's permissions on every tool call."},"884":{"id":"/manual/developing/mcp-and-ai-46","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#how-the-assistant-reaches-carbon","content":"Authentication uses either an OAuth sign-in (you log in to Carbon once, the\nassistant gets a scoped token) or an API key you generate in Carbon's settings — the\nsame key you'd use for the API."},"885":{"id":"/manual/developing/mcp-and-ai-47","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#how-the-assistant-reaches-carbon","content":"Permissions are inherited from whoever the credentials belong to. If a user can't delete\nsales orders in the app, the assistant can't either — even if it tries the DESTRUCTIVE tool.\nMCP is a new doorway into Carbon, not a way around its permission\nmodel."},"886":{"id":"/manual/developing/mcp-and-ai-48","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#how-the-assistant-reaches-carbon","content":"type: warn"},"887":{"id":"/manual/developing/mcp-and-ai-49","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#how-the-assistant-reaches-carbon","content":"An API key is a password. Anyone holding it can act as that Carbon user through MCP. Store\nkeys in your assistant's secret settings (never paste them into a chat), give each\nintegration its own key, and revoke a key the moment it's no longer needed."},"888":{"id":"/manual/developing/mcp-and-ai-50","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"The exact menu differs by assistant, but the shape is identical everywhere: point the tool at\nCarbon's MCP URL and give it credentials. Here's the flow for a desktop AI client."},"889":{"id":"/manual/developing/mcp-and-ai-51","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"Generate credentials in Carbon. Sign in to Carbon, open Settings → API keys, and\ncreate a key (or set up OAuth if your assistant supports it). Copy the key somewhere safe — you\nwon't be able to see it again."},"890":{"id":"/manual/developing/mcp-and-ai-52","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"Add Carbon as an MCP server. In your assistant's settings, find the connectors or MCP\nsection and add a new server pointing at app.carbon.ms/mcp. Paste your API key or complete\nthe OAuth sign-in when prompted."},"891":{"id":"/manual/developing/mcp-and-ai-53","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"Confirm the connection. The assistant should now list Carbon among its available tools.\nYou'll typically see the three meta-tools — search_tools, describe_tool, call_tool —\nwhich is exactly what you want; the full catalog stays hidden behind them."},"892":{"id":"/manual/developing/mcp-and-ai-54","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"Start with a READ question. Ask something safe first, like \"What's the on-hand quantity of\nA36 steel?\" or \"List Radiant Aerospace's open jobs.\" If you get a sensible answer, you're\nconnected. Only then move on to WRITE-level asks, deliberately."},"893":{"id":"/manual/developing/mcp-and-ai-55","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"type: info"},"894":{"id":"/manual/developing/mcp-and-ai-56","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#connect-an-assistant","content":"The call_tool meta-tool inherits the safety class of whatever tool it runs. Calling\ninventory_getItemQuantities through it is a READ; calling sales_deleteSalesOrder through\nit is DESTRUCTIVE. The wrapper doesn't soften the underlying risk — so the READ-first habit\nmatters even though call_tool itself looks generic."},"895":{"id":"/manual/developing/mcp-and-ai-57","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#a-worked-example-end-to-end","content":"To make the pattern concrete, here's the full round-trip behind the on-hand-steel question,\nshown as the assistant would run it. You'd only ever type the first line."},"896":{"id":"/manual/developing/mcp-and-ai-58","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#a-worked-example-end-to-end","content":"That last sentence is the real value of MCP: it didn't just fetch a number, it connected it to\nsomething you care about — you can't build a single hook until you raise another\npurchase order to Ryerson, exactly like PO000057."},"897":{"id":"/manual/developing/mcp-and-ai-59","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#a-worked-example-end-to-end","content":"type: tip"},"898":{"id":"/manual/developing/mcp-and-ai-60","page_id":"/manual/developing/mcp-and-ai","tags":[],"type":"text","url":"/manual/developing/mcp-and-ai#a-worked-example-end-to-end","content":"Because the assistant can chain reads, you can ask layered questions in one go: \"Do we have\nenough A36 steel on hand to finish job J000099 (3,000 hooks), and if not, how much do we need\nto buy?\" It reads the job's material requirement, reads inventory, and does the math."},"899":{"id":"/manual/developing/using-the-api","page_id":"/manual/developing/using-the-api","type":"page","content":"Using the API","tags":[],"url":"/manual/developing/using-the-api"},"900":{"id":"/manual/developing/using-the-api-0","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api","content":"Carbon is API-first — create a key and make your first call."},"901":{"id":"/manual/developing/using-the-api-1","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#what-api-first-means-for-you","content":"What \"API-first\" means for you"},"902":{"id":"/manual/developing/using-the-api-2","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#create-an-api-key","content":"Create an API key"},"903":{"id":"/manual/developing/using-the-api-3","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#open-api-keys-in-settings","content":"Open API Keys in Settings"},"904":{"id":"/manual/developing/using-the-api-4","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#create-a-new-key","content":"Create a new key"},"905":{"id":"/manual/developing/using-the-api-5","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#copy-the-secret-immediately","content":"Copy the secret immediately"},"906":{"id":"/manual/developing/using-the-api-6","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"API key vs. OAuth — which auth do you need?"},"907":{"id":"/manual/developing/using-the-api-7","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#use-an-official-client-library","content":"Use an official client library"},"908":{"id":"/manual/developing/using-the-api-8","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#make-your-first-call","content":"Make your first call"},"909":{"id":"/manual/developing/using-the-api-9","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#put-your-key-in-the-environment","content":"Put your key in the environment"},"910":{"id":"/manual/developing/using-the-api-10","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#list-your-items","content":"List your items"},"911":{"id":"/manual/developing/using-the-api-11","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#fetch-one-sales-order-by-its-id","content":"Fetch one sales order by its ID"},"912":{"id":"/manual/developing/using-the-api-12","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#common-patterns-youll-hit-quickly","content":"Common patterns you'll hit quickly"},"913":{"id":"/manual/developing/using-the-api-13","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#the-deep-reference-lives-in-the-developer-docs","content":"The deep reference lives in the Developer Docs"},"914":{"id":"/manual/developing/using-the-api-14","page_id":"/manual/developing/using-the-api","type":"heading","tags":[],"url":"/manual/developing/using-the-api#next-steps","content":"Next steps"},"915":{"id":"/manual/developing/using-the-api-15","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api","content":"Everything you can do in the Carbon web app — create a quote, release a job, raise a\npurchase order, read a part's method — you can also do over the\nAPI (Application Programming Interface): a way for your own code or another program to\ntalk to Carbon directly. Carbon is API-first, which means the app you click through and the\nAPI speak to the same backend. There's no second-class \"integration layer\" bolted on later;\nthe buttons in the UI call the exact same endpoints you're about to call yourself."},"916":{"id":"/manual/developing/using-the-api-16","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api","content":"This page gets you from zero to a working call: you'll create a key, pick an official client\nlibrary, and run a few lines of code that read real data back out of Carbon. It's a friendly\non-ramp — the full endpoint-by-endpoint reference lives in the separate Developer Docs,\nwhich we'll link as we go."},"917":{"id":"/manual/developing/using-the-api-17","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api","content":"type: info"},"918":{"id":"/manual/developing/using-the-api-18","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api","content":"Where this fits. This is the first stop in the Developing track. Once you can make a\ncall, the next pages build on it: AI & the MCP server lets\nAI assistants drive Carbon for you, Integrating with other systems\nconnects Carbon to your other tools, and Migrating data\nuses the same API to bulk-load your existing records. If you've never touched an API before,\nthat's fine — every step below is spelled out."},"919":{"id":"/manual/developing/using-the-api-19","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#what-api-first-means-for-you","content":"A quick mental model before you write any code. When you confirm a sales order in the web app,\nyour browser sends a request to a Carbon endpoint (a specific URL that performs one action),\nand Carbon sends back a response. The API just lets your program send that same kind of\nrequest. So anything you've read about in this manual — items, quotes, sales orders, jobs,\npurchase orders, receipts, shipments, invoices, quality records — is reachable as data you can\nread and (with the right key) write."},"920":{"id":"/manual/developing/using-the-api-20","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#what-api-first-means-for-you","content":"type: tip"},"921":{"id":"/manual/developing/using-the-api-21","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#what-api-first-means-for-you","content":"If it's in the app, it's in the API. There is no feature that's \"UI only.\" The product\nteam builds the UI on top of the public API, so the moment a capability ships in Carbon it's\ncallable from your code too. That's the single most useful thing to know on this page."},"922":{"id":"/manual/developing/using-the-api-22","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#what-api-first-means-for-you","content":"Notice that \"Your code\" and \"Carbon web app\" point at the same backend. That's the whole\nidea: the API isn't a copy of your data, it is your data."},"923":{"id":"/manual/developing/using-the-api-23","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#create-an-api-key","content":"Before any program can talk to Carbon, it needs to prove who it is. The simplest way is an\nAPI key — a long secret string that stands in for your login. You create it once, store it\nsafely, and send it with every request."},"924":{"id":"/manual/developing/using-the-api-24","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#open-api-keys-in-settings","content":"In the Carbon web app, go to Settings → API Keys. This page lists every key that exists for\nyour company, who created it, and when it was last used. New companies start with none."},"925":{"id":"/manual/developing/using-the-api-25","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#create-a-new-key","content":"Click New API Key, give it a clear name that says what it's for (for example, Shipping\nintegration or Nightly export), and create it. Naming keys by purpose makes it painless to\nrevoke the right one later without breaking everything else."},"926":{"id":"/manual/developing/using-the-api-26","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#create-a-new-key","content":"A key inherits the permissions of the user who created it. If your login can't approve\npurchase orders in the app, a key you create can't either. That's a feature — it means a key is\nnever more powerful than the person behind it. See\nUsers & permissions for how those roles work."},"927":{"id":"/manual/developing/using-the-api-27","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#copy-the-secret-immediately","content":"Carbon shows you the full key value exactly once, right after you create it. Copy it now and\nstore it somewhere safe — a secrets manager, your CI provider's encrypted variables, or a\npassword manager. If you lose it, you can't view it again; you simply delete the key and make a\nnew one."},"928":{"id":"/manual/developing/using-the-api-28","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#copy-the-secret-immediately","content":"type: warn"},"929":{"id":"/manual/developing/using-the-api-29","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#copy-the-secret-immediately","content":"Treat a key like a password. Anyone holding it can act as you in Carbon. Never paste a key\ninto client-side code, a public repository, a screenshot, or a support ticket. Keep it in an\nenvironment variable (the examples below read CARBON_API_KEY), and revoke any key the\nmoment you suspect it leaked — deleting it on the API Keys page kills it instantly."},"930":{"id":"/manual/developing/using-the-api-30","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"\"Auth\" (authentication) is just how Carbon knows who is calling. Carbon supports two styles,\nand the right one depends on whose data you're acting on."},"931":{"id":"/manual/developing/using-the-api-31","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"An API key authenticates you (or a single service account). You create it once, store the\nsecret, and send it on every request. This is the right choice for the work most readers of this\nmanual are doing:"},"932":{"id":"/manual/developing/using-the-api-32","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"A script that exports your own orders every night."},"933":{"id":"/manual/developing/using-the-api-33","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"A backend integration that pushes shipments into Carbon."},"934":{"id":"/manual/developing/using-the-api-34","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"One-off data migration or reporting jobs."},"935":{"id":"/manual/developing/using-the-api-35","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"Send it as a request header. Carbon also reads your company automatically from the key, so you\ndon't pass a company ID by hand:"},"936":{"id":"/manual/developing/using-the-api-36","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"OAuth is for apps that act on behalf of other Carbon users — for example, a third-party\nproduct you're building that lets its users connect their Carbon account. Instead of holding\na static secret, your app sends the user through a consent screen and receives a short-lived\naccess token scoped to that user's permissions."},"937":{"id":"/manual/developing/using-the-api-37","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"If you're automating your own company, you almost certainly want an API key and can skip OAuth\nfor now. If you're building a public integration that other companies install, the OAuth flow\n(client registration, scopes, token refresh) is documented in full in the Developer Docs."},"938":{"id":"/manual/developing/using-the-api-38","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"type: info"},"939":{"id":"/manual/developing/using-the-api-39","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#api-key-vs-oauth--which-auth-do-you-need","content":"Rule of thumb: automating your Carbon data → API key. Building an app other Carbon\ncustomers log into → OAuth. Either way, the request examples below are identical once you\nhave a token; only how you obtain it differs."},"940":{"id":"/manual/developing/using-the-api-40","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#use-an-official-client-library","content":"You can call Carbon with raw HTTP (any fetch or curl will do), but the team maintains\nofficial client libraries that wrap the endpoints in typed, autocompleting functions and\nhandle auth headers, pagination, and errors for you. Reach for these first."},"941":{"id":"/manual/developing/using-the-api-41","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#use-an-official-client-library","content":"type: tip"},"942":{"id":"/manual/developing/using-the-api-42","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#use-an-official-client-library","content":"The exact package names and the always-current install commands are in the\nClients section of the Developer Docs — check there if an npm/pip name differs\nfrom what you see above, since published names can change between versions."},"943":{"id":"/manual/developing/using-the-api-43","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#make-your-first-call","content":"Time to read real data. The goal of a first call is simply to prove that your key works and you\ncan get a response — so we'll read, not write. The examples below list items and then fetch a\nsingle sales order. Carbon reads your company automatically from the key (the Acme demo's company\nID is SMBHQP55H46bdEGV7acnir), so you don't pass it by hand — and the calls pull back records\nyou've already met in this manual: the Counterweight Hook (CWH-A36-15) and its order,\nSO000069."},"944":{"id":"/manual/developing/using-the-api-44","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#put-your-key-in-the-environment","content":"Don't hard-code the secret. Set it as an environment variable so your code reads it at runtime:"},"945":{"id":"/manual/developing/using-the-api-45","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#list-your-items","content":"This first call asks Carbon for a page of items and prints them. If you get rows back, your key\nand connection are working."},"946":{"id":"/manual/developing/using-the-api-46","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#list-your-items","content":"Here's the kind of list you're reading back — the same items you'd see under Items in the web\napp:"},"947":{"id":"/manual/developing/using-the-api-47","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#fetch-one-sales-order-by-its-id","content":"Listing proves the connection; fetching a single record proves you can navigate Carbon's data.\nHere we pull the hero order, SO000069 — Radiant Aerospace's order for 500 Counterweight\nHooks — and read its total and line."},"948":{"id":"/manual/developing/using-the-api-48","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#fetch-one-sales-order-by-its-id","content":"That response is exactly what the Sales Order page shows in the\nUI — same record, same numbers, no copy:"},"949":{"id":"/manual/developing/using-the-api-49","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#fetch-one-sales-order-by-its-id","content":"type: tip"},"950":{"id":"/manual/developing/using-the-api-50","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#fetch-one-sales-order-by-its-id","content":"Read before you write. Carbon's read endpoints can't change anything, so they're the safe\nplace to learn the data shapes. Once you're comfortable, the same client exposes\ncreate/update methods (for example, creating a quote line or releasing a job) — guarded by\nyour key's permissions. When you're ready to write, do it against a test or demo company\nfirst, never your live data."},"951":{"id":"/manual/developing/using-the-api-51","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#common-patterns-youll-hit-quickly","content":"A few things every Carbon caller runs into, so they don't surprise you:"},"952":{"id":"/manual/developing/using-the-api-52","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#common-patterns-youll-hit-quickly","content":"List endpoints return a page at a time. Pass limit (how many) and offset (how many to skip)\nto walk through results — limit: 50, offset: 50 gets the second page of fifty. Carbon also\nreturns a count so you know the total. Keep page sizes modest so responses stay fast."},"953":{"id":"/manual/developing/using-the-api-53","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#common-patterns-youll-hit-quickly","content":"Most records have two identifiers: a friendly readable ID you see in the app\n(SO000069, CWH-A36-15, PO000057) and an internal record ID used in URLs and links\n(so_Fx6FCeSpx9sxut9Qns6y91). The client lets you fetch by either. Readable IDs are great for\npeople; internal IDs are stable references you'll store when linking records together."},"954":{"id":"/manual/developing/using-the-api-54","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#common-patterns-youll-hit-quickly","content":"Carbon responds with standard HTTP status codes — 401 means your key is missing or wrong,\n403 means the key lacks permission for that action, 404 means the record doesn't exist, and\n429 means you're sending requests too fast. The official clients surface these as typed errors\nyou can catch. On a 429, wait a moment and retry."},"955":{"id":"/manual/developing/using-the-api-55","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#common-patterns-youll-hit-quickly","content":"Dates are ISO 8601 strings (2026-06-11). Money comes back as plain numbers in the company's\nbase currency (USD for Acme) — for example, 36820 is $36,820.00. Format it for display on\nyour side."},"956":{"id":"/manual/developing/using-the-api-56","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#the-deep-reference-lives-in-the-developer-docs","content":"This page is the on-ramp. For the full, always-current details — every endpoint, every field,\nauthentication flows, webhooks, and copy-paste setup — head to Carbon's Developer Docs:"},"957":{"id":"/manual/developing/using-the-api-57","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#the-deep-reference-lives-in-the-developer-docs","content":"type: info"},"958":{"id":"/manual/developing/using-the-api-58","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#the-deep-reference-lives-in-the-developer-docs","content":"The Developer Docs are versioned alongside the product, so if an endpoint or client method\ndiffers from an example here, trust the Developer Docs — they're generated from the live API."},"959":{"id":"/manual/developing/using-the-api-59","page_id":"/manual/developing/using-the-api","tags":[],"type":"text","url":"/manual/developing/using-the-api#next-steps","content":"You can authenticate and read data. Here's where to go from here:"},"960":{"id":"/manual/getting-started/migrating-data","page_id":"/manual/getting-started/migrating-data","type":"page","content":"Migrating your data","tags":[],"url":"/manual/getting-started/migrating-data"},"961":{"id":"/manual/getting-started/migrating-data-0","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data","content":"Bring your items, customers and suppliers into Carbon."},"962":{"id":"/manual/getting-started/migrating-data-1","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#why-order-matters","content":"Why order matters"},"963":{"id":"/manual/getting-started/migrating-data-2","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#the-recommended-sequence","content":"The recommended sequence"},"964":{"id":"/manual/getting-started/migrating-data-3","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#step-1--foundations-units-of-measure--locations","content":"Step 1 — Foundations: units of measure & locations"},"965":{"id":"/manual/getting-started/migrating-data-4","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#step-2--items-parts-materials-consumables-tools","content":"Step 2 — Items (parts, materials, consumables, tools)"},"966":{"id":"/manual/getting-started/migrating-data-5","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#step-3--customers--suppliers","content":"Step 3 — Customers & suppliers"},"967":{"id":"/manual/getting-started/migrating-data-6","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#step-4--opening-inventory","content":"Step 4 — Opening inventory"},"968":{"id":"/manual/getting-started/migrating-data-7","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"Step 5 — BOMs & methods"},"969":{"id":"/manual/getting-started/migrating-data-8","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#step-6--open-orders","content":"Step 6 — Open orders"},"970":{"id":"/manual/getting-started/migrating-data-9","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"The CSV import workflow"},"971":{"id":"/manual/getting-started/migrating-data-10","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#large-or-repeatable-migrations-use-the-api","content":"Large or repeatable migrations: use the API"},"972":{"id":"/manual/getting-started/migrating-data-11","page_id":"/manual/getting-started/migrating-data","type":"heading","tags":[],"url":"/manual/getting-started/migrating-data#next-steps","content":"Next steps"},"973":{"id":"/manual/getting-started/migrating-data-12","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data","content":"If you're moving to Carbon from spreadsheets or another system, you don't have to retype\neverything by hand. This page shows you what to bring in, in what order, and how — using\nCarbon's built-in CSV importers. The golden rule of any migration is simple: import the\nthings other records depend on first. Get the order right and the rest falls into place."},"974":{"id":"/manual/getting-started/migrating-data-13","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data","content":"We'll use Acme Inc.'s own data as the worked example throughout — the same parts, customers\nand suppliers you'll see everywhere else in this manual."},"975":{"id":"/manual/getting-started/migrating-data-14","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data","content":"type: info"},"976":{"id":"/manual/getting-started/migrating-data-15","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data","content":"Before you start. This page assumes your company is already set up\n(Set up your company) and that you've added the\npeople who'll be doing the work (Users & permissions).\nMigration is the last step of getting started — once your data is in, you're ready to\ndefine and use items for real."},"977":{"id":"/manual/getting-started/migrating-data-16","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#why-order-matters","content":"Carbon records are linked. An item points to a\nunit of measure. A piece of opening inventory points to an item and a\nlocation. A bill of materials points to the parent item\nand every child item. An open sales order points to a customer and an item."},"978":{"id":"/manual/getting-started/migrating-data-17","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#why-order-matters","content":"So if you import opening stock before the item exists, Carbon has nothing to attach it to and\nthe row fails. Import items before their units of measure exist, and the unitOfMeasureCode\ncolumn has nothing to match. The fix is to load your data in dependency order — each\nlayer building on the one below it."},"979":{"id":"/manual/getting-started/migrating-data-18","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-recommended-sequence","content":"type: tip"},"980":{"id":"/manual/getting-started/migrating-data-19","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-recommended-sequence","content":"You don't have to migrate history. Most shops bring in their master data (items,\ncustomers, suppliers) plus a snapshot of opening inventory and any open orders, and\nleave closed jobs and paid invoices in the old system. A clean start beats a perfect copy."},"981":{"id":"/manual/getting-started/migrating-data-20","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-1--foundations-units-of-measure--locations","content":"A unit of measure (UoM) is how you count an item — EA for \"each\", LB for pounds, IN\nfor inches. A location is a physical site that holds stock. These are the codes every\nlater import leans on, so they go in first. Carbon ships with the common ones already defined,\nso usually you're just confirming they exist rather than creating them."},"982":{"id":"/manual/getting-started/migrating-data-21","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-1--foundations-units-of-measure--locations","content":"Acme's setup is small and typical:"},"983":{"id":"/manual/getting-started/migrating-data-22","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-1--foundations-units-of-measure--locations","content":"type: warn"},"984":{"id":"/manual/getting-started/migrating-data-23","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-1--foundations-units-of-measure--locations","content":"Decide your UoM and location codes now and never change them later. Every imported row,\nevery BOM line and every stock balance refers to these codes by exact text — rename EA to\nea afterward and you'll orphan thousands of references. Pick the casing once and stick with it."},"985":{"id":"/manual/getting-started/migrating-data-24","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-2--items-parts-materials-consumables-tools","content":"Items are the heart of Carbon — a part you make, a material\nyou buy, a consumable, a tool. Almost everything else points at an item, so this is the\nbiggest and most important import. Get your spreadsheet clean here and the rest of the\nmigration is easy."},"986":{"id":"/manual/getting-started/migrating-data-25","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-2--items-parts-materials-consumables-tools","content":"Each row becomes one item. The columns map to real Carbon fields:"},"987":{"id":"/manual/getting-started/migrating-data-26","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-2--items-parts-materials-consumables-tools","content":"Here's a slice of Acme's items file — real parts and materials from the dossier. Notice the\ntwo key decisions on every row: its itemType (is it a part, a raw material, a tool?) and its\nreplenishmentSystem (do you make it or buy it?)."},"988":{"id":"/manual/getting-started/migrating-data-27","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-2--items-parts-materials-consumables-tools","content":"type: tip"},"989":{"id":"/manual/getting-started/migrating-data-28","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-2--items-parts-materials-consumables-tools","content":"Keep your readableId values consistent — Acme uses patterns like\n[abbrev]-[material]-[rev] for parts (CWH-A36-15) and\n[alloy]-[substance]-[form]-[thickness]\".[dimension] for materials\n(A36-STEEL-PLT-1\".96x240). A predictable scheme makes parts findable and your BOM import\nin Step 5 far easier to wire up."},"990":{"id":"/manual/getting-started/migrating-data-29","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-3--customers--suppliers","content":"With items in place, bring in the businesses you sell to and buy from. Customers are\nneeded before any quote, sales order or invoice; suppliers before any purchase order. Each\nis its own import, but the workflow is identical."},"991":{"id":"/manual/getting-started/migrating-data-30","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-3--customers--suppliers","content":"type: info"},"992":{"id":"/manual/getting-started/migrating-data-31","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-3--customers--suppliers","content":"Customer and supplier types (like \"Aerospace & Defense\" or \"Metals and Raw Materials\")\nand payment terms (like \"Net 30\") are short lookup lists. If your CSV uses a type Carbon\ndoesn't recognize yet, create it once under Settings before importing — then every row that\nreferences it lands cleanly. More in Customers and\nSuppliers."},"993":{"id":"/manual/getting-started/migrating-data-32","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-4--opening-inventory","content":"Now that items and locations both exist, you can record what's physically on your shelves\ntoday — your opening balances. Each row says: this item, this quantity, at this location\n(and, if you track bins, which shelf)."},"994":{"id":"/manual/getting-started/migrating-data-33","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-4--opening-inventory","content":"Carbon turns each row into an inventory adjustment that sets the item's on-hand quantity. After\nthe import, every part with stock shows a real on-hand figure you can build jobs against."},"995":{"id":"/manual/getting-started/migrating-data-34","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-4--opening-inventory","content":"type: warn"},"996":{"id":"/manual/getting-started/migrating-data-35","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-4--opening-inventory","content":"Import opening inventory once, ideally on go-live day, and pick a clear cutover moment.\nIf you import balances and then keep transacting in your old system, the two drift apart fast.\nFreeze the old system, count, import, and run forward in Carbon from there."},"997":{"id":"/manual/getting-started/migrating-data-36","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"A method is how a made item is built: its bill of materials\n(what it's made of) plus its routing (the operations that make it). Methods only make sense\nonce the parent and all the child items already exist — which is exactly why they come after\nStep 2."},"998":{"id":"/manual/getting-started/migrating-data-37","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"For a made-to-order part like the Counterweight Hook, the method is short: one material, three\noperations. Here's how that recipe looks once it's in Carbon."},"999":{"id":"/manual/getting-started/migrating-data-38","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"To import methods by CSV, you typically prepare two related files and load them in order:"},"1000":{"id":"/manual/getting-started/migrating-data-39","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"BOM lines — one row per material, linking a parent readableId to a child readableId\nwith a quantity. For the hook: parent CWH-A36-15, child A36-STEEL-PLT-1\".96x240, qty\n40 LB."},"1001":{"id":"/manual/getting-started/migrating-data-40","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"Routing operations — one row per operation, with its sequence, the\nprocess (Flame Cut, Sandblasting, Quality Inspection) and the\nwork center it runs at (Burn Table — PA2, Sand Blasting Room,\nInspection Station), plus times like 45 minutes per piece."},"1002":{"id":"/manual/getting-started/migrating-data-41","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"Carbon stitches the two together into the parent item's method. From then on, any\njob for that part copies this recipe automatically."},"1003":{"id":"/manual/getting-started/migrating-data-42","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"type: tip"},"1004":{"id":"/manual/getting-started/migrating-data-43","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-5--boms--methods","content":"Multi-level assemblies (a part made of sub-assemblies that are themselves made) import the\nsame way — just make sure every sub-assembly already exists as an item, and import the\ndeepest level's BOM first so each parent can find its children."},"1005":{"id":"/manual/getting-started/migrating-data-44","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-6--open-orders","content":"Last, bring in the work that's still in flight: open quotes, sales orders awaiting\nfulfillment, and purchase orders awaiting receipt. These reference items, customers and\nsuppliers, so by now everything they point at already exists."},"1006":{"id":"/manual/getting-started/migrating-data-45","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#step-6--open-orders","content":"These two rows mirror Acme's real open work — the follow-on Counterweight Hook orders\n(SO000070 and SO000071) that come right after the hero order SO000069. Once they're in,\nCarbon can plan jobs and purchasing against them just like any natively created order."},"1007":{"id":"/manual/getting-started/migrating-data-46","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"Every importer in Carbon works the same way, so once you've done one you've done them all. The\nfiles in a typical migration look like this — loaded top to bottom:"},"1008":{"id":"/manual/getting-started/migrating-data-47","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"To load any one of them:"},"1009":{"id":"/manual/getting-started/migrating-data-48","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"Open the importer. Go to the module that owns the data — Items, Sales, Purchasing,\nInventory — and choose Import. Carbon offers a template CSV with the exact column\nheaders it expects; download it and pour your data into those columns."},"1010":{"id":"/manual/getting-started/migrating-data-49","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"Upload the file. Drop your .csv in. Carbon reads the header row and previews the first\nfew rows so you can confirm it parsed the way you expected."},"1011":{"id":"/manual/getting-started/migrating-data-50","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"Map columns to Carbon fields. For each of your columns, pick the Carbon field it feeds —\nyour \"Part No.\" to readableId, your \"UoM\" to unitOfMeasureCode, your \"Make/Buy\" to\nreplenishmentSystem. If your headers already match Carbon's template, the mapping is\nauto-filled."},"1012":{"id":"/manual/getting-started/migrating-data-51","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"Validate. Carbon checks every row before changing anything — flagging blank required\nfields, a unitOfMeasureCode that doesn't exist yet, or a duplicate readableId. Fix the\nflagged rows in your spreadsheet and re-upload."},"1013":{"id":"/manual/getting-started/migrating-data-52","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"Import. When the preview is clean, confirm. Carbon creates the records and shows a\nsummary — how many created, how many skipped. Spot-check a few against the app, then move\non to the next file in the sequence."},"1014":{"id":"/manual/getting-started/migrating-data-53","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"type: warn"},"1015":{"id":"/manual/getting-started/migrating-data-54","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#the-csv-import-workflow","content":"Always run a small test batch first — five or ten rows — before importing thousands. A\ntiny run surfaces a wrong column mapping or a bad UoM code in seconds, instead of after\nyou've created 5,000 mis-mapped parts. Carbon validates before writing, but a real test\nimport is the surest check."},"1016":{"id":"/manual/getting-started/migrating-data-55","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#large-or-repeatable-migrations-use-the-api","content":"type: tip"},"1017":{"id":"/manual/getting-started/migrating-data-56","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#large-or-repeatable-migrations-use-the-api","content":"Carbon is API-first — every screen in the app is backed by a\ndocumented API, and anything you can type in, you can script. For a big migration, a one-time\ndata move from a legacy ERP, or a sync you'll run more than once, scripting it against the API\nis far more reliable than hand-mapping CSVs over and over. You control the order, you can\nre-run safely, and you get a clean log of exactly what was created. See\nUsing the API to get started."},"1018":{"id":"/manual/getting-started/migrating-data-57","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#large-or-repeatable-migrations-use-the-api","content":"The same dependency order applies whether you click or script: create units and locations, then\nitems, then customers and suppliers, then balances, then methods, then open orders. The API\njust lets you automate each layer. Because Carbon also ships a built-in\nMCP server, you can even have an AI assistant drive parts of\nthe migration for you — reading your old data and creating the Carbon records in order."},"1019":{"id":"/manual/getting-started/migrating-data-58","page_id":"/manual/getting-started/migrating-data","tags":[],"type":"text","url":"/manual/getting-started/migrating-data#next-steps","content":"You've got your data in. Here's where to go next:"},"1020":{"id":"/manual/getting-started/setup-company","page_id":"/manual/getting-started/setup-company","type":"page","content":"Setting up your company","tags":[],"url":"/manual/getting-started/setup-company"},"1021":{"id":"/manual/getting-started/setup-company-0","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company","content":"Company profile, locations, units of measure and number sequences."},"1022":{"id":"/manual/getting-started/setup-company-1","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#where-these-settings-live","content":"Where these settings live"},"1023":{"id":"/manual/getting-started/setup-company-2","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#1-company-profile","content":"1. Company profile"},"1024":{"id":"/manual/getting-started/setup-company-3","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#2-locations","content":"2. Locations"},"1025":{"id":"/manual/getting-started/setup-company-4","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#shelves-and-bins-live-inside-a-location","content":"Shelves and bins live inside a location"},"1026":{"id":"/manual/getting-started/setup-company-5","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#3-units-of-measure","content":"3. Units of measure"},"1027":{"id":"/manual/getting-started/setup-company-6","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#4-number-sequences","content":"4. Number sequences"},"1028":{"id":"/manual/getting-started/setup-company-7","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#5-payment-terms","content":"5. Payment terms"},"1029":{"id":"/manual/getting-started/setup-company-8","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#a-quick-mental-model","content":"A quick mental model"},"1030":{"id":"/manual/getting-started/setup-company-9","page_id":"/manual/getting-started/setup-company","type":"heading","tags":[],"url":"/manual/getting-started/setup-company#next-steps","content":"Next steps"},"1031":{"id":"/manual/getting-started/setup-company-10","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company","content":"Before you can quote a job or buy a sheet of steel, Carbon needs to know a few things about\nyour business: who you are, where you keep stock, the units you measure things in, how your\ndocuments should be numbered, and when you expect to get paid. This page walks an\nadministrator through that one-time setup, using the real settings behind Acme Inc., the\nexample company you'll see throughout this manual. Do this once, up front, and every page\nafter it will feel natural."},"1032":{"id":"/manual/getting-started/setup-company-11","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company","content":"type: info"},"1033":{"id":"/manual/getting-started/setup-company-12","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company","content":"Before you start. This is the very first thing you do in a brand-new Carbon company —\nbefore you add users or\nimport any data. Everything you create later\n(parts, customers, orders) attaches to the company, locations, units and terms you define\nhere, so it pays to get them right first. You'll need an\nadministrator account to change these settings."},"1034":{"id":"/manual/getting-started/setup-company-13","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#where-these-settings-live","content":"All of the foundational settings on this page live in the Settings area of Carbon (the\ngear icon in the navigation rail). Settings is split into sections — Company, Locations,\nUnits of Measure, Sequences, Payment Terms, and more. You don't have to fill in every\nsection on day one, but the five below are the ones worth doing before anything else."},"1035":{"id":"/manual/getting-started/setup-company-14","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#where-these-settings-live","content":"type: tip"},"1036":{"id":"/manual/getting-started/setup-company-15","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#where-these-settings-live","content":"You can come back and change most of these later. The big exception is your base\ncurrency — pick it carefully, because it's the currency your books are kept in and it\nisn't meant to be changed once you start transacting. Acme uses USD."},"1037":{"id":"/manual/getting-started/setup-company-16","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Your company profile is your business's identity card. It holds your legal name, address,\nlogo and base currency. Carbon stamps these onto the documents you send out — quotes, order\nconfirmations, purchase orders and invoices all carry your name, address and logo — so this is\nthe first thing to fill in."},"1038":{"id":"/manual/getting-started/setup-company-17","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Open Settings → Company. You'll land on a single form with your company's core\ndetails."},"1039":{"id":"/manual/getting-started/setup-company-18","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Enter your name and address. Acme is \"Acme Inc.\" at 2400 Anvil Way, Springfield, OH.\nThis address is what prints in the header of every outbound document."},"1040":{"id":"/manual/getting-started/setup-company-19","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Upload your logo. Drop in a PNG or SVG. Carbon places it on PDF documents and in the\ntop-left of the app. A transparent-background logo looks best."},"1041":{"id":"/manual/getting-started/setup-company-20","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Set your base currency. Acme keeps its books in USD. Every record's amounts roll\nup into this currency for reporting. If you sell or buy in other currencies later, Carbon\nconverts them back to base using an exchange rate — but the base currency itself stays\nfixed."},"1042":{"id":"/manual/getting-started/setup-company-21","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Save. That's the whole profile. You can always return to swap the logo or fix an\naddress typo."},"1043":{"id":"/manual/getting-started/setup-company-22","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Here's how Acme's finished company profile looks:"},"1044":{"id":"/manual/getting-started/setup-company-23","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"type: warn"},"1045":{"id":"/manual/getting-started/setup-company-24","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#1-company-profile","content":"Your base currency drives all of accounting. Confirm it before you create your first\ncustomer, supplier or item. Changing it after you've posted transactions is not a supported\nflow — if you picked wrong, start a fresh company rather than trying to convert in place."},"1046":{"id":"/manual/getting-started/setup-company-25","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#2-locations","content":"A location is a physical site where you make things, hold\nstock, or ship from — typically a plant or a warehouse. Carbon tracks inventory, work centers,\nand documents per location, so most companies set up at least one. Acme runs two:"},"1047":{"id":"/manual/getting-started/setup-company-26","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#2-locations","content":"Headquarters is Acme's home base — it's where the burn tables, the sandblasting room and\nthe inspection station live, and it's the location stamped on the whole Counterweight Hook\nthread you'll follow in this manual (SO000069,\nJ000097 and PO000057 all run\nout of Headquarters). Texas is a second site with its own burn table, laser table and parts\ncleaner."},"1048":{"id":"/manual/getting-started/setup-company-27","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#shelves-and-bins-live-inside-a-location","content":"Within a location you can get as detailed as you like about where stock physically sits, using\nstorage units (think racks, rows, levels and bins). Acme's are named with a\nRack-Row-Level-Bin convention — for example the 1-inch A36 steel plate for the Counterweight\nHook job lives in bin R02-B01-01. You don't have to set these up on day one; a single\ncatch-all bin per location is enough to start, and you can add structure as your warehouse grows."},"1049":{"id":"/manual/getting-started/setup-company-28","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#shelves-and-bins-live-inside-a-location","content":"type: tip"},"1050":{"id":"/manual/getting-started/setup-company-29","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#shelves-and-bins-live-inside-a-location","content":"Add a location for every site that holds inventory or ships product. If you only have one\nbuilding, one location is perfectly fine — but don't lump two physically separate warehouses\ninto one, or your on-hand quantities won't match reality. More on stock and bins in\nLocations & stock."},"1051":{"id":"/manual/getting-started/setup-company-30","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#3-units-of-measure","content":"A unit of measure (UoM) is how you count a thing: each, pounds, gallons, feet. Every\nitem in Carbon has one. The Counterweight Hook is counted in\nEA (Each); the A36 steel plate it's cut from is measured in LB (Pound). Carbon ships\nwith a sensible starter list, and Acme runs 16 of them."},"1052":{"id":"/manual/getting-started/setup-company-31","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#3-units-of-measure","content":"Acme's full set also includes BG (Bag), CS (Case), DR (Drum), LT (Liter), MT (Meter), OZ\n(Ounce), PK (Pack) and YD (Yard). To add your own, open Settings → Units of Measure and\ngive it a short code (the abbreviation that shows on documents) and a name."},"1053":{"id":"/manual/getting-started/setup-company-32","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#3-units-of-measure","content":"type: warn"},"1054":{"id":"/manual/getting-started/setup-company-33","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#3-units-of-measure","content":"Get the unit right on an item before you start transacting with it. An item's unit of\nmeasure feeds into pricing, inventory counts and purchasing — switching it after you've\nrecorded stock or orders gets messy. When you buy in one unit and stock in another (say, buy\nsteel by the pound but receive it as plates), Carbon handles that with separate purchase and\ninventory units rather than by changing the item's base unit."},"1055":{"id":"/manual/getting-started/setup-company-34","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"Every document in Carbon gets a short, human-readable ID — Q000061, SO000069, J000097,\nPO000057, AR000025. You don't type these in; Carbon generates them automatically from a\nnumber sequence: a prefix plus a running counter. This keeps IDs unique, ordered, and easy\nto say out loud on the phone."},"1056":{"id":"/manual/getting-started/setup-company-35","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"Each document type has its own sequence. Here's how Acme's are configured, with the next number\neach one will hand out:"},"1057":{"id":"/manual/getting-started/setup-company-36","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"A sequence has three parts you can tune:"},"1058":{"id":"/manual/getting-started/setup-company-37","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"Prefix — the letters in front. Acme uses Q for quotes, SO for sales orders, J for\njobs, PO for purchase orders, AR for customer (sales) invoices and AP for supplier\n(purchase) invoices. These follow common accounting shorthand: AR is accounts\nreceivable (money owed to you), AP is accounts payable (money you owe)."},"1059":{"id":"/manual/getting-started/setup-company-38","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"Padding — how many digits, zero-filled. Acme pads to six, so the 69th sales order reads\nSO000069 rather than SO69. Consistent width keeps lists sorting cleanly."},"1060":{"id":"/manual/getting-started/setup-company-39","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"Next number — the counter that increments by one each time a document is created. Acme's\nmost recent quote is Q000063, so its next one becomes Q000064, and the counter ticks up\non its own from there."},"1061":{"id":"/manual/getting-started/setup-company-40","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"So when you trace Acme's hero order — quote Q000061 becomes sales order SO000069, which\nspawns job J000097, which triggers purchase order PO000057 and finishes with invoice\nAR000025 — every one of those IDs came from a sequence defined right here."},"1062":{"id":"/manual/getting-started/setup-company-41","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"type: tip"},"1063":{"id":"/manual/getting-started/setup-company-42","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#4-number-sequences","content":"Set your prefixes and padding before you create your first document. The next-number\ncounter only ever goes up, and you generally shouldn't reset it backwards — that risks\nduplicate IDs. Changing a prefix mid-stream is fine, but it makes older and newer documents\nlook inconsistent, so decide on a scheme early and stick with it."},"1064":{"id":"/manual/getting-started/setup-company-43","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#5-payment-terms","content":"Payment terms spell out when an invoice is due — and sometimes offer a discount for paying\nearly. You attach a default term to each customer and supplier, and Carbon copies it onto their\norders and invoices, then calculates the due date for you. Acme keeps seven on file:"},"1065":{"id":"/manual/getting-started/setup-company-44","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#5-payment-terms","content":"Net 30 is Acme's default and the one on the hero thread: it's the term on Radiant\nAerospace's sales order SO000069, on the Ryerson purchase order PO000057, and on the\ninvoice AR000025. The \"Net\" terms are straightforward — pay the whole balance within N\ndays. The discount terms like 2% 10 Net 30 are an incentive: a customer who pays within 10\ndays knocks 2% off, otherwise the full amount is due at 30."},"1066":{"id":"/manual/getting-started/setup-company-45","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#5-payment-terms","content":"type: info"},"1067":{"id":"/manual/getting-started/setup-company-46","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#5-payment-terms","content":"Payment terms don't have to be set per document by hand. Set one as the company default,\noptionally override it on a specific customer or supplier, and Carbon fills it in\nautomatically on every new order and invoice for them. You can still change it on an\nindividual document when a deal calls for it."},"1068":{"id":"/manual/getting-started/setup-company-47","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#a-quick-mental-model","content":"Here's the order these settings stack up in — each layer depends on the one before it:"},"1069":{"id":"/manual/getting-started/setup-company-48","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#a-quick-mental-model","content":"Get these five squared away and your company is ready for the next steps: inviting your\nteam, and bringing in your existing parts, customers and suppliers."},"1070":{"id":"/manual/getting-started/setup-company-49","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#a-quick-mental-model","content":"type: warn"},"1071":{"id":"/manual/getting-started/setup-company-50","page_id":"/manual/getting-started/setup-company","tags":[],"type":"text","url":"/manual/getting-started/setup-company#a-quick-mental-model","content":"Do this before you import. Migrating data\nattaches everything to the company, locations and units you defined here. If you import parts\nbefore your units of measure exist, or before your locations are set up, the import has\nnowhere to put them. Foundation first, then data."},"1072":{"id":"/manual/getting-started/users-permissions","page_id":"/manual/getting-started/users-permissions","type":"page","content":"Users & permissions","tags":[],"url":"/manual/getting-started/users-permissions"},"1073":{"id":"/manual/getting-started/users-permissions-0","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions","content":"Invite your team, assign employee types and control who can do what."},"1074":{"id":"/manual/getting-started/users-permissions-1","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#the-two-ideas-who-you-are-and-what-you-can-touch","content":"The two ideas: who you are, and what you can touch"},"1075":{"id":"/manual/getting-started/users-permissions-2","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#invite-your-team","content":"Invite your team"},"1076":{"id":"/manual/getting-started/users-permissions-3","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#choose-an-employee-type-the-role","content":"Choose an employee type (the role)"},"1077":{"id":"/manual/getting-started/users-permissions-4","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#suzies-view-in-practice","content":"Suzie's view, in practice"},"1078":{"id":"/manual/getting-started/users-permissions-5","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#set-module-level-permissions","content":"Set module-level permissions"},"1079":{"id":"/manual/getting-started/users-permissions-6","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#roles-side-by-side","content":"Roles side by side"},"1080":{"id":"/manual/getting-started/users-permissions-7","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#a-note-on-ai-and-api-access","content":"A note on AI and API access"},"1081":{"id":"/manual/getting-started/users-permissions-8","page_id":"/manual/getting-started/users-permissions","type":"heading","tags":[],"url":"/manual/getting-started/users-permissions#next-steps","content":"Next steps"},"1082":{"id":"/manual/getting-started/users-permissions-9","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions","content":"A real shop has more than one person in it — a salesperson quoting work, a buyer raising\npurchase orders, operators on the floor, a bookkeeper closing the month. Carbon lets you\ninvite all of them and then control, precisely, what each one can see and change. This page\nshows you how to invite people by email, choose the right employee type for each, and\nfine-tune module-level permissions so everyone has exactly the access they need — and\nnothing more."},"1083":{"id":"/manual/getting-started/users-permissions-10","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions","content":"type: info"},"1084":{"id":"/manual/getting-started/users-permissions-11","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions","content":"Before you start. This is a foundation step, best done right after you\nset up your company and before you\nmigrate your data. You'll need to be an\nadmin to invite people. If you set up the company yourself, you already are one —\nin Acme's account that's Chase Foster (chase@carbon.ms)."},"1085":{"id":"/manual/getting-started/users-permissions-12","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#the-two-ideas-who-you-are-and-what-you-can-touch","content":"Access in Carbon comes from two layers that work together. Keep them separate in your head\nand the whole thing gets simple."},"1086":{"id":"/manual/getting-started/users-permissions-13","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#the-two-ideas-who-you-are-and-what-you-can-touch","content":"A user is one login — one person, one email address. Inviting someone creates their\nuser account."},"1087":{"id":"/manual/getting-started/users-permissions-14","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#the-two-ideas-who-you-are-and-what-you-can-touch","content":"An employee type (Carbon's word for a role) is a named\nbundle of permissions you attach to a user. Instead of\nsetting access person-by-person, you define a type once — say Sales — and assign it to\neveryone who sells."},"1088":{"id":"/manual/getting-started/users-permissions-15","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#the-two-ideas-who-you-are-and-what-you-can-touch","content":"Permissions are the actual switches. They're granted per module (Sales,\nPurchasing, Items, Production, and so on) and, within each module, per action:\nview, create, update, and delete."},"1089":{"id":"/manual/getting-started/users-permissions-16","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#the-two-ideas-who-you-are-and-what-you-can-touch","content":"So the flow is always the same: invite the user, give them an employee type, and let\nthat type's permissions decide what they can do in each module. Let's walk through it."},"1090":{"id":"/manual/getting-started/users-permissions-17","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#invite-your-team","content":"You add people by sending an email invitation. They click the link, set a password, and land\nin your company with whatever access their employee type grants."},"1091":{"id":"/manual/getting-started/users-permissions-18","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#invite-your-team","content":"Open Settings → Users. From the left navigation, go to Settings, then Users.\nThis is the list of everyone in your company and the type assigned to each. Acme's looks like\nthis."},"1092":{"id":"/manual/getting-started/users-permissions-19","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#invite-your-team","content":"Click Invite and enter their email. Type one or more email addresses — you can invite\nseveral people at once by separating addresses with a comma. Pick the employee type they\nshould get (you can change it later), then send."},"1093":{"id":"/manual/getting-started/users-permissions-20","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#invite-your-team","content":"They accept and set a password. Carbon emails the invite. When the person clicks the\nlink, they create a password and they're in — with exactly the access their type defines.\nUntil they accept, their status shows as Invited rather than Active."},"1094":{"id":"/manual/getting-started/users-permissions-21","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#invite-your-team","content":"type: tip"},"1095":{"id":"/manual/getting-started/users-permissions-22","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#invite-your-team","content":"You can deactivate a user instead of deleting them — handy when someone leaves but you\nwant to keep their name on the records they created (like the way Chase Foster stays\nattached to purchase order PO000057 and sales order\nSO000069 forever). Deactivating frees up the seat without\nerasing history."},"1096":{"id":"/manual/getting-started/users-permissions-23","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#choose-an-employee-type-the-role","content":"An employee type is the role you hand someone. It carries a default set of module\npermissions so you don't configure each person from scratch. A new Carbon company starts\nwith a few sensible types, and you can add your own to match how your shop is organized."},"1097":{"id":"/manual/getting-started/users-permissions-24","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#choose-an-employee-type-the-role","content":"Here are the types you'd typically set up for a shop like Acme, and what each one is for."},"1098":{"id":"/manual/getting-started/users-permissions-25","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#choose-an-employee-type-the-role","content":"type: info"},"1099":{"id":"/manual/getting-started/users-permissions-26","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#choose-an-employee-type-the-role","content":"The names above are examples to make the idea concrete — you create and name your own types\nto fit your team. The one type that always exists and that you can't lock yourself out of is\nAdministrator: it can reach every module and the Settings area where users and types\nare managed. Keep at least one."},"1100":{"id":"/manual/getting-started/users-permissions-27","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#suzies-view-in-practice","content":"When you give Suzie Sells the Sales type, Carbon opens up the selling side of the app\nfor her — customers, quotes and\nsales orders — and leaves the rest read-only or hidden. She\ncan build a quote like Q000061 and turn it into an order, but she\ncan't change a supplier price or post to the ledger. That's the role doing its job."},"1101":{"id":"/manual/getting-started/users-permissions-28","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#suzies-view-in-practice","content":"type: tip"},"1102":{"id":"/manual/getting-started/users-permissions-29","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#suzies-view-in-practice","content":"Employee types also pair naturally with departments. Acme groups people into\nSales, Marketing, and Sales & Marketing departments. Departments don't grant access\non their own — they're for organizing people and reporting — but they make a growing team\neasier to navigate."},"1103":{"id":"/manual/getting-started/users-permissions-30","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#set-module-level-permissions","content":"This is the heart of access control. Within an employee type, you turn on four switches for\neach module: View, Create, Update, and Delete. They stack the way you'd\nexpect — you can't create something you can't view, and Delete is the one you hand out most\nsparingly."},"1104":{"id":"/manual/getting-started/users-permissions-31","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#set-module-level-permissions","content":"Open the type and find the module grid. From Settings → Employee Types, click a type\n(say Sales) and open its Permissions tab. You'll see one row per module with four\ncheckboxes each."},"1105":{"id":"/manual/getting-started/users-permissions-32","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#set-module-level-permissions","content":"Tick the actions this role needs. For a salesperson, you'd give full access to Sales,\nlet them view Items so they can pick parts onto a quote, and leave Purchasing,\nProduction and Accounting off entirely."},"1106":{"id":"/manual/getting-started/users-permissions-33","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#set-module-level-permissions","content":"Save. The change applies to everyone with that type immediately — there's no need to\nre-edit each person. Next time Suzie loads the app, Purchasing simply isn't there."},"1107":{"id":"/manual/getting-started/users-permissions-34","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#roles-side-by-side","content":"It's easiest to design permissions by comparing roles. Here's how Acme's common types map\nacross the modules — full access (all four actions), read-only (view only), or none."},"1108":{"id":"/manual/getting-started/users-permissions-35","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#roles-side-by-side","content":"Read a column to understand one role; read a row to see who can touch one module. Notice the\nAccountant can view Sales and Purchasing (they need to see the orders behind an\ninvoice) but only has full control over Accounting — and that only the Administrator\nreaches Settings, where users and types live."},"1109":{"id":"/manual/getting-started/users-permissions-36","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#roles-side-by-side","content":"type: warn"},"1110":{"id":"/manual/getting-started/users-permissions-37","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#roles-side-by-side","content":"Grant least privilege. Give each person the minimum access their job needs, not the\nmost. It's tempting to make everyone an Administrator to avoid \"access denied\" friction —\ndon't. Over-broad permissions are how a salesperson accidentally edits a supplier price, or\nan operator deletes a sales order. Start narrow, then add a permission when someone actually\nhits a wall. Delete in particular should be rare: most roles never need it, because\nCarbon prefers to cancel or deactivate records rather than erase the history other\nrecords depend on."},"1111":{"id":"/manual/getting-started/users-permissions-38","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#a-note-on-ai-and-api-access","content":"Carbon is API-first and ships with a built-in MCP server, so\nan AI assistant can read and act in your company on your behalf. That access runs through the\nsame permission system you just set up — an AI agent or an API key inherits the access of the\nuser it acts as. The least-privilege rule matters even more here: scope a key to exactly the\nmodules a script or assistant needs. There's a whole section on this in\nDeveloping with Carbon."},"1112":{"id":"/manual/getting-started/users-permissions-39","page_id":"/manual/getting-started/users-permissions","tags":[],"type":"text","url":"/manual/getting-started/users-permissions#next-steps","content":"You've got your team in and scoped. Two natural directions from here:"},"1113":{"id":"/manual/inventory/locations-and-stock","page_id":"/manual/inventory/locations-and-stock","type":"page","content":"Locations & stock","tags":[],"url":"/manual/inventory/locations-and-stock"},"1114":{"id":"/manual/inventory/locations-and-stock-0","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock","content":"Warehouses, shelves, on-hand quantities and the item ledger."},"1115":{"id":"/manual/inventory/locations-and-stock-1","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#the-two-questions-inventory-answers","content":"The two questions inventory answers"},"1116":{"id":"/manual/inventory/locations-and-stock-2","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#layer-1--locations","content":"Layer 1 — Locations"},"1117":{"id":"/manual/inventory/locations-and-stock-3","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#layer-2--shelves--bins-storage-units","content":"Layer 2 — Shelves & bins (storage units)"},"1118":{"id":"/manual/inventory/locations-and-stock-4","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#layer-3--on-hand-quantities","content":"Layer 3 — On-hand quantities"},"1119":{"id":"/manual/inventory/locations-and-stock-5","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#reading-an-items-quantities-tab","content":"Reading an item's quantities tab"},"1120":{"id":"/manual/inventory/locations-and-stock-6","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#the-item-ledger--every-movement-forever","content":"The item ledger — every movement, forever"},"1121":{"id":"/manual/inventory/locations-and-stock-7","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#batch--lot-tracking-a-quick-note","content":"Batch & lot tracking (a quick note)"},"1122":{"id":"/manual/inventory/locations-and-stock-8","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"Fixing the numbers: inventory adjustments"},"1123":{"id":"/manual/inventory/locations-and-stock-9","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"Verifying the numbers: cycle counts"},"1124":{"id":"/manual/inventory/locations-and-stock-10","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#recap","content":"Recap"},"1125":{"id":"/manual/inventory/locations-and-stock-11","page_id":"/manual/inventory/locations-and-stock","type":"heading","tags":[],"url":"/manual/inventory/locations-and-stock#next-steps","content":"Next steps"},"1126":{"id":"/manual/inventory/locations-and-stock-12","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock","content":"Carbon always knows two things about your physical stuff: where it is and how much\nyou have. This page explains how Carbon models your warehouse — locations, then shelves\nand bins inside them — how it tracks the on-hand quantity of every item,\nand how it keeps a complete history of every movement in the item ledger. You'll also\nlearn to correct a count that's wrong (an inventory adjustment) and to verify stock with a\ncycle count."},"1127":{"id":"/manual/inventory/locations-and-stock-13","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock","content":"type: info"},"1128":{"id":"/manual/inventory/locations-and-stock-14","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock","content":"Where this fits. Stock is the thing every other part of Carbon pushes and pulls.\nReceiving a purchase order adds stock; a\njob consumes raw material and produces finished parts;\na shipment removes stock when it goes out the\ndoor. This page is the foundation underneath all of that — it's how Carbon answers\n\"do we have it, and where?\""},"1129":{"id":"/manual/inventory/locations-and-stock-15","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#the-two-questions-inventory-answers","content":"Throughout this page we'll follow Acme's stock of A36 Steel Plate 1″ (part number\nA36-STEEL-PLT-1\".96x240) — the raw material that becomes the\nCounterweight Hook on job J000097. Acme buys it by the pound, stores\nit on a rack, and pulls 40 lb into every hook it makes."},"1130":{"id":"/manual/inventory/locations-and-stock-16","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#the-two-questions-inventory-answers","content":"Two simple numbers — 17,507 lb and bin R02-B01-01 — but Carbon tracks them for every\nitem, in every location, and remembers every transaction that ever changed them. Let's build\nthat up one layer at a time."},"1131":{"id":"/manual/inventory/locations-and-stock-17","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-1--locations","content":"A location is a physical site where you hold stock: a warehouse, a plant, a building.\nMost small shops run a single location; larger ones run several. Acme has two:"},"1132":{"id":"/manual/inventory/locations-and-stock-18","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-1--locations","content":"Locations matter because on-hand quantity is always per location. The same item can\nhave 17,507 lb at Headquarters and a different amount in Texas, and Carbon never mixes them\nup. When you create a sales order,\npurchase order or job, you\npick the location it draws from or delivers to — every hero-thread document for the\nCounterweight Hook uses Headquarters (loc_CZUGEFr…)."},"1133":{"id":"/manual/inventory/locations-and-stock-19","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-1--locations","content":"type: tip"},"1134":{"id":"/manual/inventory/locations-and-stock-20","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-1--locations","content":"Moving stock between locations is a transfer, not an adjustment — Carbon has dedicated\nstock transfer and warehouse transfer records so the quantity that leaves one site is\nthe exact quantity that arrives at the other. Reach for those when relocating physical\nstock; reserve adjustments (below) for correcting a count, not moving it."},"1135":{"id":"/manual/inventory/locations-and-stock-21","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-2--shelves--bins-storage-units","content":"Inside a location, Carbon lets you pinpoint exactly where something sits using storage\nunits — the general term for any shelf, rack, row or bin. They can nest: a warehouse\ncontains rows, a row contains bins. Acme's Headquarters mixes both styles:"},"1136":{"id":"/manual/inventory/locations-and-stock-22","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-2--shelves--bins-storage-units","content":"Flat rack bins named by position — for example R02-B01-01 means Rack 02, Row B,\nLevel 01, Position 01. Acme has many of these spread across racks R01–R05."},"1137":{"id":"/manual/inventory/locations-and-stock-23","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-2--shelves--bins-storage-units","content":"Nested storage — a broad \"A Warehouse\" zone that contains \"Row H\", which in turn\ncontains a specific bin \"H-12\"."},"1138":{"id":"/manual/inventory/locations-and-stock-24","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-2--shelves--bins-storage-units","content":"A storage unit is just a label for a place — naming it well (a consistent\nRack-Row-Level-Position scheme like Acme's) is what makes a part findable on a busy floor.\nEach item can have a default storage unit, so Carbon suggests the right bin automatically\nwhen you receive or pick it. The A36 Steel Plate's default is R02-B01-01\n(KgTNPORwzkxDG2z_wGLcI)."},"1139":{"id":"/manual/inventory/locations-and-stock-25","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-2--shelves--bins-storage-units","content":"type: info"},"1140":{"id":"/manual/inventory/locations-and-stock-26","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-2--shelves--bins-storage-units","content":"Item vs. storage unit. An item is what the thing is (A36 Steel Plate 1″). A\nstorage unit is where a quantity of it sits (bin R02-B01-01). One item can live in\nseveral bins; one bin can hold several items. The combination — item × location × storage\nunit — is what Carbon counts."},"1141":{"id":"/manual/inventory/locations-and-stock-27","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#layer-3--on-hand-quantities","content":"Now the numbers. Open any stock item and Carbon shows its on-hand quantity broken down\nby location, plus a set of related quantities that tell you what's already promised or\ninbound. Here's Acme's stock-on-hand list at Headquarters — the most-stocked materials and\nparts in the demo:"},"1142":{"id":"/manual/inventory/locations-and-stock-28","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#reading-an-items-quantities-tab","content":"On-hand is only one of several numbers Carbon tracks. Open the Counterweight Hook and the\nquantities tab tells a fuller story: 100 finished hooks are sitting in stock, but 4,500 are\nalready spoken for by open sales orders to Radiant Aerospace — and Carbon has two more jobs\nlined up to build them (J000098 for 1,500, in progress, and J000099 for 3,000, ready to\nstart). That gap between what you have and what you owe is exactly what Carbon's\nreplenishment logic watches."},"1143":{"id":"/manual/inventory/locations-and-stock-29","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#reading-an-items-quantities-tab","content":"Here's what each quantity means, in plain terms:"},"1144":{"id":"/manual/inventory/locations-and-stock-30","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#reading-an-items-quantities-tab","content":"type: tip"},"1145":{"id":"/manual/inventory/locations-and-stock-31","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#reading-an-items-quantities-tab","content":"Available is the number that actually matters for promising work: roughly\non hand minus what's committed, plus what's confidently inbound. With 100 hooks on hand\nbut 4,500 committed, Acme is deep in the hole on finished stock — which is fine, because the\nhook is a Make-to-Order part: Carbon builds each batch on a job rather than stocking\nahead. For a buy-to-stock material like A36 plate, a low available number is the trigger\nto reorder."},"1146":{"id":"/manual/inventory/locations-and-stock-32","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#the-item-ledger--every-movement-forever","content":"Behind those live quantities sits the item ledger: an append-only log of every single\ntransaction that has ever changed an item's stock. Receipts, job consumption, job output,\nshipments, adjustments — each writes one entry. The on-hand quantity isn't stored as a\nguess; it's the running sum of the ledger. That's why Carbon's numbers reconcile: you can\nalways trace a balance back to the events that produced it."},"1147":{"id":"/manual/inventory/locations-and-stock-33","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#the-item-ledger--every-movement-forever","content":"type: info"},"1148":{"id":"/manual/inventory/locations-and-stock-34","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#the-item-ledger--every-movement-forever","content":"The rows above illustrate the shape of a ledger — a positive receipt, the 20,000 lb that\njob J000097 consumed to make 500 hooks (40 lb × 500), then a count that confirmed the\nbalance. Every entry names the document that caused it, so the ledger doubles as an\naudit trail: \"who moved this, when, and why\" is never a mystery."},"1149":{"id":"/manual/inventory/locations-and-stock-35","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#batch--lot-tracking-a-quick-note","content":"Some items demand more than a quantity — they need traceability down to the specific\nbatch you received. A36 Steel Plate is one: it has requiresBatchTracking turned on. That\nmeans when you receive it, Carbon records a batch number (often the supplier's heat or\nlot number), and when a job consumes it, Carbon remembers which batch went into which\nfinished parts."},"1150":{"id":"/manual/inventory/locations-and-stock-36","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#batch--lot-tracking-a-quick-note","content":"A batch (or lot) is a quantity received together that shares a property — a steel\nheat, a chemical mix date, a casting pour."},"1151":{"id":"/manual/inventory/locations-and-stock-37","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#batch--lot-tracking-a-quick-note","content":"Serial tracking goes one step further: every individual unit gets its own unique\nserial number (think a numbered turbine blade), rather than a shared batch."},"1152":{"id":"/manual/inventory/locations-and-stock-38","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#batch--lot-tracking-a-quick-note","content":"The payoff is genealogy: months later you can answer \"which heat of steel went into\nRadiant Aerospace's order?\" — or, if a supplier recalls a heat, \"which of our finished parts\nare affected?\" — in seconds. Full detail lives in\nTracking quality."},"1153":{"id":"/manual/inventory/locations-and-stock-39","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"Sometimes the physical count and Carbon's number disagree — a drop, a miscount, scrap that\nwas never recorded. An inventory adjustment is how you make Carbon match reality. It\nwrites one ledger entry (so the change is traceable) and posts the value difference to the\nInventory Adjustment account (5310) in the books, keeping accounting honest too."},"1154":{"id":"/manual/inventory/locations-and-stock-40","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"Open the item at the right location. Find the item (for example A36 Steel Plate 1″) and\nmake sure you're looking at the correct location — adjustments are always per location.\nAdjusting at Headquarters never touches Texas."},"1155":{"id":"/manual/inventory/locations-and-stock-41","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"Start a new adjustment. Choose Adjust quantity (sometimes labelled Positive\nadjustment / Negative adjustment). Pick the storage unit the change happened in — say\nR02-B01-01."},"1156":{"id":"/manual/inventory/locations-and-stock-42","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"Enter the corrected quantity, not the delta. Tell Carbon what's actually there. If the\nsystem says 17,507 lb but you physically counted 17,450 lb, enter the new on-hand and Carbon\ncomputes the −57 lb movement for you. If the item is batch-tracked, pick which batch you're\nadjusting."},"1157":{"id":"/manual/inventory/locations-and-stock-43","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"Record a reason and post. Pick a reason (damaged, miscount, found stock) and a note so\nthe entry explains itself later. Posting writes the ledger entry, updates the on-hand\nquantity, and books the value change."},"1158":{"id":"/manual/inventory/locations-and-stock-44","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"type: warn"},"1159":{"id":"/manual/inventory/locations-and-stock-45","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#fixing-the-numbers-inventory-adjustments","content":"Adjustments are for corrections, not routine flow. Don't adjust stock down to \"use it\nup\" — that's what consuming material on a job is for — and\ndon't adjust it to move stock between sites — that's a transfer. Misusing adjustments hides\nthe real reason stock changed and muddies your costs. Each adjustment should answer a clear\n\"why was the count wrong?\""},"1160":{"id":"/manual/inventory/locations-and-stock-46","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"A cycle count is a scheduled physical count of part of your inventory — a few bins at a\ntime, rotating through everything over weeks, rather than shutting the whole shop for one big\nannual count. The goal is to catch drift early and keep the ledger trustworthy without\nstopping production."},"1161":{"id":"/manual/inventory/locations-and-stock-47","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"Decide what to count. Pick a slice — one rack, one item class, or your highest-value\nmaterials. Acme might count the steel racks (R02-B01-*) one week and the stainless racks\nthe next. Counting your costliest stock most often (an \"ABC\" approach) catches the errors\nthat matter most."},"1162":{"id":"/manual/inventory/locations-and-stock-48","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"Print or pull the count sheet. Carbon lists what it thinks is in each bin. A counter\nwalks the floor and writes down what's actually there — ideally without seeing the expected\nnumber, so the count stays honest."},"1163":{"id":"/manual/inventory/locations-and-stock-49","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"Enter the counted quantities. Type each counted figure back in. Carbon compares it to the\nexpected on-hand and flags any variance. A bin with no variance needs nothing further."},"1164":{"id":"/manual/inventory/locations-and-stock-50","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"Reconcile variances into adjustments. For each bin that differs, Carbon posts an\ninventory adjustment (the same mechanism as above) so the ledger, the on-hand quantity, and\nthe books all move together. After posting, Carbon's number once again matches the shelf."},"1165":{"id":"/manual/inventory/locations-and-stock-51","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"type: tip"},"1166":{"id":"/manual/inventory/locations-and-stock-52","page_id":"/manual/inventory/locations-and-stock","tags":[],"type":"text","url":"/manual/inventory/locations-and-stock#verifying-the-numbers-cycle-counts","content":"Treat repeat variances as a signal, not just a number to fix. If the same bin is always\nshort, the cause is usually upstream — material consumed but never recorded on a job, scrap\nthat skipped the system, or a picking step done by hand. Counting tells you that you're\noff; the item ledger tells you why."},"1167":{"id":"/manual/inventory/shipping-receiving","page_id":"/manual/inventory/shipping-receiving","type":"page","content":"Shipping & receiving","tags":[],"url":"/manual/inventory/shipping-receiving"},"1168":{"id":"/manual/inventory/shipping-receiving-0","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving","content":"Move goods in and out with shipments and receipts."},"1169":{"id":"/manual/inventory/shipping-receiving-1","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#two-flows-one-idea","content":"Two flows, one idea"},"1170":{"id":"/manual/inventory/shipping-receiving-2","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#flow-1--receiving-against-a-purchase-order","content":"Flow 1 — Receiving against a purchase order"},"1171":{"id":"/manual/inventory/shipping-receiving-3","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#open-the-po-and-start-a-receipt","content":"Open the PO and start a receipt"},"1172":{"id":"/manual/inventory/shipping-receiving-4","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#confirm-the-quantities-that-actually-arrived","content":"Confirm the quantities that actually arrived"},"1173":{"id":"/manual/inventory/shipping-receiving-5","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#record-the-lot-or-batch-for-tracked-items","content":"Record the lot or batch for tracked items"},"1174":{"id":"/manual/inventory/shipping-receiving-6","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#tell-carbon-where-it-goes","content":"Tell Carbon where it goes"},"1175":{"id":"/manual/inventory/shipping-receiving-7","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"Post the receipt"},"1176":{"id":"/manual/inventory/shipping-receiving-8","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#flow-2--shipping-against-a-sales-order","content":"Flow 2 — Shipping against a sales order"},"1177":{"id":"/manual/inventory/shipping-receiving-9","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#start-a-shipment-from-the-order","content":"Start a shipment from the order"},"1178":{"id":"/manual/inventory/shipping-receiving-10","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#pick-the-finished-goods","content":"Pick the finished goods"},"1179":{"id":"/manual/inventory/shipping-receiving-11","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#choose-a-shipping-method","content":"Choose a shipping method"},"1180":{"id":"/manual/inventory/shipping-receiving-12","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#add-tracking-details-optional","content":"Add tracking details (optional)"},"1181":{"id":"/manual/inventory/shipping-receiving-13","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#post-the-shipment","content":"Post the shipment"},"1182":{"id":"/manual/inventory/shipping-receiving-14","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#what-posting-the-shipment-sets-in-motion","content":"What posting the shipment sets in motion"},"1183":{"id":"/manual/inventory/shipping-receiving-15","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#common-questions","content":"Common questions"},"1184":{"id":"/manual/inventory/shipping-receiving-16","page_id":"/manual/inventory/shipping-receiving","type":"heading","tags":[],"url":"/manual/inventory/shipping-receiving#next-steps","content":"Next steps"},"1185":{"id":"/manual/inventory/shipping-receiving-17","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving","content":"This page is about the two moments when physical goods actually cross your dock: stuff\ncoming in from a supplier (receiving), and finished goods going out to a\ncustomer (shipping). In Carbon these aren't loose warehouse chores — each one points\nback to a document you already created. A receipt settles a\npurchase order line; a shipment settles a sales order\nline and feeds the invoice. Do them right and your on-hand counts, your costs, and your\ncustomer's bill all stay in sync on their own."},"1186":{"id":"/manual/inventory/shipping-receiving-18","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving","content":"type: info"},"1187":{"id":"/manual/inventory/shipping-receiving-19","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving","content":"Where this fits. Receiving is the back half of purchasing —\nyou raised a PO, now the goods arrive. Shipping is the back half of\nselling — you made the parts on a\njob, now they leave. Both flows read and write the\nstock you keep in your locations and bins."},"1188":{"id":"/manual/inventory/shipping-receiving-20","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#two-flows-one-idea","content":"A receipt and a shipment are mirror images of each other. One adds to inventory,\nthe other subtracts from it. Both work the same way: you start from a source document,\nconfirm the real-world quantities, optionally record which physical material moved (its\nlot or batch), and then post — the moment Carbon commits the change to your books."},"1189":{"id":"/manual/inventory/shipping-receiving-21","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#two-flows-one-idea","content":"We'll use Acme's hero order to walk both ends. The A36 steel for the Counterweight Hooks\narrives on PO000057 from Ryerson — that's receiving. The 500 finished hooks leave for\nRadiant Aerospace against SO000069 — that's shipping."},"1190":{"id":"/manual/inventory/shipping-receiving-22","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#two-flows-one-idea","content":"type: tip"},"1191":{"id":"/manual/inventory/shipping-receiving-23","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#two-flows-one-idea","content":"\"Post\" is the verb that matters. Up until you post, a receipt or shipment is a draft\nyou can still edit or delete — nothing has changed in inventory. Posting is the\nirreversible commit: stock levels move, costs land, and downstream documents update. Get\nthe numbers right before you post."},"1192":{"id":"/manual/inventory/shipping-receiving-24","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#flow-1--receiving-against-a-purchase-order","content":"When a truck backs up to the dock with material you ordered, you create a receipt\nagainst the matching purchase order. Carbon already knows what you expected — the part,\nthe quantity, the price — so receiving is mostly confirming reality and noting any\ndifferences."},"1193":{"id":"/manual/inventory/shipping-receiving-25","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#flow-1--receiving-against-a-purchase-order","content":"For the hero thread, Acme ordered 54,001 LB of A36 Steel Plate from\nRyerson on PO000057. Here's the open PO line waiting to be\nreceived."},"1194":{"id":"/manual/inventory/shipping-receiving-26","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#open-the-po-and-start-a-receipt","content":"Go to Purchasing → Purchase Orders, open PO000057, and choose Receive (or start\nfrom Inventory → Receipts → New and pick the PO). Carbon copies the open lines onto a\nfresh receipt so you don't re-type anything. The receipt starts as a Draft — safe to\nedit."},"1195":{"id":"/manual/inventory/shipping-receiving-27","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#open-the-po-and-start-a-receipt","content":"type: warn"},"1196":{"id":"/manual/inventory/shipping-receiving-28","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#open-the-po-and-start-a-receipt","content":"A purchase order has to be issued to the supplier before you can receive against it.\nPO000057 is currently Needs Approval — in a real flow it would be approved and sent\nfirst. You can't receive goods against a PO that's still a draft."},"1197":{"id":"/manual/inventory/shipping-receiving-29","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#confirm-the-quantities-that-actually-arrived","content":"The receipt pre-fills each line with the quantity still outstanding. Edit the received\nquantity to match what the packing slip and your scale say. Three common cases:"},"1198":{"id":"/manual/inventory/shipping-receiving-30","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#confirm-the-quantities-that-actually-arrived","content":"Exact — the truck brought all 54,001 LB. Leave the line as-is."},"1199":{"id":"/manual/inventory/shipping-receiving-31","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#confirm-the-quantities-that-actually-arrived","content":"Short — only part of the order came. Receive what arrived; the PO line stays open for\nthe rest (a partial receipt), and you can receive the balance on a later delivery."},"1200":{"id":"/manual/inventory/shipping-receiving-32","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#confirm-the-quantities-that-actually-arrived","content":"Over — more came than you ordered. Carbon flags the overage so you can accept it or\nsend it back, per your purchasing rules."},"1201":{"id":"/manual/inventory/shipping-receiving-33","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#record-the-lot-or-batch-for-tracked-items","content":"A36 Steel Plate is batch-tracked (requiresBatchTracking: true). That means Carbon\nwon't just add \"20,000 lb of steel\" to a faceless pile — it wants to know which heat of\nsteel this is, so that months later you can answer \"exactly which material went into\nRadiant's hooks?\" Type the supplier's heat/lot number into the batch field on the line."},"1202":{"id":"/manual/inventory/shipping-receiving-34","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#record-the-lot-or-batch-for-tracked-items","content":"type: tip"},"1203":{"id":"/manual/inventory/shipping-receiving-35","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#record-the-lot-or-batch-for-tracked-items","content":"Serial vs batch. Carbon's itemTrackingType decides how granular this gets.\nInventory items (like the finished hook) just track a count. Batch items track by\nlot — one number for the whole delivery. Serial items track every single unit\nindividually. You only see a batch or serial field when the item asks for one, so for\nmost parts this step simply doesn't appear. More in\nLocations & stock."},"1204":{"id":"/manual/inventory/shipping-receiving-36","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#tell-carbon-where-it-goes","content":"Each received line needs a home: a location and a shelf (bin). Acme's steel lives\nat the Headquarters location in bin R02-B01-01 — its default — so the receipt\nsuggests that automatically. Change it if you're stocking it somewhere else."},"1205":{"id":"/manual/inventory/shipping-receiving-37","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"When the numbers and batch are right, choose Post. At that instant:"},"1206":{"id":"/manual/inventory/shipping-receiving-38","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"On-hand stock of A36 Steel Plate goes up by the received quantity in bin R02-B01-01."},"1207":{"id":"/manual/inventory/shipping-receiving-39","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"The PO line's quantityReceived updates, moving the PO toward Received / To Invoice."},"1208":{"id":"/manual/inventory/shipping-receiving-40","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"Carbon posts the value to your Inventory account and to GR/IR Clearing (the\nholding account between goods-received and invoice-received) — see\nAccounting overview."},"1209":{"id":"/manual/inventory/shipping-receiving-41","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"The material is now real stock the job can pull from. The\nCounterweight Hook job needs 40 LB per piece × 500 = 20,000 LB, and it now has steel to\nconsume."},"1210":{"id":"/manual/inventory/shipping-receiving-42","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"type: info"},"1211":{"id":"/manual/inventory/shipping-receiving-43","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-receipt","content":"The same dock handles services and outside work. If a PO line is for an Outside\nOperation (you sent parts out for, say, anodizing), receiving it back is the same motion —\nit tells Carbon the subcontracted step is done and the parts are home."},"1212":{"id":"/manual/inventory/shipping-receiving-44","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#flow-2--shipping-against-a-sales-order","content":"Once the parts are made and inspected, you send them. A shipment records what physically\nleft the building, against the sales order (and the job behind it). The hero job\nJ000097 finished all 500 Counterweight Hooks and received them into inventory\n(quantityReceivedToInventory: 500); now those 500 ship to Radiant Aerospace on\nSO000069."},"1213":{"id":"/manual/inventory/shipping-receiving-45","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#start-a-shipment-from-the-order","content":"Open SO000069 under Sales → Sales Orders and choose Ship (or go to Inventory →\nShipments → New and select the order). Carbon creates a shipment and brings the order\nlines across. As with receipts, it begins as a Draft you can adjust before posting."},"1214":{"id":"/manual/inventory/shipping-receiving-46","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#pick-the-finished-goods","content":"Picking is choosing which stock fills the shipment. For the hooks, Carbon pulls from the\njob's finished-goods bin (the job stored its output in storage unit 8-1-H). Confirm the\nquantity to ship on each line — here, all 500 EA."},"1215":{"id":"/manual/inventory/shipping-receiving-47","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#pick-the-finished-goods","content":"If a part is batch- or serial-tracked, you pick the specific lots/serials here, and Carbon\nrecords them on the shipment. That closes the traceability\nloop: you'll be able to trace this shipment back to the exact heat of A36 steel you received\nin Flow 1."},"1216":{"id":"/manual/inventory/shipping-receiving-48","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#pick-the-finished-goods","content":"type: warn"},"1217":{"id":"/manual/inventory/shipping-receiving-49","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#pick-the-finished-goods","content":"You can only ship what you have. Carbon won't let you ship more than is on hand in the\npicking location. If the job isn't finished or the finished goods haven't been received\ninto inventory yet, the quantity you can pick is capped. Short shipments are fine — the SO\nline stays open for the balance."},"1218":{"id":"/manual/inventory/shipping-receiving-50","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#choose-a-shipping-method","content":"A shipping method is the carrier and service the goods leave on — it prints on paperwork\nand tells everyone how the parts are travelling. Acme has ten methods configured, from\ncarrier overnight to a customer picking up themselves. Pick the one that matches the order."},"1219":{"id":"/manual/inventory/shipping-receiving-51","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#choose-a-shipping-method","content":"type: tip"},"1220":{"id":"/manual/inventory/shipping-receiving-52","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#choose-a-shipping-method","content":"A pallet of 500 steel hooks is heavy freight, not a parcel — so LTL (Less Than\nTruckload) or FTL (Full Truckload) is the right call here, not UPS Ground. The\nmethod you choose is also where a shipping cost rides along: SO000069 carries $250\nof freight, which shows up on the invoice but not in the goods subtotal."},"1221":{"id":"/manual/inventory/shipping-receiving-53","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#add-tracking-details-optional","content":"If the carrier gives you a tracking number, add it to the shipment along with package\ncounts and weights. It's optional, but it travels with the record so anyone looking at the\norder later can answer \"where is it?\" without leaving Carbon."},"1222":{"id":"/manual/inventory/shipping-receiving-54","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-shipment","content":"Choose Post to commit. At that instant a cascade fires:"},"1223":{"id":"/manual/inventory/shipping-receiving-55","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-shipment","content":"The 500 hooks leave inventory from the picking bin."},"1224":{"id":"/manual/inventory/shipping-receiving-56","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-shipment","content":"The SO line's quantitySent updates to 500 of 500, and because the whole line shipped\nit's flagged sentComplete — the order moves toward Completed."},"1225":{"id":"/manual/inventory/shipping-receiving-57","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-shipment","content":"The job's quantityShipped updates to 500."},"1226":{"id":"/manual/inventory/shipping-receiving-58","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#post-the-shipment","content":"A shipment record is created (sh_7injMjdu1xyZqTVFFrjauv) — the link the\ninvoice reads from next."},"1227":{"id":"/manual/inventory/shipping-receiving-59","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#what-posting-the-shipment-sets-in-motion","content":"The whole point of tying shipments to the sales order is what happens after you post. You\nrecorded one fact — \"500 hooks left the dock\" — and Carbon updates everything that depends\non it."},"1228":{"id":"/manual/inventory/shipping-receiving-60","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#what-posting-the-shipment-sets-in-motion","content":"Because the shipment is posted, Acme can now raise the sales invoice. Carbon builds\nAR000025 straight from what shipped — 500 EA at $73.14, plus the $250 freight — so the\nbill matches the truck, with no re-keying. The invoice references this exact shipment\n(shipmentId: sh_7injMjdu1xyZqTVFFrjauv), and once Radiant pays it lands as Paid. That\nis the receiving-to-shipping arc closing into cash."},"1229":{"id":"/manual/inventory/shipping-receiving-61","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#what-posting-the-shipment-sets-in-motion","content":"type: info"},"1230":{"id":"/manual/inventory/shipping-receiving-62","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#what-posting-the-shipment-sets-in-motion","content":"One number, entered once. You never told Carbon \"the order is complete\" or \"bill the\ncustomer.\" You said \"500 hooks shipped,\" and the sales order line, the job, the shipment\nrecord, and the invoice all updated themselves. That's the system-of-record payoff."},"1231":{"id":"/manual/inventory/shipping-receiving-63","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#common-questions","content":"Yes. Receipts and shipments are per-line and per-quantity. Receive 30,000 of 54,001 LB\ntoday and the PO line stays open for the rest; ship 200 of 500 hooks and the SO line keeps\nthe remaining 300 open until a later shipment. Carbon only marks a line \"complete\" once the\nfull quantity has moved."},"1232":{"id":"/manual/inventory/shipping-receiving-64","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#common-questions","content":"Posting is a committed inventory transaction, so you don't simply edit it after the fact.\nYou reverse the effect with a correcting movement — for example a negative inventory\nadjustment, a return, or a credit — which keeps a clean audit trail of what really\nhappened rather than silently overwriting history. Fix it before you post whenever you can."},"1233":{"id":"/manual/inventory/shipping-receiving-65","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#common-questions","content":"Only when the item asks for one. The field appears for items set to track by batch or\nserial — A36 Steel Plate, for example, has requiresBatchTracking: true. For plain\nInventory items like the finished Counterweight Hook, Carbon just tracks a quantity and\nthe batch/serial step never shows up."},"1234":{"id":"/manual/inventory/shipping-receiving-66","page_id":"/manual/inventory/shipping-receiving","tags":[],"type":"text","url":"/manual/inventory/shipping-receiving#common-questions","content":"A drop shipment is when a supplier ships goods straight to your customer, so they never pass\nthrough your dock. SO000069 has dropShipment: false — Acme made and shipped the hooks\nitself. When a line is drop-shipped, Carbon links the supplier delivery to the customer\norder directly, and you don't pick or post a shipment yourself."},"1235":{"id":"/manual/items/defining-an-item","page_id":"/manual/items/defining-an-item","type":"page","content":"Defining an item","tags":[],"url":"/manual/items/defining-an-item"},"1236":{"id":"/manual/items/defining-an-item-0","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item","content":"Parts, materials, tools and services — how to create and describe the things you make and buy."},"1237":{"id":"/manual/items/defining-an-item-1","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#what-an-item-is","content":"What an item is"},"1238":{"id":"/manual/items/defining-an-item-2","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#the-six-item-types","content":"The six item types"},"1239":{"id":"/manual/items/defining-an-item-3","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#anatomy-of-an-item-the-key-fields","content":"Anatomy of an item: the key fields"},"1240":{"id":"/manual/items/defining-an-item-4","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#part-number-readableid","content":"Part number (readableId)"},"1241":{"id":"/manual/items/defining-an-item-5","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#description","content":"Description"},"1242":{"id":"/manual/items/defining-an-item-6","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#unit-of-measure-uom","content":"Unit of measure (UoM)"},"1243":{"id":"/manual/items/defining-an-item-7","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#item-tracking-type","content":"Item tracking type"},"1244":{"id":"/manual/items/defining-an-item-8","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#unit-cost-and-sale-price","content":"Unit cost and sale price"},"1245":{"id":"/manual/items/defining-an-item-9","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#make-vs-buy-replenishment","content":"Make vs Buy (replenishment)"},"1246":{"id":"/manual/items/defining-an-item-10","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#create-a-part-step-by-step","content":"Create a Part, step by step"},"1247":{"id":"/manual/items/defining-an-item-11","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#open-the-new-item-form","content":"Open the new-item form"},"1248":{"id":"/manual/items/defining-an-item-12","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#choose-the-type-and-enter-the-basics","content":"Choose the type and enter the basics"},"1249":{"id":"/manual/items/defining-an-item-13","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#set-tracking-and-replenishment","content":"Set tracking and replenishment"},"1250":{"id":"/manual/items/defining-an-item-14","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#save--and-youre-done","content":"Save — and you're done"},"1251":{"id":"/manual/items/defining-an-item-15","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#reading-the-item-detail-page","content":"Reading the item detail page"},"1252":{"id":"/manual/items/defining-an-item-16","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#acmes-item-list","content":"Acme's item list"},"1253":{"id":"/manual/items/defining-an-item-17","page_id":"/manual/items/defining-an-item","type":"heading","tags":[],"url":"/manual/items/defining-an-item#next-steps","content":"Next steps"},"1254":{"id":"/manual/items/defining-an-item-18","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item","content":"Almost everything in Carbon starts with an item. An item is a single, named thing you\nmake, buy, sell, or use in your shop — a finished part, a slab of steel, a drill bit, a\nservice you charge for. Every quote line, sales order, job, purchase order and invoice\nultimately points back to an item, so getting items right is the foundation of everything\nelse. This page shows you what an item is, the six kinds Carbon recognizes, and exactly\nhow to create one — using real parts from Acme Inc.'s shop."},"1255":{"id":"/manual/items/defining-an-item-19","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item","content":"type: info"},"1256":{"id":"/manual/items/defining-an-item-20","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item","content":"Where this fits. Items are the very first thing you set up in Carbon, before you can\nquote, sell, make, or buy anything — they're one of the\ncore concepts the whole system is built on. Once an item\nexists, you give it a method (how it's made) and a\nreplenishment rule (how you keep it in stock). After\nthis page, those two are your natural next stops."},"1257":{"id":"/manual/items/defining-an-item-21","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#what-an-item-is","content":"Think of an item as a record card for one thing. It carries a unique\npart number, a description, and a handful of settings that\ntell Carbon how to treat it everywhere it shows up — what unit to count it in, whether to\ntrack stock of it, what it costs, what you sell it for, and whether you make it or\nbuy it."},"1258":{"id":"/manual/items/defining-an-item-22","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#what-an-item-is","content":"You only ever describe an item once. From then on, the Counterweight Hook is \"the\nCounterweight Hook\" on every quote, job and invoice — Carbon reuses the same record, so a\nprice change or a spelling fix happens in exactly one place."},"1259":{"id":"/manual/items/defining-an-item-23","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#the-six-item-types","content":"When you create an item, the first thing you choose is its type. The type tells Carbon\nwhat role the item plays in your business. Acme's shop uses all six."},"1260":{"id":"/manual/items/defining-an-item-24","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#the-six-item-types","content":"The two types you'll use most are Part and Material, and they sit at opposite ends\nof the same job:"},"1261":{"id":"/manual/items/defining-an-item-25","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#the-six-item-types","content":"A Part is the thing you deliver. Acme's hero part, the Counterweight Hook\n(CWH-A36-15), is a Part — a finished steel hook it makes for Radiant Aerospace."},"1262":{"id":"/manual/items/defining-an-item-26","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#the-six-item-types","content":"A Material is the raw stock you consume to make a Part. The hook is flame-cut from\nA36 Steel Plate 1″ (A36-STEEL-PLT-1\".96x240), which is a Material."},"1263":{"id":"/manual/items/defining-an-item-27","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#the-six-item-types","content":"type: tip"},"1264":{"id":"/manual/items/defining-an-item-28","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#the-six-item-types","content":"Tool vs Consumable is just durability and value. A Tool (a torque wrench, a\nmicrometer) is reused for years and worth tracking individually. A Consumable (sandpaper,\nshop rags, welding wire) is cheap and used up — you track it by quantity, not by\nserial number. When in doubt, ask \"would I notice if one walked off?\" — if yes, it's\nprobably a Tool."},"1265":{"id":"/manual/items/defining-an-item-29","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#anatomy-of-an-item-the-key-fields","content":"Every item type shares the same core fields. Here's what each one means and why it matters."},"1266":{"id":"/manual/items/defining-an-item-30","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#part-number-readableid","content":"The part number — Carbon's field name is readableId — is the short, human-friendly\ncode you and your customers use to refer to the item. Acme's are descriptive:\nCWH-A36-15 reads as Counterweight Hook, A36 steel. Materials follow a pattern of\n{grade}-{form}-{thickness}\".{sheet size}, so A36-STEEL-PLT-1\".96x240 is A36 steel\nplate, 1 inch thick, 96″×240″ sheet."},"1267":{"id":"/manual/items/defining-an-item-31","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#part-number-readableid","content":"Pick a convention and stick to it — a readable, consistent scheme pays off the moment your\nitem list grows past a few dozen. The part number must be unique within your company."},"1268":{"id":"/manual/items/defining-an-item-32","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#part-number-readableid","content":"type: info"},"1269":{"id":"/manual/items/defining-an-item-33","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#part-number-readableid","content":"An item can also carry a revision (the Counterweight Hook is revision 15). Carbon\nshows the combined value as readableIdWithRevision. Revisions let you change a design\nover time while keeping the history of older versions intact."},"1270":{"id":"/manual/items/defining-an-item-34","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#description","content":"A plain-language name — \"Counterweight Hook\", \"A36 Steel Plate 1″\". This is what prints on\nquotes, orders and invoices, so write it for the reader, not the engineer."},"1271":{"id":"/manual/items/defining-an-item-35","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#unit-of-measure-uom","content":"How you count the item. The Counterweight Hook is counted in EA (Each); the steel\nplate is bought and consumed in LB (Pounds). The unit of measure flows everywhere: when\nthe hook's method says it needs \"40 LB\" of steel per piece, Carbon knows that \"40\" means\npounds because the steel's UoM is LB."},"1272":{"id":"/manual/items/defining-an-item-36","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#item-tracking-type","content":"This decides how much detail Carbon keeps about your stock of the item. There are four\nmodes, from least to most granular:"},"1273":{"id":"/manual/items/defining-an-item-37","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#item-tracking-type","content":"The Counterweight Hook is Inventory-tracked: Carbon keeps a running count of how many\nfinished hooks are on hand. The A36 steel plate is Batch-tracked\n(requiresBatchTracking: true) — because when a quality question comes up later, Acme needs\nto know which heat of steel went into Radiant's order. That batch link is the start of\nfull traceability."},"1274":{"id":"/manual/items/defining-an-item-38","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#item-tracking-type","content":"type: warn"},"1275":{"id":"/manual/items/defining-an-item-39","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#item-tracking-type","content":"Tracking type is hard to change once an item has transaction history, so choose it when you\ncreate the item. If you're unsure, Inventory is the safe default for physical goods and\nNon-Inventory for services."},"1276":{"id":"/manual/items/defining-an-item-40","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#unit-cost-and-sale-price","content":"Unit cost is what the item costs you — for a Material, the price you pay your\nsupplier; for a Part you make, the cost Carbon rolls up from its method (materials plus\nshop time). Acme buys A36 plate from Ryerson at $0.25/LB."},"1277":{"id":"/manual/items/defining-an-item-41","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#unit-cost-and-sale-price","content":"Sale price is what you charge the customer. The Counterweight Hook sells to Radiant\nAerospace at $73.14 EA."},"1278":{"id":"/manual/items/defining-an-item-42","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#unit-cost-and-sale-price","content":"These are defaults. A specific quote or order can override the price, but the item-level\nfigures give Carbon something to work with the moment you add the item to a document."},"1279":{"id":"/manual/items/defining-an-item-43","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#make-vs-buy-replenishment","content":"The replenishment system answers one question: when you need more of this item, do you\nmake it or buy it?"},"1280":{"id":"/manual/items/defining-an-item-44","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#make-vs-buy-replenishment","content":"Make items get a method (a recipe) and are produced on a\njob. The Counterweight Hook is a Make item."},"1281":{"id":"/manual/items/defining-an-item-45","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#make-vs-buy-replenishment","content":"Buy items get suppliers and prices and are replenished with a\npurchase order. The A36 steel plate is a Buy\nitem — Acme orders it from Ryerson."},"1282":{"id":"/manual/items/defining-an-item-46","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#make-vs-buy-replenishment","content":"This single setting is why the hero thread works: because the hook is Make, an order for\nit creates a job; because the steel is Buy, that job's shortage creates a purchase order.\nYou'll tune the finer details (reorder points, lead times) in\nReplenishment & planning."},"1283":{"id":"/manual/items/defining-an-item-47","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#create-a-part-step-by-step","content":"Let's create the Counterweight Hook the way Acme did. The flow is the same for any item\ntype — you just pick a different Type in step 2."},"1284":{"id":"/manual/items/defining-an-item-48","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#open-the-new-item-form","content":"In the left rail, open the Items module and choose Parts, then click New. (Each\ntype has its own list — Parts, Materials, Tools, and so on — but they all open the same\ncreate form.)"},"1285":{"id":"/manual/items/defining-an-item-49","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#choose-the-type-and-enter-the-basics","content":"Set Type to Part. Then fill in the part number, a description, and the unit of\nmeasure. Acme enters CWH-A36-15, \"Counterweight Hook\", and EA."},"1286":{"id":"/manual/items/defining-an-item-50","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#set-tracking-and-replenishment","content":"Choose how Carbon should track stock and whether you make or buy the item. For the hook,\nthat's Inventory tracking and Make replenishment."},"1287":{"id":"/manual/items/defining-an-item-51","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#set-tracking-and-replenishment","content":"type: tip"},"1288":{"id":"/manual/items/defining-an-item-52","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#set-tracking-and-replenishment","content":"Because you chose Make, Carbon will expect a method for this part next — the recipe\nof materials and operations. You'll build it in Methods: BOM & routing.\nA Buy part would instead prompt you for suppliers and purchase prices."},"1289":{"id":"/manual/items/defining-an-item-53","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#save--and-youre-done","content":"Click Save. Carbon creates the item, marks it Active, and opens its detail page.\nThat's the whole foundation: from here you can add the method, set prices, and start\nquoting. The hook now exists as a single record that every future document will reuse."},"1290":{"id":"/manual/items/defining-an-item-54","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#reading-the-item-detail-page","content":"Once an item exists, its detail page organizes everything about it into tabs. Here's the\nCounterweight Hook's record, with each tab's job called out."},"1291":{"id":"/manual/items/defining-an-item-55","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#reading-the-item-detail-page","content":"type: info"},"1292":{"id":"/manual/items/defining-an-item-56","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#reading-the-item-detail-page","content":"Notice the Manufacturing and Purchasing tabs are mirror images. A Make item\nuses Manufacturing (its method) and leaves Purchasing mostly empty; a Buy item is\nthe reverse. The A36 steel plate, being a Buy material, fills in Purchasing (Ryerson,\n$0.25/LB) and has no method."},"1293":{"id":"/manual/items/defining-an-item-57","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#acmes-item-list","content":"Here's a real slice of Acme's parts — a mix of finished goods across aerospace, energy,\nmining and defense customers. Notice that several share the A36 and SS304 material\nfamilies, and that the hero part sits right in the middle."},"1294":{"id":"/manual/items/defining-an-item-58","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#acmes-item-list","content":"To see how the other types look as records, here's one of each kind Acme keeps:"},"1295":{"id":"/manual/items/defining-an-item-59","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#acmes-item-list","content":"type: tip"},"1296":{"id":"/manual/items/defining-an-item-60","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#acmes-item-list","content":"Don't try to perfect every field up front. Create the item with its number, description,\nUoM, type, tracking and Make/Buy choice — that's enough to start working. You can refine\ncosts, suppliers and the method as you go."},"1297":{"id":"/manual/items/defining-an-item-61","page_id":"/manual/items/defining-an-item","tags":[],"type":"text","url":"/manual/items/defining-an-item#next-steps","content":"You can create an item — now teach Carbon how to make it, what it's made of, and how to keep\nit in stock."},"1298":{"id":"/manual/items/materials","page_id":"/manual/items/materials","type":"page","content":"Materials","tags":[],"url":"/manual/items/materials"},"1299":{"id":"/manual/items/materials-0","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials","content":"Raw materials, forms, grades and dimensions for cut-to-size stock."},"1300":{"id":"/manual/items/materials-1","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#material-vs-part-whats-the-difference","content":"Material vs. Part: what's the difference?"},"1301":{"id":"/manual/items/materials-2","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#the-anatomy-of-a-material","content":"The anatomy of a material"},"1302":{"id":"/manual/items/materials-3","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#substances","content":"Substances"},"1303":{"id":"/manual/items/materials-4","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#forms","content":"Forms"},"1304":{"id":"/manual/items/materials-5","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#grades-and-dimensions","content":"Grades and dimensions"},"1305":{"id":"/manual/items/materials-6","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#acmes-material-catalog","content":"Acme's material catalog"},"1306":{"id":"/manual/items/materials-7","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#a-material-up-close","content":"A material up close"},"1307":{"id":"/manual/items/materials-8","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#cut-to-size-stock","content":"Cut-to-size stock"},"1308":{"id":"/manual/items/materials-9","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#batch-and-lot-tracking","content":"Batch and lot tracking"},"1309":{"id":"/manual/items/materials-10","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#create-a-material","content":"Create a material"},"1310":{"id":"/manual/items/materials-11","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#where-materials-show-up-next","content":"Where materials show up next"},"1311":{"id":"/manual/items/materials-12","page_id":"/manual/items/materials","type":"heading","tags":[],"url":"/manual/items/materials#next-steps","content":"Next steps"},"1312":{"id":"/manual/items/materials-13","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials","content":"A material is the raw stock you buy and then cut, machine or form into parts — a steel\nplate, an aluminum billet, a length of brass bar. In Carbon a material is a special kind of\nitem, built to describe physical stock the way a metals\ndistributor sells it: a substance (what alloy), a form (plate, bar, tube…), a grade,\nand dimensions. This page explains what makes a material different from a part, how Carbon\nnames and organizes them, and how to create one — using Acme's real steel, stainless,\naluminum and Inconel stock as the example throughout."},"1313":{"id":"/manual/items/materials-14","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials","content":"type: info"},"1314":{"id":"/manual/items/materials-15","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials","content":"Where this fits. Materials are the raw stock that feeds your\nmethods and jobs. On the hero\nthread, the Counterweight Hook (CWH-A36-15) is a Part made from one material —\nA36 Steel Plate 1″ — which Acme buys from Ryerson on\npurchase order PO000057. Define the material here,\nand it's ready to drop into a bill of materials."},"1315":{"id":"/manual/items/materials-16","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#material-vs-part-whats-the-difference","content":"Both a part and a material are items, so they share the same plumbing — a unique\nID, a unit of measure, costs, inventory tracking, suppliers. The difference is what they\ndescribe and how you usually replenish them."},"1316":{"id":"/manual/items/materials-17","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#material-vs-part-whats-the-difference","content":"The line gets blurry on purpose — a material can be made (some shops melt and pour their\nown), and a part can be bought. What you pick mostly drives the defaults Carbon shows you.\nThe practical reason to model raw stock as a material rather than a generic part is that\nCarbon then understands its anatomy: it knows \"A36 plate, 1 inch thick, 96×240 sheet\" is a\nsingle substance in three descriptive pieces, so it can group, search and reorder stock the\nway your buyers actually think."},"1317":{"id":"/manual/items/materials-18","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#material-vs-part-whats-the-difference","content":"type: tip"},"1318":{"id":"/manual/items/materials-19","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#material-vs-part-whats-the-difference","content":"If you're unsure whether something is a part, a material, a tool, a consumable or a\nservice, see the item type overview. Materials are the\nright choice for anything you cut, machine, weld or form from raw stock."},"1319":{"id":"/manual/items/materials-20","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#the-anatomy-of-a-material","content":"Every Carbon material is described by four attributes. Acme's catalog uses a tidy naming\nconvention that packs all four into the material's readable ID."},"1320":{"id":"/manual/items/materials-21","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#substances","content":"A substance is the underlying material — the alloy or compound. Carbon ships with 17\nsystem-defined substances, and you can add your own. Acme's catalog draws on six of\nthem — steel, stainless steel, aluminum, brass, Inconel and titanium. A few from Acme's\nshelves:"},"1321":{"id":"/manual/items/materials-22","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#substances","content":"type: info"},"1322":{"id":"/manual/items/materials-23","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#substances","content":"Carbon's 17 built-in substances are Aluminum, Brass, Bronze, Copper, Inconel, Magnesium,\nMonel, Nylon, Plastic, PVC, Rubber, Stainless Steel, Steel, Titanium, Tungsten, Zinc and\nZirconium. Need something exotic? You can define a company-specific substance — Acme added\nFoam for its packaging stock."},"1323":{"id":"/manual/items/materials-24","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#forms","content":"A form is the shape the stock arrives in. Carbon has 21 forms built in. Acme buys\nacross most of them:"},"1324":{"id":"/manual/items/materials-25","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#forms","content":"The full set also includes Filament, Ingot, Pellet, Rectangular Tube, S-Beam, Square Tube,\nT-Bar, W-Beam and Wide Bar — enough to describe almost anything a metals service center\nstocks. The form matters because it shapes how you measure and cut the material: plate is\nsold by area or weight, bar by length, tube by length and wall thickness."},"1325":{"id":"/manual/items/materials-26","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#grades-and-dimensions","content":"Grade captures the temper or spec — T6 on aluminum, the alloy designation baked into\nthe name (304 vs 316 stainless, A36 vs 4140 steel). Dimensions capture the physical size:\nplate thickness and sheet size (96×240 inches), bar diameter, tube wall. In Acme's catalog,\ngrade and dimension live inside the readable ID rather than as separate lookup fields, which\nkeeps the part list scannable."},"1326":{"id":"/manual/items/materials-27","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#grades-and-dimensions","content":"type: tip"},"1327":{"id":"/manual/items/materials-28","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#grades-and-dimensions","content":"Reading an Acme material ID. A36-STEEL-PLT-1\".96x240 decodes as: A36 (grade) ·\nSTEEL (substance) · PLT (form = plate) · 1″ (thickness) · 96×240 (sheet\nsize in inches). Once you can read the pattern, the whole catalog becomes self-describing."},"1328":{"id":"/manual/items/materials-29","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#acmes-material-catalog","content":"Here's a real slice of Acme's 19-material catalog, straight from the system. Notice how the\nnaming convention lets the same substance appear in several thicknesses and sheet sizes —\neach one is its own item because it's physically a different piece of stock to buy, store\nand cut."},"1329":{"id":"/manual/items/materials-30","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#acmes-material-catalog","content":"type: info"},"1330":{"id":"/manual/items/materials-31","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#acmes-material-catalog","content":"Almost every material is bought in LB (pounds) — the natural unit for metal stock — even\nwhen the part it feeds is counted in EA (each). Carbon happily mixes units: the\nCounterweight Hook's method consumes 40 LB of plate per 1 EA hook. More on units in\nthe glossary."},"1331":{"id":"/manual/items/materials-32","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#a-material-up-close","content":"Open any material to see its record. This is the one on the hero thread — the 1-inch A36 plate\nthat becomes the Counterweight Hook. The Details tab shows the four anatomy fields; other\ntabs cover where it's stored, who supplies it, and how it's replenished."},"1332":{"id":"/manual/items/materials-33","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#a-material-up-close","content":"Notice Batch tracked: Yes — that's not cosmetic. We'll come back to it below, because it\nchanges what happens every time this material moves."},"1333":{"id":"/manual/items/materials-34","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#cut-to-size-stock","content":"Most raw stock isn't consumed whole — you cut a piece off a larger plate or bar. Carbon models\nthis naturally: the material is the full stock item (a 96×240 sheet of 1-inch A36), and each\njob consumes only the quantity it needs, expressed in the material's unit of measure."},"1334":{"id":"/manual/items/materials-35","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#cut-to-size-stock","content":"On the hero thread, the Counterweight Hook's method pulls 40 LB of\nA36 plate per hook. A batch of 500 hooks therefore needs 20,000 LB — not 500 whole sheets.\nCarbon tracks the running pounds on hand and consumes against it, so a single sheet feeds many\nparts and you always know how much usable plate is left."},"1335":{"id":"/manual/items/materials-36","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#cut-to-size-stock","content":"type: tip"},"1336":{"id":"/manual/items/materials-37","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#cut-to-size-stock","content":"Buying stock in one unit and consuming it in another is common — you might purchase plate by\nthe sheet but consume it by the pound. Carbon supports a purchase unit and an inventory\nunit with a conversion between them. Acme keeps it simple and uses LB for both on its\nsteel. See purchasing basics for the buy side."},"1337":{"id":"/manual/items/materials-38","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"For materials, where the metal came from often matters as much as how much you have. A\nbatch (or lot, or heat for steel) is a group of stock that arrived together from one\nsupplier shipment. Turning on batch tracking tells Carbon to record a batch number every time\nthe material is received, and to carry that number forward into every part made from it."},"1338":{"id":"/manual/items/materials-39","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"Acme's A36 plate has requiresBatchTracking switched on. That single flag means:"},"1339":{"id":"/manual/items/materials-40","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"At receipt, Carbon asks for (or generates) a batch number when the steel arrives from\nRyerson on PO000057. The pounds are added to inventory\ntagged with that batch."},"1340":{"id":"/manual/items/materials-41","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"During the job, when 20,000 LB of plate is issued to job J000097, Carbon records which\nbatch (or batches) was consumed."},"1341":{"id":"/manual/items/materials-42","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"Forever after, the finished Counterweight Hooks carry a link back to that exact heat of\nsteel. If Ryerson later reports a problem with that heat, Acme can answer \"which orders did\nthat steel ship in?\" in seconds."},"1342":{"id":"/manual/items/materials-43","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"This chain — supplier shipment → material batch → job → finished part → customer — is what\nmanufacturers call traceability (or genealogy). It's a requirement in aerospace, defense\nand medical work, and it's exactly why Radiant Aerospace cares that Acme runs batch-tracked\nsteel. Read more in Tracking quality."},"1343":{"id":"/manual/items/materials-44","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"type: warn"},"1344":{"id":"/manual/items/materials-45","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"Decide on batch (or serial) tracking before you start\nreceiving a material. Switching it on after stock already exists in inventory is messy,\nbecause the existing quantity has no batch number attached. For regulated work, turn it on\nwhen you first create the material."},"1345":{"id":"/manual/items/materials-46","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"type: info"},"1346":{"id":"/manual/items/materials-47","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#batch-and-lot-tracking","content":"Batch vs. serial. Batch tracking groups many units under one number — right for bulk\nstock like plate and bar where individual pounds are interchangeable. Serial tracking gives\nevery single unit its own number — right for high-value finished parts you must track\none-by-one. Materials almost always use batch tracking."},"1347":{"id":"/manual/items/materials-48","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Here's how Acme added the 1-inch A36 plate. You'll create materials the same way for steel,\nstainless, aluminum, brass — anything you cut from raw stock."},"1348":{"id":"/manual/items/materials-49","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Open Items and start a new material. In the Items module, choose New → Material.\nPicking Material (rather than Part) gives you the substance/form/grade/dimension fields\ninstead of a blank part record."},"1349":{"id":"/manual/items/materials-50","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Pick the substance, form and grade. Choose Steel as the substance and Plate (PLT)\nas the form from Carbon's built-in lists. Enter the grade — A36 — and the dimensions:\n1″ thickness, 96 × 240 inch sheet. Carbon assembles these into a suggested readable\nID following your naming pattern (here, A36-STEEL-PLT-1\".96x240)."},"1350":{"id":"/manual/items/materials-51","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Set the unit of measure. Choose LB (Pound) — the unit you'll buy and consume the\nplate in. This is the unit every quantity for this material is expressed in, from purchase\norders to bills of materials to on-hand stock."},"1351":{"id":"/manual/items/materials-52","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Set replenishment to Buy. Because Acme buys plate rather than making it, set the\nreplenishment system to Buy. This unlocks the supplier\nand reorder settings and tells Carbon to suggest a purchase order when stock runs low."},"1352":{"id":"/manual/items/materials-53","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Turn on batch tracking (if needed). For traceable stock like aerospace steel, switch on\nRequires batch tracking now — before any inventory exists. Acme leaves this on for all\nits structural metals."},"1353":{"id":"/manual/items/materials-54","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Add the default supplier. On the Suppliers tab, add Ryerson as the source, with\nthe supplier's price (Acme pays $0.25/LB). Now the material is ready to be reordered and\nto appear on a purchase order like PO000057."},"1354":{"id":"/manual/items/materials-55","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Save. The material is now a first-class item: it can be dropped onto any\nmethod, stocked in any location,\nand bought from any supplier. The hero thread's hook is now buildable."},"1355":{"id":"/manual/items/materials-56","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"type: tip"},"1356":{"id":"/manual/items/materials-57","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#create-a-material","content":"Reuse, don't duplicate. Before creating a material, search the catalog — Acme already has\nA36 plate in 1″, 2″, 3″ and 4″ thicknesses. If the exact substance + form + size already\nexists, use it. Only create a new material when the physical stock is genuinely different."},"1357":{"id":"/manual/items/materials-58","page_id":"/manual/items/materials","tags":[],"type":"text","url":"/manual/items/materials#where-materials-show-up-next","content":"Once a material exists, it threads through the rest of Carbon:"},"1358":{"id":"/manual/items/methods","page_id":"/manual/items/methods","type":"page","content":"Methods: BOM & routing","tags":[],"url":"/manual/items/methods"},"1359":{"id":"/manual/items/methods-0","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods","content":"Tell Carbon how a part is made with a bill of materials and a routing."},"1360":{"id":"/manual/items/methods-1","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#the-two-halves-of-a-method","content":"The two halves of a method"},"1361":{"id":"/manual/items/methods-2","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#build-the-bill-of-materials","content":"Build the bill of materials"},"1362":{"id":"/manual/items/methods-3","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#open-the-parts-manufacturing-tab","content":"Open the part's Manufacturing tab"},"1363":{"id":"/manual/items/methods-4","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#add-a-material-line","content":"Add a material line"},"1364":{"id":"/manual/items/methods-5","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#set-the-quantity-per-piece","content":"Set the quantity per piece"},"1365":{"id":"/manual/items/methods-6","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#choose-the-method-type","content":"Choose the method type"},"1366":{"id":"/manual/items/methods-7","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#build-the-routing","content":"Build the routing"},"1367":{"id":"/manual/items/methods-8","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#add-the-first-operation","content":"Add the first operation"},"1368":{"id":"/manual/items/methods-9","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#enter-setup-and-run-time","content":"Enter setup and run time"},"1369":{"id":"/manual/items/methods-10","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#set-the-operation-order","content":"Set the operation order"},"1370":{"id":"/manual/items/methods-11","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#add-the-remaining-operations","content":"Add the remaining operations"},"1371":{"id":"/manual/items/methods-12","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#setup-vs-run-time-in-plain-numbers","content":"Setup vs. run time, in plain numbers"},"1372":{"id":"/manual/items/methods-13","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#multi-level-methods-sub-assemblies","content":"Multi-level methods (sub-assemblies)"},"1373":{"id":"/manual/items/methods-14","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#versions-and-revisions","content":"Versions and revisions"},"1374":{"id":"/manual/items/methods-15","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#a-quick-recap","content":"A quick recap"},"1375":{"id":"/manual/items/methods-16","page_id":"/manual/items/methods","type":"heading","tags":[],"url":"/manual/items/methods#next-steps","content":"Next steps"},"1376":{"id":"/manual/items/methods-17","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods","content":"A method is Carbon's word for the recipe that makes a part. Once you've created an\nitem that you make (rather than buy), the method is how\nyou teach Carbon what that part is made of and what steps turn raw stock into a finished\npiece. Get the method right once, and every future quote, job and cost estimate for that\npart is built from it automatically — no re-typing, no guesswork."},"1377":{"id":"/manual/items/methods-18","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods","content":"This page builds the method for Acme's hero part, the Counterweight Hook\n(CWH-A36-15), the same heavy steel hook that runs all the way through the\n15-minute walkthrough. By the end you'll know how to add materials,\nlay out a sequence of operations, point each step at the right machine, and keep older\nversions of a method around as the part evolves."},"1378":{"id":"/manual/items/methods-19","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods","content":"type: info"},"1379":{"id":"/manual/items/methods-20","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods","content":"Where this fits. A method lives on an item. So the order is: first\ndefine the item, then give it a method (this page), then\nCarbon can quote it and turn an order into a\njob on the shop floor. A method is the bridge between \"we\nsell this\" and \"here's exactly how we build it.\""},"1380":{"id":"/manual/items/methods-21","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#the-two-halves-of-a-method","content":"Every method is made of two parts that work together. Keep them straight and the rest of\nthis page is easy:"},"1381":{"id":"/manual/items/methods-22","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#the-two-halves-of-a-method","content":"The bill of materials (BOM) — what the part is made of. A list of the materials,\nsub-parts and sub-assemblies that go into one finished piece, each with a quantity. For\nthe hook, that's a single line: 40 lb of A36 steel plate."},"1382":{"id":"/manual/items/methods-23","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#the-two-halves-of-a-method","content":"The routing — how the part is made. An ordered list of operations\n(shop-floor steps), each run at a work center and each with a\ntime. For the hook: flame cut, then sandblast, then inspect."},"1383":{"id":"/manual/items/methods-24","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#the-two-halves-of-a-method","content":"Carbon shows both halves together as a method tree — the BOM and routing nested under\nthe part. Here's the whole recipe for the Counterweight Hook on one screen. We'll build it\npiece by piece below."},"1384":{"id":"/manual/items/methods-25","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#the-two-halves-of-a-method","content":"type: tip"},"1385":{"id":"/manual/items/methods-26","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#the-two-halves-of-a-method","content":"You'll find a part's method under its Manufacturing tab. The part itself (name, unit\nof measure, whether it's Make or Buy) is set on the item — see\nDefining an item. The method is where the making lives."},"1386":{"id":"/manual/items/methods-27","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-bill-of-materials","content":"The BOM answers one question: to make one of these, what do I consume? You add a line for\nevery material or sub-part, with the quantity needed for a single finished piece. Carbon\ndoes the multiplication later — when a job is for 500 hooks, it scales every BOM line by 500."},"1387":{"id":"/manual/items/methods-28","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-bill-of-materials","content":"For each material line you also choose how Carbon should get that material when a job\nruns. This is the line's method type, and the two you'll use most are:"},"1388":{"id":"/manual/items/methods-29","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-bill-of-materials","content":"Pull from Inventory — the material is already stocked (or will be); the job pulls it\noff the shelf. This is what the hook uses for its steel plate."},"1389":{"id":"/manual/items/methods-30","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-bill-of-materials","content":"Make — the material is itself something you manufacture, so it has its own method.\nThat's a sub-assembly (more on that below)."},"1390":{"id":"/manual/items/methods-31","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#open-the-parts-manufacturing-tab","content":"Go to Items, open the Counterweight Hook (CWH-A36-15), and select the\nManufacturing tab. A brand-new make part starts with an empty method — just the root\npart and nowhere for materials or operations yet."},"1391":{"id":"/manual/items/methods-32","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-a-material-line","content":"Under Bill of Materials, click Add Material. Search for and pick the raw material —\nhere, A36 Steel Plate 1″ (A36-STEEL-PLT-1\".96x240). Carbon pulls in its description and\nunit of measure automatically."},"1392":{"id":"/manual/items/methods-33","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#set-the-quantity-per-piece","content":"Enter how much one finished hook consumes: 40 in the unit LB (pounds). This is the\nper-each figure. Don't multiply by your batch size — Carbon scales it when it creates a\njob."},"1393":{"id":"/manual/items/methods-34","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#choose-the-method-type","content":"Set the line to Pull from Inventory. That tells Carbon the steel comes off the shelf\nrather than being made. (If stock runs short when a job is planned, Carbon flags the\nshortage so you can raise a purchase order — exactly what\nhappened on PO000057 to Ryerson in the walkthrough.)"},"1394":{"id":"/manual/items/methods-35","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#choose-the-method-type","content":"type: tip"},"1395":{"id":"/manual/items/methods-36","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#choose-the-method-type","content":"40 lb per piece, 20,000 lb per job. Because you entered the quantity per piece, a job\nfor 500 hooks automatically needs 40 × 500 = 20,000 lb of plate. Enter the small number\nonce and let Carbon scale it — that's the whole point of a per-each BOM."},"1396":{"id":"/manual/items/methods-37","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#choose-the-method-type","content":"type: warn"},"1397":{"id":"/manual/items/methods-38","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#choose-the-method-type","content":"A36 steel plate is batch-tracked at Acme. That means each receipt of plate gets a batch\nnumber, and when a job consumes it, Carbon records exactly which batch went into which\nhooks. You don't set that up on the method — it's a property of the material item — but\nit's why the hook earns full traceability downstream."},"1398":{"id":"/manual/items/methods-39","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-routing","content":"The routing is the ordered list of shop-floor steps. Each step is an operation, and an\noperation answers four things: what you do, where you do it, how long it takes, and\nwhen it can start relative to the other steps."},"1399":{"id":"/manual/items/methods-40","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-routing","content":"A couple of terms before we add the steps:"},"1400":{"id":"/manual/items/methods-41","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-routing","content":"A work center is a specific machine or station — for\nexample Burn Table — PA2 or Inspection Station. It carries its own labor and machine\nrates, which Carbon uses to cost the operation."},"1401":{"id":"/manual/items/methods-42","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-routing","content":"A process is the kind of work — Flame Cut,\nSandblasting, Quality Inspection. A work center can perform one or more processes.\nWhen you add an operation you pick the process, and Carbon offers the work centers that can\nrun it."},"1402":{"id":"/manual/items/methods-43","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-routing","content":"The hook's routing is three operations, in this order:"},"1403":{"id":"/manual/items/methods-44","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#build-the-routing","content":"Here's how to add each one."},"1404":{"id":"/manual/items/methods-45","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-the-first-operation","content":"Under Routing, click Add Operation. Pick the process Flame Cut, then choose the\nwork center Burn Table — PA2. Carbon assigns it sequence number 10 — routings are\nnumbered in tens (10, 20, 30…) so you have room to slot a step in between later without\nrenumbering everything."},"1405":{"id":"/manual/items/methods-46","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#enter-setup-and-run-time","content":"Every operation can carry two kinds of time:"},"1406":{"id":"/manual/items/methods-47","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#enter-setup-and-run-time","content":"Setup time — a one-time amount per job, no matter the quantity (e.g. fixturing a part,\nloading a program). The hook's flame cut has 0 setup."},"1407":{"id":"/manual/items/methods-48","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#enter-setup-and-run-time","content":"Run time (labor time) — the per-piece time to actually do the work. For flame cut,\nthat's 45 Minutes/Piece."},"1408":{"id":"/manual/items/methods-49","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#enter-setup-and-run-time","content":"The unit matters as much as the number. Minutes/Piece multiplies by the job quantity;\nTotal Minutes does not. So 45 Minutes/Piece on a 500-piece job is 375 hours of cutting,\nwhile a setup entered as Total Minutes stays fixed. Carbon uses these times plus the work\ncenter's rates to estimate the job's cost and schedule."},"1409":{"id":"/manual/items/methods-50","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#set-the-operation-order","content":"Leave the order as After Previous. That tells Carbon this step can't start until the one\nbefore it finishes — the natural sequence for the hook (you can't sandblast before you've\ncut). The alternative, With Previous, lets two steps run in parallel; you'd use it when,\nsay, two stations work the same part at once."},"1410":{"id":"/manual/items/methods-51","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-the-remaining-operations","content":"Repeat for the other two steps, in order:"},"1411":{"id":"/manual/items/methods-52","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-the-remaining-operations","content":"20 · Sandblasting — process Sandblasting, work center Sand Blasting Room,\n2 Minutes/Piece, After Previous."},"1412":{"id":"/manual/items/methods-53","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-the-remaining-operations","content":"30 · Inspection — process Quality Inspection, work center Inspection Station,\n10 Minutes/Piece, After Previous."},"1413":{"id":"/manual/items/methods-54","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-the-remaining-operations","content":"The last step being an inspection is deliberate: it's the quality gate before the hooks can\nship. More on that in Tracking quality."},"1414":{"id":"/manual/items/methods-55","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-the-remaining-operations","content":"type: tip"},"1415":{"id":"/manual/items/methods-56","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#add-the-remaining-operations","content":"Inside vs. outside operations. All three hook operations are Inside — Acme does them\nin its own shop. If a step is sent to a vendor (anodizing, heat treat, plating), you'd mark\nit an Outside operation, and Carbon can raise a purchase order to the subcontractor for\nthat service. See Advanced purchasing."},"1416":{"id":"/manual/items/methods-57","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#setup-vs-run-time-in-plain-numbers","content":"Because setup and run time behave differently, it's worth seeing what they do to a real\nbatch. For the hook's flame-cut step at a 500-piece job:"},"1417":{"id":"/manual/items/methods-58","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#setup-vs-run-time-in-plain-numbers","content":"The takeaway: run time scales with quantity, setup doesn't. Spreading a fixed setup over\nmore pieces is why larger batches usually cost less per piece — and Carbon does that math for\nyou the moment you set a job quantity."},"1418":{"id":"/manual/items/methods-59","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#multi-level-methods-sub-assemblies","content":"The hook is a single-level method — raw material straight to finished part. But many\nproducts are built from sub-parts that are themselves manufactured. Carbon handles this with\nmulti-level methods: a BOM line can point at another make part, which brings its own\nBOM and routing along."},"1419":{"id":"/manual/items/methods-60","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#multi-level-methods-sub-assemblies","content":"The mechanism is the material line's method type again. Set a BOM line to Make (instead\nof Pull from Inventory) and that line becomes a sub-assembly — Carbon nests the child\npart's whole method underneath it in the tree. When a job runs, Carbon can create\nsub-jobs to build those sub-assemblies first."},"1420":{"id":"/manual/items/methods-61","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#multi-level-methods-sub-assemblies","content":"Here's the idea, using a made-up two-level part so you can see the shape (the hook itself\nstays single-level):"},"1421":{"id":"/manual/items/methods-62","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#multi-level-methods-sub-assemblies","content":"type: info"},"1422":{"id":"/manual/items/methods-63","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#multi-level-methods-sub-assemblies","content":"You don't redefine a sub-assembly's recipe each time you use it. Define its method once on\nits own item, then drop it into as many parent BOMs as you like. Update it in one place and\nevery parent picks up the change on its next job."},"1423":{"id":"/manual/items/methods-64","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#versions-and-revisions","content":"Methods aren't frozen — parts change. Carbon keeps history so a change today doesn't rewrite\nwhat you already built and shipped."},"1424":{"id":"/manual/items/methods-65","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#versions-and-revisions","content":"A revision is a deliberate, named iteration of the part itself (Rev 0, Rev A, Rev B…),\nusually driven by an engineering change. The hook is at revision 0. Each revision can\ncarry its own method, so you can quote and build an old revision long after a new one\nexists."},"1425":{"id":"/manual/items/methods-66","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#versions-and-revisions","content":"A version is Carbon's internal snapshot of a method. When a job\nis created, it takes its own copy of the method as it stands at that moment — a job make\nmethod. After that, editing the part's master method does not change a job already in\nflight."},"1426":{"id":"/manual/items/methods-67","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#versions-and-revisions","content":"This copy-on-create behavior is the safety net behind the whole walkthrough: job J000097\nmade 500 hooks against the method exactly as it was the day it was released, even if\nengineering tweaks the master method next month."},"1427":{"id":"/manual/items/methods-68","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#versions-and-revisions","content":"type: warn"},"1428":{"id":"/manual/items/methods-69","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#versions-and-revisions","content":"Editing the master method only affects future jobs. If a hook already running on the\nshop floor needs a routing change, edit it on that job's method, not (only) on the part.\nChanging the part's master method updates the recipe new jobs will copy — it does not reach\nback into jobs already created."},"1429":{"id":"/manual/items/methods-70","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#a-quick-recap","content":"You've now built a complete method for the Counterweight Hook:"},"1430":{"id":"/manual/items/methods-71","page_id":"/manual/items/methods","tags":[],"type":"text","url":"/manual/items/methods#a-quick-recap","content":"With the method in place, Carbon can estimate a price, plan the work, and create a job the\nmoment an order lands — which is exactly what happens next in the flow."},"1431":{"id":"/manual/items/replenishment","page_id":"/manual/items/replenishment","type":"page","content":"Replenishment: make vs. buy","tags":[],"url":"/manual/items/replenishment"},"1432":{"id":"/manual/items/replenishment-0","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment","content":"Reorder policies, lead times and planning parameters that keep stock flowing."},"1433":{"id":"/manual/items/replenishment-1","page_id":"/manual/items/replenishment","type":"heading","tags":[],"url":"/manual/items/replenishment#the-two-questions-carbon-asks","content":"The two questions Carbon asks"},"1434":{"id":"/manual/items/replenishment-2","page_id":"/manual/items/replenishment","type":"heading","tags":[],"url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"Step 1 — The replenishment system (make or buy)"},"1435":{"id":"/manual/items/replenishment-3","page_id":"/manual/items/replenishment","type":"heading","tags":[],"url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"Step 2 — The method type on a line"},"1436":{"id":"/manual/items/replenishment-4","page_id":"/manual/items/replenishment","type":"heading","tags":[],"url":"/manual/items/replenishment#how-demand-and-supply-drive-planning","content":"How demand and supply drive planning"},"1437":{"id":"/manual/items/replenishment-5","page_id":"/manual/items/replenishment","type":"heading","tags":[],"url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Step 3 — Set the planning parameters"},"1438":{"id":"/manual/items/replenishment-6","page_id":"/manual/items/replenishment","type":"heading","tags":[],"url":"/manual/items/replenishment#putting-it-together-a-policy-at-a-glance","content":"Putting it together: a policy at a glance"},"1439":{"id":"/manual/items/replenishment-7","page_id":"/manual/items/replenishment","type":"heading","tags":[],"url":"/manual/items/replenishment#next-steps","content":"Next steps"},"1440":{"id":"/manual/items/replenishment-8","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment","content":"Every item in Carbon has to come from somewhere. A finished\npart might roll off your shop floor; a sheet of steel arrives on a truck from a supplier.\nReplenishment is the word Carbon uses for how an item gets here — and getting it\nright is what stops your shop from running out of steel mid-job or from making 500 of\nsomething nobody ordered. This page explains the two settings that drive all of it\n(make vs. buy, and the fulfillment method on a line), then the planning numbers —\nlead time, safety stock, reorder point — that let Carbon top up your stock for you."},"1441":{"id":"/manual/items/replenishment-9","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment","content":"type: info"},"1442":{"id":"/manual/items/replenishment-10","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment","content":"Where this fits. You've already learned to define an item,\ngive it a method, and decide what counts as\nmaterial. Replenishment is the last decision on an item:\nhow do we obtain it? That answer flows straight into\nJobs (for the things you make) and\nPurchasing (for the things you buy)."},"1443":{"id":"/manual/items/replenishment-11","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#the-two-questions-carbon-asks","content":"Replenishment comes down to two questions, asked at two different moments."},"1444":{"id":"/manual/items/replenishment-12","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#the-two-questions-carbon-asks","content":"On the item: in general, do we make this or buy this? Carbon stores the answer in\na field called the replenishment system."},"1445":{"id":"/manual/items/replenishment-13","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#the-two-questions-carbon-asks","content":"On each line (a sales order line, a job material, a quote line): for this specific\ndemand, how do we satisfy it — make a fresh batch, pull from the shelf, or order it in?\nCarbon stores that answer in a field called the method type."},"1446":{"id":"/manual/items/replenishment-14","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#the-two-questions-carbon-asks","content":"The item-level answer is the default. The line-level answer is the decision Carbon actually\nacts on, and it can differ line by line. Hold onto that distinction — it's the single thing\npeople trip over."},"1447":{"id":"/manual/items/replenishment-15","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"The replenishment system lives on the item itself, on the Replenishment area of the\nitem record. It has three values:"},"1448":{"id":"/manual/items/replenishment-16","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"Make — Carbon expects to produce this item with a job.\nIt must have a method (a BOM + routing). Our hero part, the\nCounterweight Hook, is Make."},"1449":{"id":"/manual/items/replenishment-17","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"Buy — Carbon expects to purchase this item from a supplier on a\npurchase order. It needs a supplier and a purchase price.\nThe A36 steel plate the hook is cut from is Buy."},"1450":{"id":"/manual/items/replenishment-18","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"Make & Buy — both are allowed. Use this for an item you usually make but sometimes\nbuy in (or vice versa). You then pick make-or-buy per line."},"1451":{"id":"/manual/items/replenishment-19","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"Here are the two hero items side by side. Same company, opposite answers."},"1452":{"id":"/manual/items/replenishment-20","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"type: tip"},"1453":{"id":"/manual/items/replenishment-21","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-1--the-replenishment-system-make-or-buy","content":"A quick rule of thumb: if an item has a method, it's almost always Make. If it has\na preferred supplier and a purchase price, it's Buy. Carbon won't let a Buy item\ngo onto a job as something-to-produce, and it won't let a Make item with no supplier go\nonto a purchase order — the replenishment system is what gates those choices."},"1454":{"id":"/manual/items/replenishment-22","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"When an item shows up as demand — a customer orders it, or a parent job needs it as a\ncomponent — Carbon has to decide how to satisfy that one line. That choice is the\nmethod type, and there are three:"},"1455":{"id":"/manual/items/replenishment-23","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"Make to Order (MTO) — create a brand-new job tied to this demand. The job exists to\nfill this order and nothing else. Best for custom or low-volume parts you don't stock."},"1456":{"id":"/manual/items/replenishment-24","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"Make to Stock (MTS) — make a batch into inventory ahead of demand, then ship from the\nshelf. Best for parts you sell repeatedly and want ready to go."},"1457":{"id":"/manual/items/replenishment-25","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"Pull from Inventory — don't make or buy anything new for this line; consume what's\nalready on the shelf. This is how components get drawn into a parent job, and how stocked\nfinished goods get shipped."},"1458":{"id":"/manual/items/replenishment-26","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"On the Counterweight Hook's sales order, the line is Make to Order — so Carbon spun up\njob J000097 the moment the order was confirmed. Inside that job's\nmethod, the A36 steel appears as a material line set to\nPull from Inventory — Carbon expects to draw the 40 lb per piece from the shelf rather\nthan buy fresh steel for the job itself."},"1459":{"id":"/manual/items/replenishment-27","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"type: info"},"1460":{"id":"/manual/items/replenishment-28","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-2--the-method-type-on-a-line","content":"\"Pull from Inventory\" assumes the inventory is there. Carbon will happily plan to pull\n20,000 lb of steel for this job — but if the shelf is short, that shortage becomes new\ndemand for the steel, which (because steel is a Buy item) turns into a suggested\npurchase order. That's exactly how PO000057 to Ryerson came to exist. Make and buy aren't\nseparate worlds; one feeds the other."},"1461":{"id":"/manual/items/replenishment-29","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#how-demand-and-supply-drive-planning","content":"Here's the mental model that makes everything else click. Carbon is constantly comparing two\ncolumns for every item, at every location:"},"1462":{"id":"/manual/items/replenishment-30","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#how-demand-and-supply-drive-planning","content":"When demand outruns supply, Carbon flags a shortage and proposes the fix that matches the\nitem's replenishment system:"},"1463":{"id":"/manual/items/replenishment-31","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#how-demand-and-supply-drive-planning","content":"A shortage on a Make item becomes a suggested job."},"1464":{"id":"/manual/items/replenishment-32","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#how-demand-and-supply-drive-planning","content":"A shortage on a Buy item becomes a suggested purchase order."},"1465":{"id":"/manual/items/replenishment-33","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#how-demand-and-supply-drive-planning","content":"You review those suggestions in Carbon's planning views and turn the good ones into real jobs\nand POs. Nothing happens behind your back — Carbon does the arithmetic, you make the call."},"1466":{"id":"/manual/items/replenishment-34","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#how-demand-and-supply-drive-planning","content":"Notice every line of demand here is matched by a job that fills it — because the hook is\nMake to Order, supply is created to order. For a Buy item like the A36 steel, the supply\ncolumn fills with purchase orders instead."},"1467":{"id":"/manual/items/replenishment-35","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"For a pure Make-to-Order part, planning is simple: an order arrives, a job is made, done.\nThe numbers below matter most for items you stock — raw materials you buy in bulk, and\nfinished goods you make to stock — because Carbon uses them to decide when and how much\nto replenish before you run dry."},"1468":{"id":"/manual/items/replenishment-36","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"You'll find these on the item's Planning tab, set per location (Headquarters and Texas\ncan have different numbers for the same item)."},"1469":{"id":"/manual/items/replenishment-37","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Pick a reordering policy. This tells Carbon when to suggest a top-up. The common\nchoices are:"},"1470":{"id":"/manual/items/replenishment-38","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Manual Reorder — Carbon never auto-suggests; you create jobs and POs yourself."},"1471":{"id":"/manual/items/replenishment-39","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Demand-Based Reorder — Carbon looks ahead over a window of time (a demand window,\nset to 4 weeks for both hero items), totals up the demand in that window, and suggests\nenough supply to cover it. This is what both hero items use."},"1472":{"id":"/manual/items/replenishment-40","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Maximum Quantity — keep the shelf topped up toward a target level (a classic min/max)."},"1473":{"id":"/manual/items/replenishment-41","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Set the reorder point and quantities. Depending on the policy, you'll fill in some of:"},"1474":{"id":"/manual/items/replenishment-42","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Reorder point — the on-hand level that triggers a refill. Drop below it and Carbon\nraises a suggestion."},"1475":{"id":"/manual/items/replenishment-43","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Reorder quantity — how much to order each time you do."},"1476":{"id":"/manual/items/replenishment-44","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Minimum / maximum order quantity — floor and ceiling on a single order (a supplier\nmight require a 1,000-lb minimum, for example)."},"1477":{"id":"/manual/items/replenishment-45","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Maximum inventory quantity — the ceiling you top up toward under a Maximum Quantity\npolicy."},"1478":{"id":"/manual/items/replenishment-46","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Order multiple — round orders up to a sensible pack size (order in multiples of, say,\none full sheet rather than odd pounds)."},"1479":{"id":"/manual/items/replenishment-47","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Set safety stock. This is the buffer you want sitting on the shelf beyond known demand,\nto absorb surprises. Acme keeps 3,000 LB of A36 steel as safety stock at Headquarters, so\nCarbon always plans to keep that cushion on hand on top of whatever the jobs need. The hook\nitself carries no safety stock — it's made to order, so there's nothing to buffer."},"1480":{"id":"/manual/items/replenishment-48","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Set the lead time. Lead time is how long replenishment takes — days to receive a PO, or\ndays to run a job. Both hero items use a 7-day lead time. Carbon works backwards from your\ndue date by the lead time to tell you the latest day you can place the order or release the\njob and still be on time."},"1481":{"id":"/manual/items/replenishment-49","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"Set lot sizing and scrap. Lot size controls batching — make/buy in fixed lots\n(0 means \"exactly what's needed\", no rounding). Scrap percentage pads quantities for\nexpected loss, so a job that needs 500 good pieces might be sized a little larger. Both hero\nitems use lot size 0 and 0% scrap."},"1482":{"id":"/manual/items/replenishment-50","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"type: warn"},"1483":{"id":"/manual/items/replenishment-51","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#step-3--set-the-planning-parameters","content":"A reorder point is per location, not per company. Setting a reorder point at\nHeadquarters does nothing for Texas. If you stock the same material in two places, give each\nlocation its own planning numbers — otherwise one site will quietly run dry while the other\nis overstocked."},"1484":{"id":"/manual/items/replenishment-52","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#putting-it-together-a-policy-at-a-glance","content":"Different items, different jobs to do — so different replenishment settings. Here's how a few\nreal Acme items compare, and why each is set the way it is."},"1485":{"id":"/manual/items/replenishment-53","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#putting-it-together-a-policy-at-a-glance","content":"Read it as a story: the hook is made fresh for each order; the steel it's cut from is\nbought in bulk and pulled off the shelf, with a 3,000-lb cushion so a job never stalls waiting\nfor material; the Thermal Exhaust Nozzle is made in large batches into stock because it\nsells steadily; and nitrile gloves are just bought and consumed. Same machinery, four\ndifferent replenishment strategies — all driven by those two fields and a handful of planning\nnumbers."},"1486":{"id":"/manual/items/replenishment-54","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#putting-it-together-a-policy-at-a-glance","content":"type: tip"},"1487":{"id":"/manual/items/replenishment-55","page_id":"/manual/items/replenishment","tags":[],"type":"text","url":"/manual/items/replenishment#putting-it-together-a-policy-at-a-glance","content":"Start simple. You don't need every parameter on day one. Set the replenishment\nsystem (make or buy) on every item, set a lead time so dates are realistic, and add\nsafety stock and reorder points only to the items where running out actually hurts.\nYou can always tighten the numbers once you see how stock really moves."},"1488":{"id":"/manual/manufacturing/jobs","page_id":"/manual/manufacturing/jobs","type":"page","content":"Jobs","tags":[],"url":"/manual/manufacturing/jobs"},"1489":{"id":"/manual/manufacturing/jobs-0","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs","content":"Create production jobs from a sales order or from scratch."},"1490":{"id":"/manual/manufacturing/jobs-1","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#what-a-job-is","content":"What a job is"},"1491":{"id":"/manual/manufacturing/jobs-2","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#how-a-job-gets-created","content":"How a job gets created"},"1492":{"id":"/manual/manufacturing/jobs-3","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#1-automatically-from-a-make-to-order-sales-order-line","content":"1. Automatically, from a Make-to-Order sales order line"},"1493":{"id":"/manual/manufacturing/jobs-4","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#2-manually-when-you-need-a-job-on-its-own","content":"2. Manually, when you need a job on its own"},"1494":{"id":"/manual/manufacturing/jobs-5","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#the-fields-that-drive-a-job","content":"The fields that drive a job"},"1495":{"id":"/manual/manufacturing/jobs-6","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#the-method-the-job-carries","content":"The method the job carries"},"1496":{"id":"/manual/manufacturing/jobs-7","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#operations-the-steps-in-order","content":"Operations: the steps, in order"},"1497":{"id":"/manual/manufacturing/jobs-8","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#materials-what-the-job-will-consume","content":"Materials: what the job will consume"},"1498":{"id":"/manual/manufacturing/jobs-9","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#releasing-a-job-to-the-floor","content":"Releasing a job to the floor"},"1499":{"id":"/manual/manufacturing/jobs-10","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#job-statuses","content":"Job statuses"},"1500":{"id":"/manual/manufacturing/jobs-11","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#where-the-numbers-go-next","content":"Where the numbers go next"},"1501":{"id":"/manual/manufacturing/jobs-12","page_id":"/manual/manufacturing/jobs","type":"heading","tags":[],"url":"/manual/manufacturing/jobs#next-steps","content":"Next steps"},"1502":{"id":"/manual/manufacturing/jobs-13","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs","content":"A job is a production order: Carbon's instruction to the shop floor to make a\nspecific quantity of a part by a specific date. If a sales order\nis the promise you made to a customer, the job is how you keep it. This page follows one\nreal job — J000097, where Acme makes 500 Counterweight Hooks for Radiant Aerospace —\nso you can see exactly how a job is born, what it carries, and how you turn it loose on the\nshop floor."},"1503":{"id":"/manual/manufacturing/jobs-14","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs","content":"type: info"},"1504":{"id":"/manual/manufacturing/jobs-15","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs","content":"Where this fits. A job sits in the middle of the end-to-end flow:\nQuote → Sales Order → Job → Purchasing → Quality → Shipment → Invoice. The job we follow here\ncomes straight from sales order SO000069 and feeds\npurchase order PO000057 (the steel it needs).\nOnce it's released, operators run it in the shop-floor app,\nand you track its day-to-day progress in managing production."},"1505":{"id":"/manual/manufacturing/jobs-16","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"When you make something rather than buy it, that work has to be planned, tracked, costed\nand finished. A job is the record that holds all of it together. A single job answers:"},"1506":{"id":"/manual/manufacturing/jobs-17","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"What are we making? (the part — here, CWH-A36-15, the Counterweight Hook)"},"1507":{"id":"/manual/manufacturing/jobs-18","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"How many? (the production quantity — 500 each)"},"1508":{"id":"/manual/manufacturing/jobs-19","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"By when? (the due date — 2026-06-26)"},"1509":{"id":"/manual/manufacturing/jobs-20","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"How is it made? (the method — a recipe of materials and steps)"},"1510":{"id":"/manual/manufacturing/jobs-21","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"Where are we? (the status, and how many good pieces are done)"},"1511":{"id":"/manual/manufacturing/jobs-22","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"The big idea: a job carries its own copy of the method. When the job is created, Carbon\nsnapshots the part's bill of materials and routing onto the job. From that moment the job\nis self-contained — even if someone later edits the part's master method, this job keeps the\nrecipe it was created with. That's what lets you trust a finished job's cost and\ntraceability months later."},"1512":{"id":"/manual/manufacturing/jobs-23","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"type: tip"},"1513":{"id":"/manual/manufacturing/jobs-24","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#what-a-job-is","content":"Method = BOM + Routing. The bill of materials (BOM)\nis what the part is made of; the routing is the ordered steps to make it. A job\ncopies both. We cover authoring methods in depth in\nMethods: BOM & routing."},"1514":{"id":"/manual/manufacturing/jobs-25","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#how-a-job-gets-created","content":"There are two ways a job comes into being. Most jobs at Acme are created the first way,\nwithout anyone lifting a finger."},"1515":{"id":"/manual/manufacturing/jobs-26","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#1-automatically-from-a-make-to-order-sales-order-line","content":"When a sales order line is set to Make to Order — meaning \"don't ship this from stock,\nmake it fresh for this order\" — Carbon offers to spin up a job for that line directly from\nthe sales order. The job is pre-filled with the part, the quantity, the customer and the due\ndate from the order, and it stays linked back to the line it came from."},"1516":{"id":"/manual/manufacturing/jobs-27","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#1-automatically-from-a-make-to-order-sales-order-line","content":"This is exactly how J000097 was born. Look at the source line on SO000069:"},"1517":{"id":"/manual/manufacturing/jobs-28","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#1-automatically-from-a-make-to-order-sales-order-line","content":"Because the line says Make to Order, Carbon links job J000097 to it. The job knows it's\nworking for SO000069, and the order knows the job is making its 500 hooks. You never typed\nthe part number or quantity into the job — they flowed in from the order."},"1518":{"id":"/manual/manufacturing/jobs-29","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#1-automatically-from-a-make-to-order-sales-order-line","content":"type: info"},"1519":{"id":"/manual/manufacturing/jobs-30","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#1-automatically-from-a-make-to-order-sales-order-line","content":"The same automatic link happens for the other two Radiant orders for this part:\nSO000070 created job J000098 (1,500 EA) and SO000071 created job J000099\n(3,000 EA). One part, three orders, three independent jobs."},"1520":{"id":"/manual/manufacturing/jobs-31","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#2-manually-when-you-need-a-job-on-its-own","content":"Sometimes you want a job that isn't tied to a customer order — for example, building parts\nto stock, a rework batch, or a one-off prototype. In that case you create the job yourself.\nAcme's job J000094 (10,000 Thermal Exhaust Nozzles, built to stock) is a manual job like\nthis; it has no sales order behind it."},"1521":{"id":"/manual/manufacturing/jobs-32","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#2-manually-when-you-need-a-job-on-its-own","content":"Open the Jobs list and start a new job. Go to the Jobs area under the production\nmodule. You'll see every job in the system — Acme has 89 of them, J000001 through\nJ000099. Click New Job."},"1522":{"id":"/manual/manufacturing/jobs-33","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#2-manually-when-you-need-a-job-on-its-own","content":"Pick the part. Choose the item you want to make — for\nexample CWH-A36-15, the Counterweight Hook. Carbon checks that the part is a Make item\n(its replenishmentSystem is Make, not Buy) and pulls in its description and unit of\nmeasure (EA)."},"1523":{"id":"/manual/manufacturing/jobs-34","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#2-manually-when-you-need-a-job-on-its-own","content":"Set the quantity, due date and priority. Enter how many to make, when they're needed,\nand how urgent the job is relative to others. We'll look at each of these fields next."},"1524":{"id":"/manual/manufacturing/jobs-35","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#2-manually-when-you-need-a-job-on-its-own","content":"Save. Carbon assigns the next job number and snapshots the part's method onto the new\njob. The job opens in the Planned status, ready for you to review before you release it."},"1525":{"id":"/manual/manufacturing/jobs-36","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-fields-that-drive-a-job","content":"When you open J000097 you land on its Details tab. A handful of fields do most of the\nwork; everything else on the shop floor flows from them."},"1526":{"id":"/manual/manufacturing/jobs-37","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-fields-that-drive-a-job","content":"Production quantity is how many good pieces you intend to finish — here, 500. If you\nexpect to lose some to scrap, you can also set a separate scrap quantity so Carbon plans\nenough material; J000097 ran with a scrap quantity of 0."},"1527":{"id":"/manual/manufacturing/jobs-38","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-fields-that-drive-a-job","content":"Due date is when the parts must be done. The deadline type tells Carbon how to treat\nthat date: a Hard Deadline (used here) is a firm commitment, versus a soft target. This\nfeeds the scheduling and the at-a-glance \"is this job late?\" view in\nmanaging production."},"1528":{"id":"/manual/manufacturing/jobs-39","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-fields-that-drive-a-job","content":"Priority ranks this job against every other open job competing for the same machines and\npeople. J000097 is priority 1 — the highest — so it jumps the queue at the burn table.\nLower-priority jobs wait their turn."},"1529":{"id":"/manual/manufacturing/jobs-40","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-fields-that-drive-a-job","content":"type: tip"},"1530":{"id":"/manual/manufacturing/jobs-41","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-fields-that-drive-a-job","content":"Location matters. A job is made at one location.\nJ000097 runs at Headquarters, so it can only use Headquarters work centers (like\nBurn Table — PA2) and pulls material from Headquarters stock. Acme's other location, Texas,\nhas its own burn tables and laser tables."},"1531":{"id":"/manual/manufacturing/jobs-42","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-method-the-job-carries","content":"Click the Method tab and you'll see the recipe Carbon copied onto the job. For the\nCounterweight Hook it's short: one material, three operations. The root node is the part\nitself; everything indented under it is what goes into making it."},"1532":{"id":"/manual/manufacturing/jobs-43","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-method-the-job-carries","content":"Two things to notice. First, the BOM has a single material line: 40 LB of A36 steel\nplate per piece. Multiply by 500 and the job needs 20,000 LB of steel — Carbon does\nthat math for you. Second, the material is set to Pull from Inventory, meaning the job\nexpects to draw the steel from stock; the purchase order to Ryerson\nexists to make sure that stock is there."},"1533":{"id":"/manual/manufacturing/jobs-44","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-method-the-job-carries","content":"type: info"},"1534":{"id":"/manual/manufacturing/jobs-45","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#the-method-the-job-carries","content":"Because the job carries its own copy of this method, you can tweak it for this run only —\nswap a material, add a deburring step, change a time — without touching the part's master\nmethod or any other job. Edits here affect J000097 and nothing else."},"1535":{"id":"/manual/manufacturing/jobs-46","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#operations-the-steps-in-order","content":"The Operations tab lists the routing as a sequence. Each operation runs at one work\ncenter (a specific machine or station) and has a time per piece. Operations run in order —\neach one here is set to start After Previous, so Sandblasting can't begin until Flame Cut\nis done."},"1536":{"id":"/manual/manufacturing/jobs-47","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#operations-the-steps-in-order","content":"Every operation here is Inside (done in Acme's own shop) rather than outside\n(subcontracted). The labor time is per piece, so Carbon can estimate the total: 45 minutes\nof flame cutting × 500 pieces is the bulk of the work, with a quick sandblast and a final\ninspection gate at the end. As operators clock on and report finished pieces in the\nshop-floor app, the Complete and Status columns\nfill in — that's how all three reached Done and the whole job rolled up its real recorded\ncost."},"1537":{"id":"/manual/manufacturing/jobs-48","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#operations-the-steps-in-order","content":"type: tip"},"1538":{"id":"/manual/manufacturing/jobs-49","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#operations-the-steps-in-order","content":"The last operation, Inspection, is a quality step. Putting an inspection at the end of\nthe routing makes it a gate: the parts aren't considered finished until they pass. See\nTracking quality."},"1539":{"id":"/manual/manufacturing/jobs-50","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#materials-what-the-job-will-consume","content":"The Materials tab is the job's shopping list — every material it needs, with how much it\nexpects to use. For J000097 it's one line:"},"1540":{"id":"/manual/manufacturing/jobs-51","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#materials-what-the-job-will-consume","content":"The steel is batch-tracked, so when it's consumed Carbon records exactly which heat of\nmaterial went into this batch of hooks — the foundation of Radiant's\ntraceability. The material is pulled from bin\nR02-B01-01 at Headquarters."},"1541":{"id":"/manual/manufacturing/jobs-52","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#releasing-a-job-to-the-floor","content":"A new job starts life as Planned — a draft you can still edit freely. Nothing reaches the\nshop floor until you release it. Releasing is the deliberate \"go\" that says this job is\nreal, schedule it and let operators start clocking on."},"1542":{"id":"/manual/manufacturing/jobs-53","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#releasing-a-job-to-the-floor","content":"Review the job. Confirm the quantity, due date and priority on Details, and skim the\nMethod, Operations and Materials tabs to make sure the recipe is right for this\nrun."},"1543":{"id":"/manual/manufacturing/jobs-54","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#releasing-a-job-to-the-floor","content":"Check material availability. Carbon flags any shortages. For J000097, the 20,000 LB of\nA36 steel wasn't all on hand, which is why Acme raised\npurchase order PO000057 to Ryerson. Buying and making can\nrun in parallel — you don't have to wait for steel to release the job."},"1544":{"id":"/manual/manufacturing/jobs-55","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#releasing-a-job-to-the-floor","content":"Release the job. Click Release. Carbon stamps the released date — for J000097 that\nwas 2026-06-11 — moves the job into the active queue, and makes its operations available in\nthe shop-floor app."},"1545":{"id":"/manual/manufacturing/jobs-56","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#releasing-a-job-to-the-floor","content":"The floor takes over. Operators clock onto each operation in sequence and report finished\npieces. When the last operation's good quantity reaches the production quantity, the job is\nCompleted — J000097 completed the same day, with all 500 pieces done and later shipped."},"1546":{"id":"/manual/manufacturing/jobs-57","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#job-statuses","content":"A job moves through a clear set of statuses as it goes from idea to finished parts. Acme's 89\njobs are spread across all of them right now:"},"1547":{"id":"/manual/manufacturing/jobs-58","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#job-statuses","content":"Here's what each status means and how a job moves between them:"},"1548":{"id":"/manual/manufacturing/jobs-59","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#job-statuses","content":"type: warn"},"1549":{"id":"/manual/manufacturing/jobs-60","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#job-statuses","content":"A Planned job does nothing on its own. It won't appear on the shop floor and operators\ncan't book time to it until you release it. If a job seems \"stuck\" with no activity,\nthe first thing to check is whether it's still in Planned."},"1550":{"id":"/manual/manufacturing/jobs-61","page_id":"/manual/manufacturing/jobs","tags":[],"type":"text","url":"/manual/manufacturing/jobs#where-the-numbers-go-next","content":"Once J000097 completed, its 500 finished hooks were received into inventory, shipped to\nRadiant Aerospace, and billed on invoice AR000025. The job's\nrecorded labor and material rolled up into the cost of those parts — closing the loop between\nwhat you planned and what it actually took."},"1551":{"id":"/manual/manufacturing/managing-production","page_id":"/manual/manufacturing/managing-production","type":"page","content":"Managing production","tags":[],"url":"/manual/manufacturing/managing-production"},"1552":{"id":"/manual/manufacturing/managing-production-0","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production","content":"Schedule, track and plan work across the shop."},"1553":{"id":"/manual/manufacturing/managing-production-1","page_id":"/manual/manufacturing/managing-production","type":"heading","tags":[],"url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"The big picture: demand in, plan out"},"1554":{"id":"/manual/manufacturing/managing-production-2","page_id":"/manual/manufacturing/managing-production","type":"heading","tags":[],"url":"/manual/manufacturing/managing-production#the-planning-view","content":"The planning view"},"1555":{"id":"/manual/manufacturing/managing-production-3","page_id":"/manual/manufacturing/managing-production","type":"heading","tags":[],"url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Scheduling jobs across work centers"},"1556":{"id":"/manual/manufacturing/managing-production-4","page_id":"/manual/manufacturing/managing-production","type":"heading","tags":[],"url":"/manual/manufacturing/managing-production#prioritizing-what-runs-first","content":"Prioritizing what runs first"},"1557":{"id":"/manual/manufacturing/managing-production-5","page_id":"/manual/manufacturing/managing-production","type":"heading","tags":[],"url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Tracking progress across the shop"},"1558":{"id":"/manual/manufacturing/managing-production-6","page_id":"/manual/manufacturing/managing-production","type":"heading","tags":[],"url":"/manual/manufacturing/managing-production#next-steps","content":"Next steps"},"1559":{"id":"/manual/manufacturing/managing-production-7","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production","content":"A single job is easy to follow. The real challenge starts when you have dozens of them at\nonce — some waiting on steel, some halfway through the shop, all competing for the same\nmachines. This page is about that bird's-eye view: how Carbon turns customer demand into a\nplan, tells you what to make and what to buy, schedules the work across your\nmachines, and shows you — at a glance — whether everything is on track."},"1560":{"id":"/manual/manufacturing/managing-production-8","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production","content":"Acme runs 89 jobs through 19 work centers and 16 processes, so we'll use its real\nshop to show how it all hangs together."},"1561":{"id":"/manual/manufacturing/managing-production-9","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production","content":"type: info"},"1562":{"id":"/manual/manufacturing/managing-production-10","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production","content":"Where this fits. A sales order creates demand, and a\njob is how you satisfy it. This page sits between the two:\nit's the planning and oversight layer that decides which jobs to run, when, and\non which machine — then watches them finish. Once a job hits the floor, operators run\nit in the shop floor app."},"1563":{"id":"/manual/manufacturing/managing-production-11","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"Every manufacturing system has to answer one question over and over: given everything\ncustomers have ordered, what do we need to do today? Carbon answers it by comparing\ndemand against supply."},"1564":{"id":"/manual/manufacturing/managing-production-12","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"Demand is everything that needs material or capacity: open sales orders, the materials\njobs will consume, safety-stock targets."},"1565":{"id":"/manual/manufacturing/managing-production-13","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"Supply is everything that will satisfy demand: stock on hand, open purchase orders\nalready on their way, and jobs already in progress."},"1566":{"id":"/manual/manufacturing/managing-production-14","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"Where demand outruns supply, Carbon raises a suggestion.\nFor a part you buy, that's a suggestion to raise a purchase\norder. For a part you make, it's a suggestion to\ncreate a job. This demand-vs-supply engine is what most ERP\nsystems call MRP (Material Requirements Planning) — you don't have to call it that, but\nit's the idea behind the planning screen."},"1567":{"id":"/manual/manufacturing/managing-production-15","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"Walk the Counterweight Hook through it. The order SO000069\nneeds 500 hooks, each hook needs 40 LB of A36 steel plate, so the demand is 20,000 LB\nof steel. Acme doesn't keep that much on the shelf — so Carbon sees the shortage and suggests\nbuying it. That suggestion became purchase order\nPO000057 to Ryerson. Meanwhile, because the hook is a\nMake part, the order itself became make-suggestion → job J000097. One screen, two\nkinds of action."},"1568":{"id":"/manual/manufacturing/managing-production-16","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"type: tip"},"1569":{"id":"/manual/manufacturing/managing-production-17","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-big-picture-demand-in-plan-out","content":"Make vs Buy is a setting on every item — its\nreplenishmentSystem. The Counterweight Hook is Make; its A36 steel plate is Buy.\nThat one flag is what decides whether a shortage turns into a job or a purchase order.\nSee Replenishment for how to set it."},"1570":{"id":"/manual/manufacturing/managing-production-18","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-planning-view","content":"Open Production → Planning to see demand and supply side by side, one row per item that\nneeds attention. Each row shows what's required, what's available, the resulting shortage,\nand the action Carbon suggests. You review the suggestions, adjust quantities or dates if you\nneed to, and then turn the ones you accept into real jobs and purchase orders."},"1571":{"id":"/manual/manufacturing/managing-production-19","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-planning-view","content":"Set your planning horizon. At the top of the screen, choose how far ahead to look — a\ncommon starting point is the next few weeks. Carbon only raises suggestions for demand that\nfalls inside the horizon, so a longer horizon surfaces more (and earlier) suggestions."},"1572":{"id":"/manual/manufacturing/managing-production-20","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-planning-view","content":"Read each row. Demand is everything pulling on the item; Supply is everything already\ncovering it. When Short is greater than zero, Carbon proposes an action in the\nSuggestion column. For the A36 steel plate, demand of 20,000 LB with nothing on hand\nproduces a Buy → PO suggestion."},"1573":{"id":"/manual/manufacturing/managing-production-21","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-planning-view","content":"Adjust before you commit. You can change a suggested quantity (for example, round a steel\nbuy up to a full sheet) or pull a date earlier. Acme's PO000057 ended up at 54,001 LB —\nmore than the 20,000 LB this one job needed — because the buyer rounded up to cover the next\ntwo Radiant orders too."},"1574":{"id":"/manual/manufacturing/managing-production-22","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-planning-view","content":"Convert the ones you accept. Select the suggestions you're happy with and convert them:\nBuy suggestions become draft purchase orders, Make\nsuggestions become jobs. Carbon links the new record back to the\ndemand that created it, so the trail stays intact."},"1575":{"id":"/manual/manufacturing/managing-production-23","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-planning-view","content":"type: warn"},"1576":{"id":"/manual/manufacturing/managing-production-24","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#the-planning-view","content":"A suggestion is a proposal, never an automatic action. Carbon will not raise a PO or\nrelease a job on its own — you always review and confirm. That's deliberate: planning\nshould inform your decisions, not make them for you."},"1577":{"id":"/manual/manufacturing/managing-production-25","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Once jobs exist, the next question is when does each one run, and on which machine? In\nCarbon, every operation in a job's routing points at a\nwork center — a specific machine or station that performs a\nprocess. Acme's shop has 19 of them; here are the ones the\nCounterweight Hook touches, plus a few others to show the range."},"1578":{"id":"/manual/manufacturing/managing-production-26","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Why this matters for scheduling: each operation carries a time (Flame Cut is 45 min per\npiece, Sandblasting 2 min, Inspection 10 min), and operations run After Previous — step 20\ncan't start until step 10 finishes. Multiply the per-piece time by the job quantity and Carbon\nknows how long each operation occupies its work center. Lay those out across the calendar and\nyou have a schedule."},"1579":{"id":"/manual/manufacturing/managing-production-27","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Find the bottleneck. Some work centers are in higher demand than others. Acme has three\nBurn Tables (PA1, PA2, TX1) for Flame Cut but only one Sand Blasting Room — so sandblasting is\nthe constraint everything flame-cut has to squeeze through. The schedule view shows each work\ncenter's load so you can spot where work is piling up."},"1580":{"id":"/manual/manufacturing/managing-production-28","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Balance the load. When a process has more than one work center, you can move an operation\nto a less-busy machine. Flame Cut work, for instance, can run on Burn Table PA1, PA2 or the\nTexas table — so a backlog at PA2 can shift to PA1 without changing the method."},"1581":{"id":"/manual/manufacturing/managing-production-29","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Respect the sequence. Because operations are After Previous, scheduling step 20 earlier\ndoes nothing if step 10 hasn't finished. Carbon keeps operations in order automatically; your\njob is to decide where the whole chain fits relative to other jobs."},"1582":{"id":"/manual/manufacturing/managing-production-30","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Watch the location. Work centers belong to a location\n— Acme's Headquarters or Texas. A job at Headquarters schedules onto Headquarters work centers.\nJ000097 ran entirely at Headquarters (loc_CZUGEFrKS1CCvUruMgY9CA)."},"1583":{"id":"/manual/manufacturing/managing-production-31","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"type: tip"},"1584":{"id":"/manual/manufacturing/managing-production-32","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#scheduling-jobs-across-work-centers","content":"Work-center rates aren't just for scheduling — they're how Carbon costs your jobs. Every\nminute booked against Burn Table PA2 absorbs labor at $50/hr and machine time at $25/hr.\nThat's why J000097's tiny per-piece cost rolled up from recorded shop time, not a guess.\nMore on costing in Accounting overview."},"1585":{"id":"/manual/manufacturing/managing-production-33","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#prioritizing-what-runs-first","content":"When more work wants a machine than the machine can handle, something has to go first. Carbon\ngives every job a priority (a number — lower means more urgent) and a due date with a\ndeadline type: a Hard Deadline can't slip, a Soft Deadline has some give. Together with\nstatus, these tell you — and the scheduler — what to push to the front."},"1586":{"id":"/manual/manufacturing/managing-production-34","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#prioritizing-what-runs-first","content":"Here's Acme's live Counterweight Hook backlog. Three jobs for the same part, the same customer,\nstacked up:"},"1587":{"id":"/manual/manufacturing/managing-production-35","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#prioritizing-what-runs-first","content":"Read that as a plan: J000097 finished first (earliest due date), J000098 is running now, and\nJ000099 is staged and Ready to release once capacity frees up. Because all three flow through\nthe single Sand Blasting Room, sequencing them by due date keeps that bottleneck from becoming\na missed deadline."},"1588":{"id":"/manual/manufacturing/managing-production-36","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#prioritizing-what-runs-first","content":"type: warn"},"1589":{"id":"/manual/manufacturing/managing-production-37","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#prioritizing-what-runs-first","content":"A job has to be released before the shop floor can touch it. The statuses you'll see\nwalk in order: Draft → Planned → Ready → In Progress → Completed. Ready means\n\"everything's lined up, release it when you want it to start\" — J000099 above is sitting at\nReady. Releasing is covered on the Jobs page."},"1590":{"id":"/manual/manufacturing/managing-production-38","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"The payoff of all this planning is a single place to answer \"how are we doing?\" The jobs list\nis your production dashboard: filter by status, location or due date, and read completion at a\nglance. The numbers update themselves as operators record finished pieces in the\nshop floor app — you never type a percentage by hand."},"1591":{"id":"/manual/manufacturing/managing-production-39","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"A few things to read off this screen:"},"1592":{"id":"/manual/manufacturing/managing-production-40","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Completion is real, not estimated. J000097 shows 500 of 500 because operators clocked\noff all 500 pieces. The In Progress jobs show a partial count that climbs on its own as the\nfloor reports finished pieces — you never type a number in by hand."},"1593":{"id":"/manual/manufacturing/managing-production-41","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Status tells you where to look. In Progress jobs are on the floor right now —\nJ000095 and J000098 are where today's attention goes. Planned and Ready jobs aren't\nconsuming capacity yet."},"1594":{"id":"/manual/manufacturing/managing-production-42","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Due dates flag risk. J000095 is due 2026-04-23 — already in the past — while it's\nstill In Progress. A row whose due date has slipped behind today is your cue to investigate\nbefore it turns into a missed commitment."},"1595":{"id":"/manual/manufacturing/managing-production-43","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"A quick KPI strip at the top of the dashboard summarizes the same picture as headline numbers:"},"1596":{"id":"/manual/manufacturing/managing-production-44","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Filter to what matters. Narrow the list to In Progress at Headquarters to see only\nthe work happening in front of you right now. Save the filter and it becomes your daily view."},"1597":{"id":"/manual/manufacturing/managing-production-45","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Drill into a job. Click any row to open the job. Its\nOperations tab shows which step is live and which work center it's on; the Materials\ntab shows whether the parts it needs are on hand."},"1598":{"id":"/manual/manufacturing/managing-production-46","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Trace a shortage back. If a job is stalled waiting on material, follow the link to the\npurchase order covering it — for J000097 that's PO000057\nto Ryerson — and check its expected receipt date."},"1599":{"id":"/manual/manufacturing/managing-production-47","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"Re-plan when things change. New orders arrive, dates move, a job scraps a batch. Re-run\nthe planning screen and Carbon recomputes demand vs supply against the latest reality,\nsurfacing any new shortages as fresh suggestions."},"1600":{"id":"/manual/manufacturing/managing-production-48","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"type: info"},"1601":{"id":"/manual/manufacturing/managing-production-49","page_id":"/manual/manufacturing/managing-production","tags":[],"type":"text","url":"/manual/manufacturing/managing-production#tracking-progress-across-the-shop","content":"The loop, in one sentence. Demand creates suggestions, you turn suggestions into jobs\nand purchase orders, you schedule those jobs across work centers, operators run them, and\nthe dashboard reflects progress in real time — then new demand restarts the loop. Planning\nisn't a one-time setup; it's the rhythm of running the shop."},"1602":{"id":"/manual/manufacturing/shop-floor","page_id":"/manual/manufacturing/shop-floor","type":"page","content":"The shop floor (MES)","tags":[],"url":"/manual/manufacturing/shop-floor"},"1603":{"id":"/manual/manufacturing/shop-floor-0","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor","content":"How operators run jobs: clock in, record quantities and complete operations."},"1604":{"id":"/manual/manufacturing/shop-floor-1","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"The MES is its own app"},"1605":{"id":"/manual/manufacturing/shop-floor-2","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#what-an-operator-sees","content":"What an operator sees"},"1606":{"id":"/manual/manufacturing/shop-floor-3","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#run-an-operation-start-to-finish","content":"Run an operation, start to finish"},"1607":{"id":"/manual/manufacturing/shop-floor-4","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#open-the-operation","content":"Open the operation"},"1608":{"id":"/manual/manufacturing/shop-floor-5","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#read-the-standard-procedure","content":"Read the standard procedure"},"1609":{"id":"/manual/manufacturing/shop-floor-6","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#clock-on","content":"Clock ON"},"1610":{"id":"/manual/manufacturing/shop-floor-7","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"Record good and scrap quantities"},"1611":{"id":"/manual/manufacturing/shop-floor-8","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#clock-off-and-complete-the-operation","content":"Clock OFF and complete the operation"},"1612":{"id":"/manual/manufacturing/shop-floor-9","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#what-clocking-off-feeds-back","content":"What clocking off feeds back"},"1613":{"id":"/manual/manufacturing/shop-floor-10","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#finishing-the-last-operation-finishes-the-job","content":"Finishing the last operation finishes the job"},"1614":{"id":"/manual/manufacturing/shop-floor-11","page_id":"/manual/manufacturing/shop-floor","type":"heading","tags":[],"url":"/manual/manufacturing/shop-floor#next-steps","content":"Next steps"},"1615":{"id":"/manual/manufacturing/shop-floor-12","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor","content":"So far the manual has planned the work — quoting it, ordering it, releasing a job.\nThis page is where the work actually gets done. It covers Carbon's MES — the\nManufacturing Execution System — the part of Carbon a machine operator opens at a station\non the shop floor. The MES turns a planned job into real activity: an operator picks an\noperation, clocks on, follows the written instructions, records how many good and scrap\npieces they made, and clocks off. Every one of those taps feeds real labor time and cost\nback to the job — no clipboards, no end-of-day data entry."},"1616":{"id":"/manual/manufacturing/shop-floor-13","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor","content":"type: info"},"1617":{"id":"/manual/manufacturing/shop-floor-14","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor","content":"Where this fits. A job is planned by a scheduler and\nrun by operators. Managing production is the\nmanager's view — releasing and tracking jobs. This page is the operator's view: the MES\nis the screen on the floor where the hours actually get logged. The last operation here is\nusually a quality gate, which leads into tracking quality."},"1618":{"id":"/manual/manufacturing/shop-floor-15","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"Carbon ships as two front ends that share one database:"},"1619":{"id":"/manual/manufacturing/shop-floor-16","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"The ERP — the full office app you've seen on every other page (Sales, Purchasing,\nItems, Production). This is where jobs are planned, scheduled and costed."},"1620":{"id":"/manual/manufacturing/shop-floor-17","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"The MES — a stripped-down, touch-friendly app built for a shop-floor tablet or kiosk.\nIt shows an operator only what they need: the operations waiting at their\nwork center, the instructions for each, and big buttons to\nstart, pause and finish."},"1621":{"id":"/manual/manufacturing/shop-floor-18","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"Both look at the same job. When an operator finishes an operation in the MES, a manager sees\nit update in the ERP a moment later. You don't enter anything twice."},"1622":{"id":"/manual/manufacturing/shop-floor-19","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"type: tip"},"1623":{"id":"/manual/manufacturing/shop-floor-20","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"Operators reach the MES at its own address (think mes.carbon.ms) and sign in with their\nown account. A worker who only runs machines never needs to learn the full ERP — they live\nentirely in this one focused screen. Permissions are covered in\nUsers & permissions."},"1624":{"id":"/manual/manufacturing/shop-floor-21","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#the-mes-is-its-own-app","content":"We'll follow the same real job as the rest of the manual: J000097, the batch of 500\nCounterweight Hooks (CWH-A36-15) for Radiant Aerospace. It runs three operations in\norder — Flame Cut, Sandblasting, then Inspection — and Carbon recorded the whole thing\nfinishing in about 282 seconds of logged shop time."},"1625":{"id":"/manual/manufacturing/shop-floor-22","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-an-operator-sees","content":"When an operator signs in, the MES doesn't show them the whole factory. It shows the\noperations queued at the work center(s) they're assigned to, newest deadlines first. Each\nrow is one operation on one job. Operator Fred Flame works the burn tables, so his queue is led\nby the Flame Cut on J000097."},"1626":{"id":"/manual/manufacturing/shop-floor-23","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-an-operator-sees","content":"A couple of things to notice:"},"1627":{"id":"/manual/manufacturing/shop-floor-24","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-an-operator-sees","content":"The MES filters by work center, not by job. Fred sees Flame Cut work from several\ndifferent jobs together, because they all run on his Burn Table. A different operator at the\nSand Blasting Room (here, Carlos Axis) sees a completely different list."},"1628":{"id":"/manual/manufacturing/shop-floor-25","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-an-operator-sees","content":"An operation only becomes Ready once the operation before it is done (the routing on\nJ000097 says each step runs After Previous). Sandblasting won't show as Ready in the\nblast-room queue until Flame Cut is finished. This is why the same job's three operations\nlight up one at a time, in sequence."},"1629":{"id":"/manual/manufacturing/shop-floor-26","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-an-operator-sees","content":"type: info"},"1630":{"id":"/manual/manufacturing/shop-floor-27","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-an-operator-sees","content":"Carbon defines an operation as one step in a job's\nrouting, performed at one work center. J000097 has three: Flame Cut at Burn Table -\nPA2, Sandblasting at the Sand Blasting Room, and Inspection at the Inspection\nStation. Each has a planned time per piece, which is what Carbon expects the operation to\ntake."},"1631":{"id":"/manual/manufacturing/shop-floor-28","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#run-an-operation-start-to-finish","content":"Here's the full loop an operator does for one operation. Fred will run the Flame Cut on\nJ000097: 500 hooks, 45 minutes planned per piece, on Burn Table - PA2."},"1632":{"id":"/manual/manufacturing/shop-floor-29","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#open-the-operation","content":"Tap the Flame Cut row for J000097. The MES opens an operation card — everything for\nthis one step on one screen. It tells the operator what to make, how many, from what, and how."},"1633":{"id":"/manual/manufacturing/shop-floor-30","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#open-the-operation","content":"The Materials tab shows what to pull and from where — for this part, 40 LB of\nA36 Steel Plate 1″ per piece, drawn from bin R02-B01-01. The Tools tab lists any\ntooling or fixtures the step needs. Because the steel is batch-tracked, the operator will be\nasked which batch they consumed — that's what makes full\ntraceability possible later."},"1634":{"id":"/manual/manufacturing/shop-floor-31","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#read-the-standard-procedure","content":"Most operations have a procedure attached — Carbon's name for a standard work instruction.\nAcme keeps 12 procedures, one for each kind of process, so the same job done by two\ndifferent operators is done the same way. The procedure for a Flame Cut / CNC-style operation\nwalks through setup and run as a checklist the operator ticks off:"},"1635":{"id":"/manual/manufacturing/shop-floor-32","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#read-the-standard-procedure","content":"Steps aren't only checkboxes. A procedure step can also ask the operator to type a\nmeasurement (with an allowed minimum and maximum, so an out-of-range value is caught on the\nspot), pick from a list, or attach a photo or file. That's how a written instruction\nbecomes recorded, checkable data instead of a laminated sheet on the wall."},"1636":{"id":"/manual/manufacturing/shop-floor-33","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#read-the-standard-procedure","content":"type: tip"},"1637":{"id":"/manual/manufacturing/shop-floor-34","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#read-the-standard-procedure","content":"Procedures are versioned. Acme's Quality Inspection procedure, for example, has an\nActive version 1 and a newer Draft version 2 — operators always run the Active version, and\nmanagers can revise the draft without disrupting the floor. Build and manage them from the\nERP's Production module."},"1638":{"id":"/manual/manufacturing/shop-floor-35","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#clock-on","content":"When the operator is ready to cut, they tap Start. This is the moment that matters: it\nclocks them ON to the operation and Carbon starts a timer. From here, every minute counts\nagainst this job — at Burn Table - PA2's labor rate of $50/hour, that time is becoming real\ncost on J000097 as the operator works."},"1639":{"id":"/manual/manufacturing/shop-floor-36","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#clock-on","content":"If the operator stops for a break or to switch tasks, they tap Pause — the timer stops, so\nbreaks don't get billed to the job. They can clock off one operation and onto another at any\ntime; Carbon keeps each operation's time separate."},"1640":{"id":"/manual/manufacturing/shop-floor-37","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#clock-on","content":"type: warn"},"1641":{"id":"/manual/manufacturing/shop-floor-38","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#clock-on","content":"An operator can only be clocked on to one operation at a time. If Fred forgets to clock\noff Flame Cut before lunch, his time keeps running against J000097. Encourage the habit:\nPause when you step away, Finish when the step is done. A manager can correct a\nbad time entry later from the ERP, but it's far cleaner to get it right on the floor."},"1642":{"id":"/manual/manufacturing/shop-floor-39","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"As pieces come off the table, the operator reports them. Carbon tracks two numbers:"},"1643":{"id":"/manual/manufacturing/shop-floor-40","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"Good quantity — pieces that passed and move on to the next operation."},"1644":{"id":"/manual/manufacturing/shop-floor-41","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"Scrap quantity — pieces that failed and won't continue. Each scrap is tagged with a\nreason so the shop can see why parts are being lost."},"1645":{"id":"/manual/manufacturing/shop-floor-42","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"Acme keeps three scrap reasons — Damaged, Defective, and Quality — and the\noperator picks one whenever they scrap a piece."},"1646":{"id":"/manual/manufacturing/shop-floor-43","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"On J000097 every hook was good — 500 made, 0 scrapped — so the job's scrapQuantity stayed\nat zero. When scrap does happen, those reasons roll up into reports so a manager can spot, say,\na run of Defective parts at one work center and dig into the cause."},"1647":{"id":"/manual/manufacturing/shop-floor-44","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"type: info"},"1648":{"id":"/manual/manufacturing/shop-floor-45","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#record-good-and-scrap-quantities","content":"Scrapping a piece does more than count it. It can also feed the\nquality side of Carbon — repeated failures of the same\nkind are exactly what a non-conformance (NCR) is for. Scrap reasons and failure modes are\nthe raw material for quality analysis."},"1649":{"id":"/manual/manufacturing/shop-floor-46","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#clock-off-and-complete-the-operation","content":"When the count is in and the work is finished, the operator taps Finish. This clocks them\noff, stops the timer, and marks the operation Done. The finished good quantity is now\navailable to the next operation — so the moment Fred finishes Flame Cut, Sandblasting flips\nto Ready in the blast-room queue."},"1650":{"id":"/manual/manufacturing/shop-floor-47","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#clock-off-and-complete-the-operation","content":"The other two operators do the same thing in turn. Carlos Axis runs the Sandblasting operation\n(2 min/piece) at the Sand Blasting Room and clocks off; then Terry Tolerance, the inspector at\nthe Inspection Station, runs the Quality Inspection procedure (10 min/piece) and clocks off\nthe last operation."},"1651":{"id":"/manual/manufacturing/shop-floor-48","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-clocking-off-feeds-back","content":"Each clock-on/clock-off pair is a production event — a timestamped record of who worked\nwhich operation, for how long, and how many good and scrap pieces resulted. These events\nare the heart of the MES. They do three jobs at once:"},"1652":{"id":"/manual/manufacturing/shop-floor-49","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-clocking-off-feeds-back","content":"They cost the job. Recorded minutes are multiplied by the work center's labor and\nmachine rates (Burn Table - PA2 bills $50/hr labor + $25/hr machine) and posted to the\njob as actual cost. That's how Carbon compares what a job was estimated to cost against\nwhat it really cost — and the gap shows up as a variance you can act on."},"1653":{"id":"/manual/manufacturing/shop-floor-50","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-clocking-off-feeds-back","content":"They advance the work. Reported good quantity flows to the next operation; the routing's\nAfter Previous rule means the floor naturally runs steps in order."},"1654":{"id":"/manual/manufacturing/shop-floor-51","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#what-clocking-off-feeds-back","content":"They build the record. Who ran each step and when is stored for good — useful for\ntraceability, payroll, and answering \"what happened on\nthis job?\" months later."},"1655":{"id":"/manual/manufacturing/shop-floor-52","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#finishing-the-last-operation-finishes-the-job","content":"The operations run in sequence, and the last one is special. When the inspector clocks off\nthe final Inspection operation on J000097, there's nothing left to do — all three\noperations are Done and all 500 pieces are made. Carbon rolls the job up: the finished hooks are\nreceived into inventory, the job's actual cost is locked in from the production events, and the\njob moves to Completed."},"1656":{"id":"/manual/manufacturing/shop-floor-53","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#finishing-the-last-operation-finishes-the-job","content":"This is the hand-off back to the office: a Completed job means the parts exist, ready to be\npicked and shipped against sales order SO000069 and billed\non invoice AR000025. The shop floor did its part, and every\nminute it spent is now visible to the rest of Carbon."},"1657":{"id":"/manual/manufacturing/shop-floor-54","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#finishing-the-last-operation-finishes-the-job","content":"type: tip"},"1658":{"id":"/manual/manufacturing/shop-floor-55","page_id":"/manual/manufacturing/shop-floor","tags":[],"type":"text","url":"/manual/manufacturing/shop-floor#finishing-the-last-operation-finishes-the-job","content":"Why clock time at all? Because guessed labor is the most common reason a shop loses money\nwithout knowing it. When operators clock real time on the MES, every quote you build next\nrests on what work actually takes — not a hopeful estimate. The MES is where Carbon's costing\ngets honest."},"1659":{"id":"/manual/overview/core-concepts","page_id":"/manual/overview/core-concepts","type":"page","content":"Core concepts","tags":[],"url":"/manual/overview/core-concepts"},"1660":{"id":"/manual/overview/core-concepts-0","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts","content":"The handful of ideas that make everything else click: items, methods, jobs, orders and traceability."},"1661":{"id":"/manual/overview/core-concepts-1","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#the-big-picture","content":"The big picture"},"1662":{"id":"/manual/overview/core-concepts-2","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#1-the-item","content":"1. The Item"},"1663":{"id":"/manual/overview/core-concepts-3","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#the-six-item-types","content":"The six item types"},"1664":{"id":"/manual/overview/core-concepts-4","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#unit-of-measure-and-tracking","content":"Unit of measure and tracking"},"1665":{"id":"/manual/overview/core-concepts-5","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"2. The Method — BOM + Routing"},"1666":{"id":"/manual/overview/core-concepts-6","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"3. Make vs Buy (replenishment)"},"1667":{"id":"/manual/overview/core-concepts-7","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#4-demand--quote-and-sales-order","content":"4. Demand — Quote and Sales Order"},"1668":{"id":"/manual/overview/core-concepts-8","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#5-the-job--a-production-order","content":"5. The Job — a production order"},"1669":{"id":"/manual/overview/core-concepts-9","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#6-supply--the-purchase-order","content":"6. Supply — the Purchase Order"},"1670":{"id":"/manual/overview/core-concepts-10","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#7-location-and-shelf--where-stock-lives","content":"7. Location and Shelf — where stock lives"},"1671":{"id":"/manual/overview/core-concepts-11","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#8-traceability--the-genealogy","content":"8. Traceability — the genealogy"},"1672":{"id":"/manual/overview/core-concepts-12","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#how-it-all-connects","content":"How it all connects"},"1673":{"id":"/manual/overview/core-concepts-13","page_id":"/manual/overview/core-concepts","type":"heading","tags":[],"url":"/manual/overview/core-concepts#next-steps","content":"Next steps"},"1674":{"id":"/manual/overview/core-concepts-14","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts","content":"Carbon has a lot of screens, but it's built on a small set of ideas. Learn these eight and\nthe rest of the manual is just detail. This page defines each one in plain language and shows\nit on the same real example you met in the walkthrough — a\nCounterweight Hook that Acme makes for Radiant Aerospace. Read it once, top to\nbottom, and the vocabulary you'll see everywhere else in Carbon will already make sense."},"1675":{"id":"/manual/overview/core-concepts-15","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts","content":"type: info"},"1676":{"id":"/manual/overview/core-concepts-16","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts","content":"Before you start. This is the mental-model page. You don't need to do anything in the\napp yet — just read along. If you'd rather see the whole flow in motion first, the\n15-minute walkthrough follows one order from quote to cash. Either\norder works; this page goes a level deeper on the why."},"1677":{"id":"/manual/overview/core-concepts-17","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#the-big-picture","content":"Almost everything in Carbon is a record — an item, a quote, a job, a purchase order — and\nthe records link to each other. You enter information once, and it follows the work\neverywhere it goes. Here's how the main records connect for our hook:"},"1678":{"id":"/manual/overview/core-concepts-18","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#the-big-picture","content":"The rest of this page walks each box. Don't worry about memorizing the diagram — by the end\nit'll feel obvious."},"1679":{"id":"/manual/overview/core-concepts-19","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#1-the-item","content":"An item is anything you make, buy, store, or sell. It's the\nnoun the whole system is built around. Every part on a quote, every material on a purchase\norder, every line on an invoice points back to an item."},"1680":{"id":"/manual/overview/core-concepts-20","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#1-the-item","content":"Our hero is the item CWH-A36-15, the Counterweight Hook. Two settings on it matter most:"},"1681":{"id":"/manual/overview/core-concepts-21","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#1-the-item","content":"Item type — what kind of thing it is (see the six types below)."},"1682":{"id":"/manual/overview/core-concepts-22","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#1-the-item","content":"Replenishment — how you get it: you either make it or buy it (covered in\nsection 3)."},"1683":{"id":"/manual/overview/core-concepts-23","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#the-six-item-types","content":"Every item is exactly one of these types. The type tells Carbon how the item behaves — what\nscreens it shows, whether it can have a recipe, and where it shows up."},"1684":{"id":"/manual/overview/core-concepts-24","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#the-six-item-types","content":"type: tip"},"1685":{"id":"/manual/overview/core-concepts-25","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#the-six-item-types","content":"Don't overthink the type at first. The two you'll use most are Part (the things you\nsell) and Material (the raw stock you cut them from). Full detail on every field lives\nin Defining an item."},"1686":{"id":"/manual/overview/core-concepts-26","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#unit-of-measure-and-tracking","content":"Two more item settings show up constantly:"},"1687":{"id":"/manual/overview/core-concepts-27","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#unit-of-measure-and-tracking","content":"Unit of measure (UoM) — how you count it. The hook is counted in EA (Each); its steel\nis measured in LB (pounds). Carbon converts between a purchase UoM and a stock UoM when\nthey differ."},"1688":{"id":"/manual/overview/core-concepts-28","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#unit-of-measure-and-tracking","content":"Tracking type — whether Carbon keeps a stock balance for it. The hook is Inventory\ntracked (Carbon counts how many are on hand). Some items are Non-Inventory (bought\nstraight to a job and never counted on a shelf)."},"1689":{"id":"/manual/overview/core-concepts-29","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"A method is the recipe for a made item. It has two halves,\nand you'll hear both terms constantly:"},"1690":{"id":"/manual/overview/core-concepts-30","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"type: info"},"1691":{"id":"/manual/overview/core-concepts-31","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"Bill of Materials (BOM) — what the item is made of. The list of materials and\nsub-parts that go into one unit, with quantities. The hook's BOM is one line: 40 lb of A36\nsteel plate."},"1692":{"id":"/manual/overview/core-concepts-32","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"type: info"},"1693":{"id":"/manual/overview/core-concepts-33","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"Routing — how the item is made. The ordered list of operations\n(shop steps), each run at a work center. The hook's routing is\nthree operations: Flame Cut, then Sandblasting, then Inspection."},"1694":{"id":"/manual/overview/core-concepts-34","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"Carbon shows the BOM and routing together as a single method tree — materials and\noperations nested under the item they build. Here's the hook's method:"},"1695":{"id":"/manual/overview/core-concepts-35","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"Two things to notice, because they explain a lot of Carbon's \"magic\":"},"1696":{"id":"/manual/overview/core-concepts-36","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"The method drives cost and price. Carbon adds up the material (40 lb of steel) and the\nshop time (45 + 2 + 10 minutes per piece, at each work center's labor and machine rates) to\nestimate what one hook costs to make. That estimate is what you price a quote against."},"1697":{"id":"/manual/overview/core-concepts-37","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"The method drives the plan. When you make this part, Carbon copies the method onto the\njob — so the shop knows exactly what to consume and which steps to run, in order."},"1698":{"id":"/manual/overview/core-concepts-38","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"type: tip"},"1699":{"id":"/manual/overview/core-concepts-39","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#2-the-method--bom--routing","content":"A method can nest. If a part is built from sub-assemblies that you also make, each one\nbrings its own BOM and routing, and the tree grows another level deep. The hook is simple —\none material, three steps — but the same structure scales to complex assemblies. See\nMethods: BOM & routing."},"1700":{"id":"/manual/overview/core-concepts-40","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"Replenishment answers one question for every item: when you\nneed this, how do you get more? There are exactly two answers, and they decide which part of\nCarbon does the work."},"1701":{"id":"/manual/overview/core-concepts-41","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"This is why our two items behave differently:"},"1702":{"id":"/manual/overview/core-concepts-42","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"The hook CWH-A36-15 is Make — so demand for it produces a job (section 5)."},"1703":{"id":"/manual/overview/core-concepts-43","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"Its steel A36-STEEL-PLT-1\".96x240 is Buy — so demand for it produces a\npurchase order (section 7)."},"1704":{"id":"/manual/overview/core-concepts-44","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"A single order can pull both levers at once: making the hook creates demand for the steel,\nwhich Carbon then suggests buying. You'll see that chain play out below."},"1705":{"id":"/manual/overview/core-concepts-45","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"type: tip"},"1706":{"id":"/manual/overview/core-concepts-46","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#3-make-vs-buy-replenishment","content":"Replenishment isn't only Make-vs-Buy — it also governs when and how much to reorder\n(reorder points, lead time, lot sizing). Those settings live in\nReplenishment & planning."},"1707":{"id":"/manual/overview/core-concepts-47","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#4-demand--quote-and-sales-order","content":"Everything Acme makes or buys starts with demand: someone wants something. On the sell\nside, demand comes in two records that link together."},"1708":{"id":"/manual/overview/core-concepts-48","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#4-demand--quote-and-sales-order","content":"type: info"},"1709":{"id":"/manual/overview/core-concepts-49","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#4-demand--quote-and-sales-order","content":"Quote — a priced offer, before the customer commits. You add lines (item, quantity,\nprice) and send it. Carbon's configurators can even price\nmade-to-order parts from the customer's choices. Our hook was quoted as Q000061."},"1710":{"id":"/manual/overview/core-concepts-50","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#4-demand--quote-and-sales-order","content":"type: info"},"1711":{"id":"/manual/overview/core-concepts-51","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#4-demand--quote-and-sales-order","content":"Sales Order (SO) — the customer's commitment. It records who's buying, what, how\nmany, when it's due, and at what price. When a quote is accepted you convert it to a sales\norder in one click — no re-typing. Our quote became SO000069."},"1712":{"id":"/manual/overview/core-concepts-52","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#4-demand--quote-and-sales-order","content":"The fulfillment method on the line — Make to Order — is the hinge between selling and\nmaking. Because the hook is a Make item, that setting tells Carbon the next step is a job,\nnot a pick from the shelf. Learn the sell side in Quoting and\nSales orders."},"1713":{"id":"/manual/overview/core-concepts-53","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#5-the-job--a-production-order","content":"A job is a production order: the instruction to actually\nmake a quantity of a part. When you release a job, Carbon copies the item's method onto it, so\nthe job carries its own snapshot of the BOM and routing. (That copy is why changing a\npart's master method later doesn't rewrite jobs already in progress.)"},"1714":{"id":"/manual/overview/core-concepts-54","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#5-the-job--a-production-order","content":"For our order, Carbon created job J000097 for 500 hooks. The operations are the routing from\nthe method; the shop floor reports against them."},"1715":{"id":"/manual/overview/core-concepts-55","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#5-the-job--a-production-order","content":"A job moves through statuses as it goes — Draft → Ready → In Progress → Completed (you'll\nalso see Planned for jobs scheduled but not yet released). The same hook runs on other jobs\ntoo: J000098 (1,500 EA, In Progress) and J000099 (3,000 EA, Ready) are queued for Radiant\nright behind this one. Full detail in Jobs; the operator side\nis the shop floor (MES)."},"1716":{"id":"/manual/overview/core-concepts-56","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#6-supply--the-purchase-order","content":"A job needs materials. The hook's BOM calls for 40 lb of A36 steel per piece — 20,000 lb\nfor the batch of 500 — and the steel is a Buy item. So Carbon raises supply with a\npurchase order."},"1717":{"id":"/manual/overview/core-concepts-57","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#6-supply--the-purchase-order","content":"type: info"},"1718":{"id":"/manual/overview/core-concepts-58","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#6-supply--the-purchase-order","content":"Purchase Order (PO) — your commitment to a supplier to buy specified items at agreed\nprices and dates. It's the buy-side mirror of a sales order. The steel for our hook was\nordered on PO000057 from Ryerson."},"1719":{"id":"/manual/overview/core-concepts-59","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#6-supply--the-purchase-order","content":"When the steel arrives, a receipt adds it to inventory. That single act does two things:\nit raises the on-hand balance, and — because A36 plate is batch-tracked — it records exactly\nwhich batch of steel came in. Hold that thought; it's the foundation of traceability in\nsection 8. Learn the buy side in Purchasing basics."},"1720":{"id":"/manual/overview/core-concepts-60","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#7-location-and-shelf--where-stock-lives","content":"Physical items have to be somewhere. Carbon answers \"where?\" at two levels of detail:"},"1721":{"id":"/manual/overview/core-concepts-61","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#7-location-and-shelf--where-stock-lives","content":"type: info"},"1722":{"id":"/manual/overview/core-concepts-62","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#7-location-and-shelf--where-stock-lives","content":"Location — a site or warehouse. Acme has two: Headquarters and Texas. Stock,\nwork centers, and orders all belong to a location. Everything in our hero thread happens at\nHeadquarters."},"1723":{"id":"/manual/overview/core-concepts-63","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#7-location-and-shelf--where-stock-lives","content":"type: info"},"1724":{"id":"/manual/overview/core-concepts-64","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#7-location-and-shelf--where-stock-lives","content":"Shelf (also called a bin or storage unit) — a specific spot inside a location: a rack,\nshelf, or bin. Acme's A36 steel lives on shelf R02-B01-01; finished hooks land on shelf\n8-1-H."},"1725":{"id":"/manual/overview/core-concepts-65","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#7-location-and-shelf--where-stock-lives","content":"Knowing the exact shelf is what lets the shop pick material fast and lets Carbon tell you not\njust how much you have but where it is. More in\nLocations & stock."},"1726":{"id":"/manual/overview/core-concepts-66","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#8-traceability--the-genealogy","content":"The last big idea ties the others together. Traceability (or\ngenealogy) is Carbon's ability to answer, after the fact: what exactly went into this? and\nwhere did this end up?"},"1727":{"id":"/manual/overview/core-concepts-67","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#8-traceability--the-genealogy","content":"It works because of two kinds of tracking you can turn on for an item:"},"1728":{"id":"/manual/overview/core-concepts-68","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#8-traceability--the-genealogy","content":"A36 steel plate is batch-tracked. So when Ryerson's steel was received against PO000057,\nCarbon stamped that incoming lot with a batch number. When job J000097 consumed the steel,\nCarbon linked that exact batch to those exact 500 hooks — and through the sales order and\nshipment, to Radiant Aerospace."},"1729":{"id":"/manual/overview/core-concepts-69","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#8-traceability--the-genealogy","content":"That unbroken chain is worth real money. If Ryerson later reports a defect in that heat of\nsteel, Acme can answer \"which finished parts are affected, and which customer got them?\" in\nseconds — instead of recalling everything. The same chain runs the other way too: from a\ncustomer complaint back to the raw material. Quality records like inspections and\nnon-conformances hang off this genealogy."},"1730":{"id":"/manual/overview/core-concepts-70","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#8-traceability--the-genealogy","content":"type: tip"},"1731":{"id":"/manual/overview/core-concepts-71","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#8-traceability--the-genealogy","content":"You don't have to track everything. Turn on batch or serial tracking only for items where it\nearns its keep — regulated, high-value, or warranty-sensitive parts. For everything else,\nplain inventory tracking is enough."},"1732":{"id":"/manual/overview/core-concepts-72","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#how-it-all-connects","content":"Here's the whole vocabulary on one screen, mapped to our hook. Every row is a record you can\nopen, and each one links to the next:"},"1733":{"id":"/manual/overview/core-concepts-73","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#how-it-all-connects","content":"type: info"},"1734":{"id":"/manual/overview/core-concepts-74","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#how-it-all-connects","content":"That linking is the entire point of a system of record: enter information once, and it\nfollows the work everywhere. Every Carbon page from here on is just a closer look at one of\nthese records."},"1735":{"id":"/manual/overview/core-concepts-75","page_id":"/manual/overview/core-concepts","tags":[],"type":"text","url":"/manual/overview/core-concepts#next-steps","content":"You now have the mental model. Pick where to go next:"},"1736":{"id":"/manual/overview/glossary","page_id":"/manual/overview/glossary","type":"page","content":"Glossary","tags":[],"url":"/manual/overview/glossary"},"1737":{"id":"/manual/overview/glossary-0","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary","content":"Plain-English definitions of every Carbon and manufacturing term in this manual."},"1738":{"id":"/manual/overview/glossary-1","page_id":"/manual/overview/glossary","type":"heading","tags":[],"url":"/manual/overview/glossary#the-three-letters-erp-mes-qms","content":"The three letters: ERP, MES, QMS"},"1739":{"id":"/manual/overview/glossary-2","page_id":"/manual/overview/glossary","type":"heading","tags":[],"url":"/manual/overview/glossary#the-full-az","content":"The full A–Z"},"1740":{"id":"/manual/overview/glossary-3","page_id":"/manual/overview/glossary","type":"heading","tags":[],"url":"/manual/overview/glossary#how-the-big-terms-connect","content":"How the big terms connect"},"1741":{"id":"/manual/overview/glossary-4","page_id":"/manual/overview/glossary","type":"heading","tags":[],"url":"/manual/overview/glossary#a-worked-example-term-by-term","content":"A worked example, term by term"},"1742":{"id":"/manual/overview/glossary-5","page_id":"/manual/overview/glossary","type":"heading","tags":[],"url":"/manual/overview/glossary#next-steps","content":"Next steps"},"1743":{"id":"/manual/overview/glossary-6","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary","content":"This page is your dictionary. Carbon (and manufacturing in general) uses a lot of words that\nsound technical but turn out to be simple once someone explains them in plain language. That's\nwhat this page does: one sentence per term, and wherever it helps, a real example from Acme\nInc. — the demo company you'll see throughout this manual."},"1744":{"id":"/manual/overview/glossary-7","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary","content":"You don't need to read this top to bottom. Skim it once to get a feel for the vocabulary, then\ncome back and look things up whenever a page uses a word you're not sure about. Most pages link\ntheir jargon straight here."},"1745":{"id":"/manual/overview/glossary-8","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary","content":"type: info"},"1746":{"id":"/manual/overview/glossary-9","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary","content":"Where this fits. This is a reference, not a tutorial. If you're brand new, start with\nWhat is Carbon? for the big picture, then watch one real\norder move through the whole system in Carbon in 15 minutes. The\nexample used in most definitions below — the Counterweight Hook CWH-A36-15 that Acme\nmakes for Radiant Aerospace — is that same walkthrough thread."},"1747":{"id":"/manual/overview/glossary-10","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#the-three-letters-erp-mes-qms","content":"Carbon is described as \"an ERP + MES + QMS.\" Those three acronyms each cover one slice of running\na shop, and Carbon rolls all three into a single system that shares one set of data."},"1748":{"id":"/manual/overview/glossary-11","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#the-three-letters-erp-mes-qms","content":"Because they live in one system, finishing a shop-floor operation (MES) updates the job cost\n(ERP) and records which material went in (QMS) — all at once, with no re-typing."},"1749":{"id":"/manual/overview/glossary-12","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#the-full-az","content":"Every term used in the manual, alphabetical. Real Acme examples are woven in where they make a\ndefinition click."},"1750":{"id":"/manual/overview/glossary-13","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#how-the-big-terms-connect","content":"If a few of these still feel abstract, this is the chain they form in real life. Each box is a\nrecord in Carbon, and each one links to the next automatically — the same thread the\nwalkthrough follows end to end."},"1751":{"id":"/manual/overview/glossary-14","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#how-the-big-terms-connect","content":"type: tip"},"1752":{"id":"/manual/overview/glossary-15","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#how-the-big-terms-connect","content":"A quick way to remember the item types: Part and Material become the product (one is\nmade/sold, one is consumed into it), while Tool, Fixture and Consumable are what\nyou use to do the work. A Service is work itself rather than a thing."},"1753":{"id":"/manual/overview/glossary-16","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#a-worked-example-term-by-term","content":"Here's the hero order again, but this time as a glossary in motion — every record below is one of\nthe terms above, filled with real Acme data."},"1754":{"id":"/manual/overview/glossary-17","page_id":"/manual/overview/glossary","tags":[],"type":"text","url":"/manual/overview/glossary#a-worked-example-term-by-term","content":"Read that table top to bottom and you've just used a dozen glossary terms in one breath — which\nis exactly how Carbon strings them together for real."},"1755":{"id":"/manual/overview/navigating","page_id":"/manual/overview/navigating","type":"page","content":"Navigating Carbon","tags":[],"url":"/manual/overview/navigating"},"1756":{"id":"/manual/overview/navigating-0","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating","content":"A tour of the app: modules, layout, search and where to find things."},"1757":{"id":"/manual/overview/navigating-1","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#the-big-picture","content":"The big picture"},"1758":{"id":"/manual/overview/navigating-2","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#the-module-rail-area-by-area","content":"The module rail, area by area"},"1759":{"id":"/manual/overview/navigating-3","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#jump-anywhere-with-search-k","content":"Jump anywhere with search (⌘K)"},"1760":{"id":"/manual/overview/navigating-4","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#lists-vs-records-the-two-screens-youll-always-see","content":"Lists vs records: the two screens you'll always see"},"1761":{"id":"/manual/overview/navigating-5","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#the-list-view","content":"The list view"},"1762":{"id":"/manual/overview/navigating-6","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#the-record-view","content":"The record view"},"1763":{"id":"/manual/overview/navigating-7","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#reading-status-badges","content":"Reading status badges"},"1764":{"id":"/manual/overview/navigating-8","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#creating-a-new-record","content":"Creating a new record"},"1765":{"id":"/manual/overview/navigating-9","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#where-do-i-find","content":"\"Where do I find…?\""},"1766":{"id":"/manual/overview/navigating-10","page_id":"/manual/overview/navigating","type":"heading","tags":[],"url":"/manual/overview/navigating#next-steps","content":"Next steps"},"1767":{"id":"/manual/overview/navigating-11","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating","content":"The first time you open Carbon there's a lot on screen — a column of icons down the left,\na search box up top, and a big table in the middle. The good news: the whole app is built\nfrom a handful of repeating pieces. Learn those pieces once and every screen, from a\npurchase order to a quality inspection, suddenly feels familiar. This page is the guided\ntour: what's where, how to jump anywhere in two keystrokes, and how to read the two screens\nyou'll see most — the list and the record."},"1768":{"id":"/manual/overview/navigating-12","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating","content":"type: info"},"1769":{"id":"/manual/overview/navigating-13","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating","content":"Before you start. This page assumes you can sign in to Carbon (or you're following\nalong with the live demo). If you haven't yet, your administrator sets you up in\nUsers & permissions. New to the ideas\nbehind Carbon — items, jobs, orders? Read Core concepts\nalongside this page; here we focus only on driving the interface."},"1770":{"id":"/manual/overview/navigating-14","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-big-picture","content":"Every page in Carbon shares the same frame. A module rail runs down the left edge — that's\nhow you switch between big areas of the business like Sales, Purchasing or Production. Across\nthe top sits the search bar (your fastest way to jump anywhere) plus your account and\nnotifications. Everything else — the list, the record you opened, the form you're filling in —\nloads in the large content area in the middle."},"1771":{"id":"/manual/overview/navigating-15","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-big-picture","content":"Above, the Production module is selected (highlighted in the rail) and its Jobs list\nfills the content area. Click a different icon in the rail and the whole middle swaps to that\narea's lists. The frame never moves — only the content does."},"1772":{"id":"/manual/overview/navigating-16","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-module-rail-area-by-area","content":"Each icon in the left rail opens one part of Carbon. Here's what lives behind each one, so\nyou know where to head:"},"1773":{"id":"/manual/overview/navigating-17","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-module-rail-area-by-area","content":"type: tip"},"1774":{"id":"/manual/overview/navigating-18","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-module-rail-area-by-area","content":"You don't need every module from day one. Most people live in one or two — a buyer almost\nnever leaves Purchasing; a planner lives in Production. What you can see is also\ngoverned by your permissions, so your rail may\nbe shorter than the one above."},"1775":{"id":"/manual/overview/navigating-19","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#jump-anywhere-with-search-k","content":"The single most useful habit in Carbon is the command palette. Press ⌘K (on\nWindows, Ctrl+K) — or click the search bar at the top — and a search\nbox opens over whatever you're doing. Start typing and Carbon searches everything at once:\nrecords by number, parts by name, and the app's own navigation."},"1776":{"id":"/manual/overview/navigating-20","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#jump-anywhere-with-search-k","content":"Type a record number you already know — SO000069, J000097, Q000061 — and press\nEnter to land straight on it. Type a part name like Counterweight Hook and you'll\nget the item plus every order and job that touches it. You can also search for screens\nthemselves: typing Suppliers or Work Centers jumps you to that list without ever touching\nthe rail."},"1777":{"id":"/manual/overview/navigating-21","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#jump-anywhere-with-search-k","content":"type: tip"},"1778":{"id":"/manual/overview/navigating-22","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#jump-anywhere-with-search-k","content":"⌘K is faster than clicking once you trust it. Think of it the way you'd use a browser's\naddress bar: don't navigate to a thing — just name it."},"1779":{"id":"/manual/overview/navigating-23","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#lists-vs-records-the-two-screens-youll-always-see","content":"Almost everything you open in Carbon is one of two screens. Understanding the difference is\nmost of what \"knowing the app\" means."},"1780":{"id":"/manual/overview/navigating-24","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#lists-vs-records-the-two-screens-youll-always-see","content":"A list (also called a table or index) shows many records of one kind — every job,\nevery customer, every purchase order — one per row. You use it to find, filter and scan."},"1781":{"id":"/manual/overview/navigating-25","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#lists-vs-records-the-two-screens-youll-always-see","content":"A record (also called a detail view) shows one of those records in full, with all\nits fields, tabs and related documents. You use it to read or edit a single thing."},"1782":{"id":"/manual/overview/navigating-26","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#lists-vs-records-the-two-screens-youll-always-see","content":"You move between them constantly: open a list, click a row, and you're in that record. The\nflow below is the same everywhere in Carbon."},"1783":{"id":"/manual/overview/navigating-27","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-list-view","content":"A list is a table. Every row is one record; the columns are its most important fields. At the\ntop you'll find a search/filter bar to narrow the rows, and a New button to create one.\nStatus columns use color-coded badges so you can scan the health\nof dozens of records at a glance."},"1784":{"id":"/manual/overview/navigating-28","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-list-view","content":"A few things to know about every list in Carbon:"},"1785":{"id":"/manual/overview/navigating-29","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-list-view","content":"Click a row to open that record. The row number, like SO000069, is also a clickable\nlink."},"1786":{"id":"/manual/overview/navigating-30","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-list-view","content":"Search and filter at the top narrow the rows — by status, customer, date, and more."},"1787":{"id":"/manual/overview/navigating-31","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-list-view","content":"Sort by clicking a column header."},"1788":{"id":"/manual/overview/navigating-32","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-list-view","content":"Columns are yours to arrange. You can show, hide and reorder columns, and Carbon\nremembers your choice for that list."},"1789":{"id":"/manual/overview/navigating-33","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-record-view","content":"Click SO000069 and you land on its record. A record gathers everything about one thing:\nits key fields up top, a status badge showing where it stands, and a set of tabs that\ngroup related information — and related documents, like the lines on an order or the\nshipments against it."},"1790":{"id":"/manual/overview/navigating-34","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-record-view","content":"The tabs are the key to a record. On this sales order, Details holds the header you see\nabove; Lines holds the parts ordered; Shipments and Invoices hold the documents created\nfrom it. Different record types have different tabs — a Job has Operations and Materials,\na Part has Manufacturing and Costing — but the pattern is always the same: header on top,\nrelated detail in tabs."},"1791":{"id":"/manual/overview/navigating-35","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-record-view","content":"type: tip"},"1792":{"id":"/manual/overview/navigating-36","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#the-record-view","content":"Records are linked. From SO000069 you can hop straight to the job that makes it\n(J000097), the shipment that sent it, or the invoice that billed it (AR000025) — usually\nby clicking the linked number. This is the heart of how Carbon works: one continuous chain\nof records, each a click from the next. You can watch the whole chain unfold in the\n15-minute walkthrough."},"1793":{"id":"/manual/overview/navigating-37","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#reading-status-badges","content":"Carbon uses small colored status badges everywhere — in lists, on records, in search.\nThey're shorthand for \"where is this in its lifecycle?\" The colors are consistent across the\napp, so once you learn them you can read any screen at a glance:"},"1794":{"id":"/manual/overview/navigating-38","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#reading-status-badges","content":"type: info"},"1795":{"id":"/manual/overview/navigating-39","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#reading-status-badges","content":"Each record type has its own exact set of statuses — a purchase order moves through Draft →\nNeeds Approval → To Receive → To Invoice, for instance, while a quote moves Draft → Sent →\nAccepted. The colors stay consistent even when the words differ, so amber always means\n\"in motion\" and green always means \"good / done\"."},"1796":{"id":"/manual/overview/navigating-40","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"Wherever there's a list, there's a way to add to it. The pattern is always the same:"},"1797":{"id":"/manual/overview/navigating-41","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"Go to the right list. Pick the module in the left rail, then the list you want — for a\nnew order, Sales → Sales Orders. Or just press ⌘K and type the list name."},"1798":{"id":"/manual/overview/navigating-42","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"Click New (top-right of the list). Carbon opens a blank record — often as a panel that\nslides in — and assigns the next number automatically. You don't pick the number; Carbon\nhands you SO000072 after SO000071."},"1799":{"id":"/manual/overview/navigating-43","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"Fill in the header. Choose the customer or supplier, the location, dates and terms.\nRequired fields are marked; Carbon won't let you save without them."},"1800":{"id":"/manual/overview/navigating-44","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"Save, then add the detail. Once the header is saved the record opens in full, with its\ntabs. Now add the lines — the parts, quantities and prices — under the Lines tab."},"1801":{"id":"/manual/overview/navigating-45","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"Advance the status when you're ready. A new record starts as a Draft.\nActions like Confirm, Release or Send (usually a button near the status) move it\nforward and trigger the next steps — like creating a job from a confirmed order."},"1802":{"id":"/manual/overview/navigating-46","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"type: warn"},"1803":{"id":"/manual/overview/navigating-47","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#creating-a-new-record","content":"Many records start in Draft and do nothing until you advance them. A purchase order sitting\nin Draft hasn't been sent to the supplier; a quote in\nDraft hasn't reached the customer. If something \"didn't happen,\" check its status first — it's\nthe most common surprise for new users."},"1804":{"id":"/manual/overview/navigating-48","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#where-do-i-find","content":"A quick cheat-sheet for the things people hunt for first. When in doubt, ⌘K and type it."},"1805":{"id":"/manual/overview/navigating-49","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#where-do-i-find","content":"type: tip"},"1806":{"id":"/manual/overview/navigating-50","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#where-do-i-find","content":"Lost? Two reliable resets: press ⌘K to search from anywhere, or click the Carbon\nlogo at the top-left to return to your home dashboard. You can't get truly stuck — every record\nis always reachable by its number."},"1807":{"id":"/manual/overview/navigating-51","page_id":"/manual/overview/navigating","tags":[],"type":"text","url":"/manual/overview/navigating#next-steps","content":"You can now drive the interface. Next, get the ideas behind the screens, then start setting\nthings up."},"1808":{"id":"/manual/overview/what-is-carbon","page_id":"/manual/overview/what-is-carbon","type":"page","content":"What is Carbon?","tags":[],"url":"/manual/overview/what-is-carbon"},"1809":{"id":"/manual/overview/what-is-carbon-0","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon","content":"ERP, MES and QMS in one system of record — and who uses each part."},"1810":{"id":"/manual/overview/what-is-carbon-1","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#meet-acme--our-running-example","content":"Meet Acme — our running example"},"1811":{"id":"/manual/overview/what-is-carbon-2","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#three-jobs-one-system","content":"Three jobs, one system"},"1812":{"id":"/manual/overview/what-is-carbon-3","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#erp--the-business","content":"ERP — the business"},"1813":{"id":"/manual/overview/what-is-carbon-4","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#mes--the-shop-floor","content":"MES — the shop floor"},"1814":{"id":"/manual/overview/what-is-carbon-5","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#qms--quality","content":"QMS — quality"},"1815":{"id":"/manual/overview/what-is-carbon-6","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#one-database-underneath","content":"One database underneath"},"1816":{"id":"/manual/overview/what-is-carbon-7","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#who-uses-each-part","content":"Who uses each part"},"1817":{"id":"/manual/overview/what-is-carbon-8","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"Why Carbon is different"},"1818":{"id":"/manual/overview/what-is-carbon-9","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#the-one-idea-to-remember","content":"The one idea to remember"},"1819":{"id":"/manual/overview/what-is-carbon-10","page_id":"/manual/overview/what-is-carbon","type":"heading","tags":[],"url":"/manual/overview/what-is-carbon#next-steps","content":"Next steps"},"1820":{"id":"/manual/overview/what-is-carbon-11","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon","content":"Carbon is software for running a manufacturing business. If you've never used a tool\nlike this before, here's the short version: Carbon keeps track of everything your shop\ndoes — the orders you take, the parts you make, the materials you buy, and the money that\nmoves — all in one place. When you write something down once, Carbon carries it everywhere\nit's needed, so nobody has to re-type it."},"1821":{"id":"/manual/overview/what-is-carbon-12","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon","content":"Most shops cobble this together from spreadsheets, a separate accounting program, paper\ntravelers on the shop floor, and a folder of inspection forms. Each one holds part of the\ntruth, and none of them talk to each other. Carbon replaces that pile with a single\nsystem of record — one trusted place where the real, current state of the business\nlives."},"1822":{"id":"/manual/overview/what-is-carbon-13","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon","content":"type: info"},"1823":{"id":"/manual/overview/what-is-carbon-14","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon","content":"Where this fits. This is the first concept page. It explains what Carbon is at a\nhigh level. Next, Core concepts defines the building\nblocks (items, methods, jobs, orders), and Navigating Carbon\nshows you how to move around the app. If you'd rather see it all in action first, the\n15-minute walkthrough follows one real order end to end."},"1824":{"id":"/manual/overview/what-is-carbon-15","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#meet-acme--our-running-example","content":"Every page in this manual uses one real demo company so the examples stay concrete.\nAcme Inc. is a metal-fabrication shop in Springfield, OH. It cuts, machines, and\nfinishes steel and aluminum parts for customers in aerospace, defense, energy, mining,\nand construction."},"1825":{"id":"/manual/overview/what-is-carbon-16","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#meet-acme--our-running-example","content":"Throughout the manual we follow one part Acme makes — a Counterweight Hook\n(part number CWH-A36-15) that it produces for the customer Radiant Aerospace. You'll\nsee that hook turn up again and again, because a single order for it touches every corner\nof Carbon. Keep it in mind; it's the thread that ties the whole manual together."},"1826":{"id":"/manual/overview/what-is-carbon-17","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#three-jobs-one-system","content":"People often describe business software with three acronyms — ERP, MES, and QMS. Plenty of\ncompanies buy three separate programs to cover them. Carbon does all three, and the magic\nis that they're not three programs bolted together: they're three views of the same\ndata. Here's what each one means in plain language."},"1827":{"id":"/manual/overview/what-is-carbon-18","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#erp--the-business","content":"ERP stands for Enterprise Resource Planning. Ignore the jargon — it just means the\noffice side of the business. In Carbon, that's where you:"},"1828":{"id":"/manual/overview/what-is-carbon-19","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#erp--the-business","content":"Quote a customer and turn the quote into a sales order when they say yes."},"1829":{"id":"/manual/overview/what-is-carbon-20","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#erp--the-business","content":"Raise purchase orders to suppliers for the materials and services you need."},"1830":{"id":"/manual/overview/what-is-carbon-21","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#erp--the-business","content":"Track inventory — what's on the shelf, where, and how much."},"1831":{"id":"/manual/overview/what-is-carbon-22","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#erp--the-business","content":"Roll up cost automatically, so you know what a part really costs to make and whether\nthe price you quoted leaves a profit."},"1832":{"id":"/manual/overview/what-is-carbon-23","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#erp--the-business","content":"For Acme, this is the layer that took Radiant Aerospace's order for 500 Counterweight Hooks\n(sales order SO000069, $36,820) and the layer that bought the steel to make them from\nRyerson (purchase order PO000057)."},"1833":{"id":"/manual/overview/what-is-carbon-24","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#mes--the-shop-floor","content":"MES stands for Manufacturing Execution System. It's the part operators actually use,\nout on the floor, to do the work. When the office releases a job (a production order to\nmake a specific quantity of a part), the job appears in the MES app. An operator opens it,\nclocks on to an operation, and records how many good pieces they finished. That's what\nturns a planned order into real parts — and it's what feeds true labor time back into the\ncost."},"1834":{"id":"/manual/overview/what-is-carbon-25","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#mes--the-shop-floor","content":"For Acme's hook, the MES side ran three operations in order: Flame Cut, then\nSandblasting, then Inspection. Each was clocked and completed on job J000097."},"1835":{"id":"/manual/overview/what-is-carbon-26","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#qms--quality","content":"QMS stands for Quality Management System. This is how you make sure each part is right\nand can prove it later. In Carbon that means:"},"1836":{"id":"/manual/overview/what-is-carbon-27","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#qms--quality","content":"Inspections — a quality check, often built right into a job as an operation (notice\n\"Inspection\" was the last step on the hook)."},"1837":{"id":"/manual/overview/what-is-carbon-28","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#qms--quality","content":"Non-conformances (NCRs) — a record you raise when something is wrong, so it gets\nreviewed and fixed instead of slipping through."},"1838":{"id":"/manual/overview/what-is-carbon-29","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#qms--quality","content":"Traceability (also called genealogy) — the linked chain from finished part back to\nthe exact batch of raw material it came from. Because Acme's A36 steel is batch-tracked,\nCarbon can answer \"which heat of steel went into Radiant's hooks?\" in seconds."},"1839":{"id":"/manual/overview/what-is-carbon-30","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#qms--quality","content":"type: tip"},"1840":{"id":"/manual/overview/what-is-carbon-31","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#qms--quality","content":"New to any of these words? Every bolded term — item, method, job,\nsales order, non-conformance and more — is defined in the\nglossary. You never have to guess what something means."},"1841":{"id":"/manual/overview/what-is-carbon-32","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#one-database-underneath","content":"The reason the three sides feel like one tool is simple: they sit on one database. A\nsales order, the job that fulfills it, the purchase order for its material, the inspection\nthat passed it, and the invoice that bills it are all linked records pointing at each other."},"1842":{"id":"/manual/overview/what-is-carbon-33","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#one-database-underneath","content":"This is what \"system of record\" really buys you: enter information once, and it follows\nthe work everywhere. When Acme shipped the 500 hooks, the sales invoice AR000025 pulled\nits lines straight from what shipped — nobody re-typed quantities or prices. Here's the same\nsingle order seen through all three lenses at once."},"1843":{"id":"/manual/overview/what-is-carbon-34","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#one-database-underneath","content":"type: warn"},"1844":{"id":"/manual/overview/what-is-carbon-35","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#one-database-underneath","content":"This is the single biggest difference from running on spreadsheets. In a spreadsheet world\neach of those rows lives in a different file, gets copied by hand, and quietly drifts out\nof sync. In Carbon they are the same data — change one, and everyone sees it."},"1845":{"id":"/manual/overview/what-is-carbon-36","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#who-uses-each-part","content":"You don't have to learn all of Carbon to be useful in it. Most people live in one or two\nareas. Here's roughly who touches what at a shop like Acme."},"1846":{"id":"/manual/overview/what-is-carbon-37","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#who-uses-each-part","content":"Because it's all one system, the hand-offs between these roles are automatic. The estimator\ndoesn't email the order to the floor; the order becomes a job the operator can open. The\ninspector doesn't keep a separate quality binder; the inspection is a step on that same job."},"1847":{"id":"/manual/overview/what-is-carbon-38","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"Plenty of software does ERP, MES, or QMS. A few things make Carbon stand apart."},"1848":{"id":"/manual/overview/what-is-carbon-39","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"Everything lives together, so there's no re-keying and nothing drifts out of sync.\nA quote becomes a sales order becomes a job becomes a shipment becomes an invoice — each\none inheriting from the last. The walkthrough follows exactly that\nchain for Acme's hook, from price request to paid invoice, without anyone copying a\nnumber by hand."},"1849":{"id":"/manual/overview/what-is-carbon-40","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"An API (Application Programming Interface) is a way for other software to read and\nwrite your data. Carbon is API-first: every screen you click is doing the same thing a\nprogram could do through the API. That means you can connect Carbon to your other tools,\nbuild custom reports, or automate the boring parts. More in\nUsing the API."},"1850":{"id":"/manual/overview/what-is-carbon-41","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"Carbon ships with a built-in MCP server — a standard doorway that lets an AI\nassistant safely operate Carbon for you (look things up, draft a quote, check a job's\nstatus) in plain language. The same demo data in this manual was pulled through it. See\nMCP & AI."},"1851":{"id":"/manual/overview/what-is-carbon-42","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"Carbon's code is open source — anyone can read it, run it, and extend it. You're not\nlocked into a black box: you can self-host, audit how it works, and shape it to your\nshop. The integration story continues in\nIntegrating with Carbon."},"1852":{"id":"/manual/overview/what-is-carbon-43","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"type: tip"},"1853":{"id":"/manual/overview/what-is-carbon-44","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#why-carbon-is-different","content":"You don't need to understand the API or AI features to get full value from Carbon. They're\nthere when you're ready. Day one, you can quote, order, make, buy, inspect and invoice\nentirely by clicking — exactly as the rest of this manual shows."},"1854":{"id":"/manual/overview/what-is-carbon-45","page_id":"/manual/overview/what-is-carbon","tags":[],"type":"text","url":"/manual/overview/what-is-carbon#the-one-idea-to-remember","content":"If you take away a single thing: Carbon is one connected system of record for the whole\nbusiness. ERP runs the office, MES runs the floor, QMS keeps it good — but they're three\nwindows into the same data, not three programs. Information goes in once and follows the\nwork from the first quote to the final payment."},"1855":{"id":"/manual/quality/tracking-quality","page_id":"/manual/quality/tracking-quality","type":"page","content":"Tracking quality","tags":[],"url":"/manual/quality/tracking-quality"},"1856":{"id":"/manual/quality/tracking-quality-0","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality","content":"Non-conformances, inspections, corrective actions and full traceability."},"1857":{"id":"/manual/quality/tracking-quality-1","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#the-four-jobs-of-a-qms","content":"The four jobs of a QMS"},"1858":{"id":"/manual/quality/tracking-quality-2","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#inspections-a-quality-gate-inside-the-job","content":"Inspections: a quality gate inside the job"},"1859":{"id":"/manual/quality/tracking-quality-3","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#how-an-inspection-runs-on-the-shop-floor","content":"How an inspection runs on the shop floor"},"1860":{"id":"/manual/quality/tracking-quality-4","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#non-conformances-ncrs-recording-what-went-wrong","content":"Non-conformances (NCRs): recording what went wrong"},"1861":{"id":"/manual/quality/tracking-quality-5","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#classify-it-ncr-types","content":"Classify it: NCR types"},"1862":{"id":"/manual/quality/tracking-quality-6","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#match-the-response-to-the-severity-workflows","content":"Match the response to the severity: workflows"},"1863":{"id":"/manual/quality/tracking-quality-7","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Raise an NCR"},"1864":{"id":"/manual/quality/tracking-quality-8","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#the-ncr-lifecycle-at-a-glance","content":"The NCR lifecycle, at a glance"},"1865":{"id":"/manual/quality/tracking-quality-9","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"Gauges and calibration: trust your measurements"},"1866":{"id":"/manual/quality/tracking-quality-10","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#traceability-and-genealogy-proving-what-went-where","content":"Traceability and genealogy: proving what went where"},"1867":{"id":"/manual/quality/tracking-quality-11","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#following-the-thread-both-ways","content":"Following the thread both ways"},"1868":{"id":"/manual/quality/tracking-quality-12","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#why-its-worth-the-effort","content":"Why it's worth the effort"},"1869":{"id":"/manual/quality/tracking-quality-13","page_id":"/manual/quality/tracking-quality","type":"heading","tags":[],"url":"/manual/quality/tracking-quality#next-steps","content":"Next steps"},"1870":{"id":"/manual/quality/tracking-quality-14","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality","content":"Quality is the part of Carbon that keeps bad parts from leaving the building — and lets you\nprove it later. This page covers the four pieces of Carbon's QMS (Quality Management\nSystem, the glossary term for the tools that control and document\nquality): inspections baked into a job, non-conformances (NCRs) and the corrective\nactions that follow them, gauges and their calibration schedule, and traceability —\nhow batch and serial tracking let you answer \"which heat of A36 steel went into Radiant's\norder?\" months after the job shipped."},"1871":{"id":"/manual/quality/tracking-quality-15","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality","content":"type: info"},"1872":{"id":"/manual/quality/tracking-quality-16","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality","content":"Where this fits. Quality runs alongside the whole flow, not after it. The hero job\nJ000097 ends with an Inspection operation; the steel on\nPO000057 is batch-tracked when it's\nreceived; and if anything goes wrong, an NCR ties\nit all together. You're reading the chapter between the shop floor making parts and the\nwarehouse shipping them."},"1873":{"id":"/manual/quality/tracking-quality-17","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#the-four-jobs-of-a-qms","content":"Before the click-by-click, here's the shape of it. Each piece answers a different question."},"1874":{"id":"/manual/quality/tracking-quality-18","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#the-four-jobs-of-a-qms","content":"You don't have to use all four to start. Many shops begin with a single inspection\noperation on their most important part and grow from there."},"1875":{"id":"/manual/quality/tracking-quality-19","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#inspections-a-quality-gate-inside-the-job","content":"In Carbon an inspection isn't a separate module — it's just an operation in a\nrouting, run at a work center you've set aside for checking parts. The hero Counterweight\nHook proves the point. Its method has three operations, and the\nlast one is the gate:"},"1876":{"id":"/manual/quality/tracking-quality-20","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#inspections-a-quality-gate-inside-the-job","content":"Operation 30 runs at the Inspection Station work center using the Quality Inspection\nprocess, and it's allotted 10 minutes per piece. Because the routing is After Previous,\nno hook reaches inspection until it's been cut and sandblasted — Carbon enforces the order."},"1877":{"id":"/manual/quality/tracking-quality-21","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#how-an-inspection-runs-on-the-shop-floor","content":"An inspector clocks onto operation 30. In the MES app,\nthe inspector opens job J000097, taps the Inspection operation, and clocks on — exactly\nlike any other operation. Carbon already knows which procedure applies (Acme's\nQuality Inspection, version 1, is an Active standard work instruction)."},"1878":{"id":"/manual/quality/tracking-quality-22","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#how-an-inspection-runs-on-the-shop-floor","content":"They check parts against the spec. Using calibrated gauges — a height gauge, calipers,\na micrometer — they measure features and compare to the drawing. The procedure spells out\nwhat to check and how."},"1879":{"id":"/manual/quality/tracking-quality-23","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#how-an-inspection-runs-on-the-shop-floor","content":"They record good and scrap quantities. Good pieces get reported as quantity complete;\nanything that fails gets reported as scrap with a reason. On J000097 all 500 pieces\npassed, so quantity complete rolled up to 500 with zero scrap."},"1880":{"id":"/manual/quality/tracking-quality-24","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#how-an-inspection-runs-on-the-shop-floor","content":"A failure becomes an NCR. If parts fail, the inspector raises a non-conformance\nright from the operation (covered next). The job can be held until the issue is resolved,\nso bad parts can't be picked and shipped by mistake."},"1881":{"id":"/manual/quality/tracking-quality-25","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#how-an-inspection-runs-on-the-shop-floor","content":"type: tip"},"1882":{"id":"/manual/quality/tracking-quality-26","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#how-an-inspection-runs-on-the-shop-floor","content":"Want first-article or incoming inspection instead of a final gate? Put an inspection\noperation first in the routing, or inspect material the moment it's\nreceived. The mechanism is identical — it's just an\noperation at the Inspection Station — only the position changes."},"1883":{"id":"/manual/quality/tracking-quality-27","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#non-conformances-ncrs-recording-what-went-wrong","content":"A non-conformance report — an NCR, sometimes called an issue in Carbon — is the\nrecord you open when something doesn't meet spec: a mismeasured part, a bad batch of steel,\na customer complaint. It captures what happened, how bad it is, what you did about it,\nand how you proved the fix worked. That paper trail is what auditors and customers like\nRadiant Aerospace want to see."},"1884":{"id":"/manual/quality/tracking-quality-28","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#classify-it-ncr-types","content":"Carbon ships Acme with ten NCR types so every issue is filed under a cause you can report\non later. Filing by type is how you spot patterns — for example, three \"Material Issue\" NCRs\nin a month all pointing back to one supplier."},"1885":{"id":"/manual/quality/tracking-quality-29","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#match-the-response-to-the-severity-workflows","content":"Not every problem deserves the same paperwork. A scratched part and a customer recall are\nworlds apart, so Carbon attaches a workflow to each NCR. A workflow is a named playbook —\nit sets a priority, lists the required actions you must complete before closing, and can\nrequire sign-off from a review board. Acme uses three, drawn straight from standard quality\npractice:"},"1886":{"id":"/manual/quality/tracking-quality-30","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#match-the-response-to-the-severity-workflows","content":"Reading those left to right: 5 Why 2 How is the quick investigation for a minor issue.\nCAPA — Corrective and Preventive Action — adds a documented fix and a step to stop it\nrecurring. 8D is the heavyweight, eight-discipline response reserved for critical problems;\nit even requires MRB (Material Review Board) sign-off before the NCR can close."},"1887":{"id":"/manual/quality/tracking-quality-31","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#match-the-response-to-the-severity-workflows","content":"type: info"},"1888":{"id":"/manual/quality/tracking-quality-32","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#match-the-response-to-the-severity-workflows","content":"Corrective vs preventive. A corrective action fixes the parts in front of you\n(re-inspect the batch, scrap the bad ones). A preventive action changes the process so\nit can't happen again (add a fixture, update the procedure). The heavier workflows make you\ndo both — and Carbon won't let you close the NCR until every required action is checked off."},"1889":{"id":"/manual/quality/tracking-quality-33","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Here's the click-by-click for opening a non-conformance — say a handful of Counterweight\nHooks fail the dimensional check at operation 30."},"1890":{"id":"/manual/quality/tracking-quality-34","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Start the NCR from where the problem is. Open the failing operation on job J000097\n(or go to Quality → Issues → New). Starting from the operation pre-fills the link back\nto the job, the part CWH-A36-15, and the work center, so the NCR is anchored to the work."},"1891":{"id":"/manual/quality/tracking-quality-35","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Pick the NCR type. Choose the cause — here Manufacturing Defect if it's a cutting\nproblem, or Material Issue if the plate was bad. This is the field you'll report on later."},"1892":{"id":"/manual/quality/tracking-quality-36","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Choose the workflow. Select CAPA for a recurring defect, or 8D if scrap parts\nmay have shipped and the customer is exposed. Carbon then lists the required actions you'll\nhave to complete."},"1893":{"id":"/manual/quality/tracking-quality-37","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Describe and quantify. Write what you saw, attach a photo, and record the\nnon-conforming quantity. If you're scrapping parts, pick a scrap reason so the cost\nlands in the right account."},"1894":{"id":"/manual/quality/tracking-quality-38","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Assign and investigate. Assign an owner, then work the required actions — root cause,\ncorrective action, and (for CAPA/8D) a preventive action and verification step. Each action\nis a checklist item with its own owner and status."},"1895":{"id":"/manual/quality/tracking-quality-39","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#raise-an-ncr","content":"Close it. Once every required action is complete — and the MRB has signed off, if the\nworkflow demands it — close the NCR. It stays on the record forever, linked to the job and\nthe part."},"1896":{"id":"/manual/quality/tracking-quality-40","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#the-ncr-lifecycle-at-a-glance","content":"type: warn"},"1897":{"id":"/manual/quality/tracking-quality-41","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#the-ncr-lifecycle-at-a-glance","content":"Don't reach for 8D on every scratch. Over-classifying buries your team in paperwork and\nhides the issues that truly matter. Match the workflow to the risk: most shop-floor defects\nare a 5 Why 2 How; reserve 8D for problems that reached the customer or carry safety risk."},"1898":{"id":"/manual/quality/tracking-quality-42","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"An inspection is only as good as the tool doing the measuring. A gauge is any\nmeasuring instrument — a micrometer, a height gauge, a thread plug. Over time gauges drift,\nso each one is calibrated on a schedule against a known standard. Carbon tracks every\ngauge, when it was last calibrated, and when it's due again — and flags any tool that's\noverdue so it can't quietly produce bad readings."},"1899":{"id":"/manual/quality/tracking-quality-43","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"Acme registers ten gauges, G00001 through G00010, each on a six-month calibration\ninterval. Here's the live register — note the dates are real, so several are already overdue\nas of today (2026-06-15):"},"1900":{"id":"/manual/quality/tracking-quality-44","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"Each gauge record carries a calibration interval (six months here), a last calibration\ndate, and a Carbon-computed next due date. When the next-due date passes, Carbon moves\nthe gauge to Out of Calibration automatically — which is your signal to pull it from\nservice until it's re-certified."},"1901":{"id":"/manual/quality/tracking-quality-45","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"Register the gauge. In Quality → Gauges → New, give it a number (Carbon suggests\nthe next in sequence, e.g. G00011), a description, a gauge type, and a home location."},"1902":{"id":"/manual/quality/tracking-quality-46","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"Set the calibration interval. Acme uses six months. Carbon uses this to compute the\nnext-due date every time you log a calibration."},"1903":{"id":"/manual/quality/tracking-quality-47","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"Log each calibration. When the gauge is calibrated, record the date and result. Carbon\nrolls the next-due date forward and flips the status back to In Calibration."},"1904":{"id":"/manual/quality/tracking-quality-48","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"Watch the overdue list. Filter the register by Out of Calibration to see what needs\nattention. Five of Acme's ten gauges are overdue right now — a realistic backlog for a\nsmall shop, and exactly the list a quality manager works down each week."},"1905":{"id":"/manual/quality/tracking-quality-49","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"type: warn"},"1906":{"id":"/manual/quality/tracking-quality-50","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#gauges-and-calibration-trust-your-measurements","content":"An out-of-calibration gauge taints every measurement made with it. If the Thread Plug\nGauge (G00003, last calibrated 2025-09-03) was used to accept parts after its 2026-03-03\ndue date, you can't trust those results — which may itself become a Testing Failure NCR.\nKeeping gauges current is what makes your inspection records defensible."},"1907":{"id":"/manual/quality/tracking-quality-51","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#traceability-and-genealogy-proving-what-went-where","content":"Traceability (also called genealogy) is Carbon's ability to follow a part backward\nand forward through its whole life: which raw material went into it, which job made it, and\nwhich customer it shipped to. It's the payoff for all the structure above. The enabler is\ntracking set on the item — and the hero thread shows both flavors:"},"1908":{"id":"/manual/quality/tracking-quality-52","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#traceability-and-genealogy-proving-what-went-where","content":"Batch tracking groups material by lot. A36 Steel Plate (A36-STEEL-PLT-1\") has\nrequiresBatchTracking: true, so every receipt records a batch — effectively the heat\nof steel from the mill. When the job pulled 20,000 LB for the 500 hooks, Carbon recorded\nexactly which batch was consumed."},"1909":{"id":"/manual/quality/tracking-quality-53","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#traceability-and-genealogy-proving-what-went-where","content":"Serial tracking gives each finished unit its own number — used when a customer needs to\ntrace an individual part. The Counterweight Hook is inventory-tracked rather than serialized,\nbut a safety-critical part would carry a serial through the same machinery."},"1910":{"id":"/manual/quality/tracking-quality-54","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#following-the-thread-both-ways","content":"Because every one of those records links to the next, you can read the chain in either\ndirection:"},"1911":{"id":"/manual/quality/tracking-quality-55","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#following-the-thread-both-ways","content":"Backward (recall): \"We think a bad heat of steel shipped. Which orders are affected?\"\nStart at the batch, follow it forward to job J000097, then to SO000069, and you land on\nRadiant Aerospace — in seconds, not days."},"1912":{"id":"/manual/quality/tracking-quality-56","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#following-the-thread-both-ways","content":"Forward (provenance): \"Radiant is asking for the material certs behind their hooks.\"\nStart at the shipment on AR000025, walk back through the job to the consumed batch, and\nyou have the exact heat of A36 steel and the Ryerson PO it came in on."},"1913":{"id":"/manual/quality/tracking-quality-57","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#following-the-thread-both-ways","content":"type: tip"},"1914":{"id":"/manual/quality/tracking-quality-58","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#following-the-thread-both-ways","content":"Turn on tracking before you receive material, not after. Set requiresBatchTracking\n(or serial tracking) on the item up front, and every\nreceipt, job consumption and shipment records the lot automatically. Switch it on too late\nand the early records have nothing to trace."},"1915":{"id":"/manual/quality/tracking-quality-59","page_id":"/manual/quality/tracking-quality","tags":[],"type":"text","url":"/manual/quality/tracking-quality#why-its-worth-the-effort","content":"That's the whole point of a QMS: not extra paperwork for its own sake, but the ability to\nprove — to an auditor, a customer, or yourself — that what you shipped was good, and to\ncontain the damage fast when it wasn't."},"1916":{"id":"/manual/selling/customers","page_id":"/manual/selling/customers","type":"page","content":"Customers","tags":[],"url":"/manual/selling/customers"},"1917":{"id":"/manual/selling/customers-0","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers","content":"Create customers, contacts, locations and payment terms."},"1918":{"id":"/manual/selling/customers-1","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#the-customer-list","content":"The customer list"},"1919":{"id":"/manual/selling/customers-2","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#status-where-a-customer-is-in-your-relationship","content":"Status: where a customer is in your relationship"},"1920":{"id":"/manual/selling/customers-3","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#type-how-you-group-customers","content":"Type: how you group customers"},"1921":{"id":"/manual/selling/customers-4","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#create-a-customer","content":"Create a customer"},"1922":{"id":"/manual/selling/customers-5","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#open-the-new-customer-form","content":"Open the new-customer form"},"1923":{"id":"/manual/selling/customers-6","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#set-the-customer-id-or-let-carbon-do-it","content":"Set the customer ID (or let Carbon do it)"},"1924":{"id":"/manual/selling/customers-7","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#save","content":"Save"},"1925":{"id":"/manual/selling/customers-8","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#add-contacts","content":"Add contacts"},"1926":{"id":"/manual/selling/customers-9","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#open-the-contacts-tab","content":"Open the Contacts tab"},"1927":{"id":"/manual/selling/customers-10","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#enter-the-persons-details","content":"Enter the person's details"},"1928":{"id":"/manual/selling/customers-11","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#save-and-repeat","content":"Save and repeat"},"1929":{"id":"/manual/selling/customers-12","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#add-ship-to-and-bill-to-locations","content":"Add ship-to and bill-to locations"},"1930":{"id":"/manual/selling/customers-13","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#open-the-locations-tab","content":"Open the Locations tab"},"1931":{"id":"/manual/selling/customers-14","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#enter-the-address-and-its-role","content":"Enter the address and its role"},"1932":{"id":"/manual/selling/customers-15","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#save-1","content":"Save"},"1933":{"id":"/manual/selling/customers-16","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#set-payment-terms","content":"Set payment terms"},"1934":{"id":"/manual/selling/customers-17","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#open-the-payment-tab","content":"Open the Payment tab"},"1935":{"id":"/manual/selling/customers-18","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#choose-the-terms-and-currency","content":"Choose the terms and currency"},"1936":{"id":"/manual/selling/customers-19","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#save-2","content":"Save"},"1937":{"id":"/manual/selling/customers-20","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#customer-specific-part-numbers","content":"Customer-specific part numbers"},"1938":{"id":"/manual/selling/customers-21","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#reading-a-customer-record","content":"Reading a customer record"},"1939":{"id":"/manual/selling/customers-22","page_id":"/manual/selling/customers","type":"heading","tags":[],"url":"/manual/selling/customers#next-steps","content":"Next steps"},"1940":{"id":"/manual/selling/customers-23","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers","content":"A customer is anyone you sell to. In Carbon, a customer record is the home base for one\ncompany you do business with — it holds their people (contacts), their addresses (ship-to and\nbill-to locations), how and when they pay you (payment terms), and even the part numbers they\nuse for your parts. Once a customer exists, you can quote them, take their orders, ship to them,\nand invoice them — all without re-typing their details each time."},"1941":{"id":"/manual/selling/customers-24","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers","content":"This page walks you through creating a customer, filling in everything Carbon needs, and reading\na customer record. We'll use Acme's real customers throughout, and build out Radiant Aerospace\nin full — the customer behind the Counterweight Hook order you may have seen in\nCarbon in 15 minutes."},"1942":{"id":"/manual/selling/customers-25","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers","content":"type: info"},"1943":{"id":"/manual/selling/customers-26","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers","content":"Where this fits. Customers are the who of selling — the starting point for everything on\nthe sales side. Once a customer exists, you can write them a quote,\nturn that into a sales order, and eventually bill them. This is\nthe first stop in the Quote → Sales Order → Job → Shipment → Invoice flow."},"1944":{"id":"/manual/selling/customers-27","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#the-customer-list","content":"Everything starts on the Customers list, under the Sales module. Each row is one company.\nAt a glance you can see who's active and what kind of business they are. Acme has 16 customers;\nhere are five of them."},"1945":{"id":"/manual/selling/customers-28","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#the-customer-list","content":"Two columns are worth a closer look before you start creating customers — status and type."},"1946":{"id":"/manual/selling/customers-29","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#status-where-a-customer-is-in-your-relationship","content":"Every customer has a status that controls whether you can actively sell to them. Carbon ships\nwith five:"},"1947":{"id":"/manual/selling/customers-30","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#type-how-you-group-customers","content":"A customer type is a label you use to slice your customers into segments — handy for filtering\nlists and reporting. Acme groups its customers by industry: Aerospace & Defense, Construction,\nDealers, Energy & Power, and Mining. Radiant Aerospace is Aerospace & Defense. Types are\noptional but make a long customer list far easier to navigate."},"1948":{"id":"/manual/selling/customers-31","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#type-how-you-group-customers","content":"type: tip"},"1949":{"id":"/manual/selling/customers-32","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#type-how-you-group-customers","content":"Both statuses and types are fully editable lists you set up once for your company, under\nSettings. Define the segments that match your business before you start adding customers in\nbulk, so everything lands in the right bucket from day one. See\nSet up your company."},"1950":{"id":"/manual/selling/customers-33","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#create-a-customer","content":"Let's create Radiant Aerospace from scratch. The only thing Carbon truly requires is a name — but\nfilling in the rest now saves re-keying later."},"1951":{"id":"/manual/selling/customers-34","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#open-the-new-customer-form","content":"From the Customers list, click New Customer (top right). Carbon opens a blank customer\nform. Give it a name — this is the one required field — then set the optional details that make\nthe customer usable everywhere else."},"1952":{"id":"/manual/selling/customers-35","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#set-the-customer-id-or-let-carbon-do-it","content":"Carbon assigns a readable customer ID automatically using your company's numbering sequence —\nRadiant's is CUS000003, and you rarely type this yourself. Behind the scenes every customer also\ngets a permanent internal ID (Radiant's is cust_LxoH7AbowNVjTwGSoqkW1Q); you'll see that form of\nID in the URL and in the API, but day to day you just use the\nname."},"1953":{"id":"/manual/selling/customers-36","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save","content":"Click Save. The customer now exists and appears on the Customers list. You can stop here and\nadd the rest later — but the next sections (contacts, locations, payment terms) are what make a\ncustomer ready to quote and ship."},"1954":{"id":"/manual/selling/customers-37","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#add-contacts","content":"A contact is a person at the customer — a buyer, an engineer, an AP clerk. You attach contacts\nto a customer so that when you write a quote or a sales order, you can pick who it's for and\nwho to email. A customer can have as many contacts as you need; one is usually marked as the\nprimary point of contact."},"1955":{"id":"/manual/selling/customers-38","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#open-the-contacts-tab","content":"On the customer record, switch to the Contacts tab and click New Contact."},"1956":{"id":"/manual/selling/customers-39","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#enter-the-persons-details","content":"Fill in name, email, phone and (optionally) job title. Email matters most — it's what Carbon uses\nwhen you send a quote or order PDF, and it's how the customer can be invited to the\ncustomer portal to see their orders."},"1957":{"id":"/manual/selling/customers-40","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save-and-repeat","content":"Save the contact. Add more for anyone else you deal with — for example a separate accounts-payable\ncontact who should receive invoices. When you later create a quote or order for this customer,\nthese contacts appear in a dropdown so you can pick the right recipient."},"1958":{"id":"/manual/selling/customers-41","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save-and-repeat","content":"type: tip"},"1959":{"id":"/manual/selling/customers-42","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save-and-repeat","content":"The buyer's name and email aren't just decoration. On Radiant's real order SO000069, the\nselected contact is the person Carbon addressed the order confirmation to — and the same contact\nflowed through to the invoice AR000025. Set contacts up once and they follow the paperwork."},"1960":{"id":"/manual/selling/customers-43","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#add-ship-to-and-bill-to-locations","content":"A customer location is an address. Carbon treats two address roles specially:"},"1961":{"id":"/manual/selling/customers-44","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#add-ship-to-and-bill-to-locations","content":"Ship-to — where finished goods are delivered. This drives shipments."},"1962":{"id":"/manual/selling/customers-45","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#add-ship-to-and-bill-to-locations","content":"Bill-to — where invoices are sent. This drives accounting."},"1963":{"id":"/manual/selling/customers-46","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#add-ship-to-and-bill-to-locations","content":"Most customers have one of each (often the same address), but a large customer might receive at\nseveral plants while all the bills go to one accounts-payable office. You add as many addresses as\nyou need and tag each one with its role."},"1964":{"id":"/manual/selling/customers-47","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#open-the-locations-tab","content":"On the customer record, go to the Locations tab and click New Location."},"1965":{"id":"/manual/selling/customers-48","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#enter-the-address-and-its-role","content":"Type the street address, city, state, postal code and country. Mark whether this address is a\nship-to, a bill-to, or both, and set one as the default so Carbon pre-fills it on new\norders. Radiant uses a single headquarters address for both roles, which is the most common setup."},"1966":{"id":"/manual/selling/customers-49","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save-1","content":"Save each address. On every new quote, order and invoice for this customer, Carbon proposes the\ndefault ship-to and bill-to — but you can switch to any other address on the customer in one click."},"1967":{"id":"/manual/selling/customers-50","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#set-payment-terms","content":"Payment terms define when a customer is expected to pay an invoice — for example Net 30\nmeans \"due 30 days after the invoice date.\" Setting terms on the customer means every invoice you\nraise for them inherits the right due date automatically, so your accounting stays consistent\nwithout anyone remembering the rule."},"1968":{"id":"/manual/selling/customers-51","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#open-the-payment-tab","content":"On the customer record, go to the Payment tab. Pick the customer's default payment terms\nfrom the dropdown (these terms are a reusable list set up in Settings)."},"1969":{"id":"/manual/selling/customers-52","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#choose-the-terms-and-currency","content":"Radiant Aerospace is set to Net 30, billed in USD. You can also set a default tax setting\nhere if the customer is tax-exempt or charged at a specific rate."},"1970":{"id":"/manual/selling/customers-53","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save-2","content":"Save. From now on, any invoice for this customer defaults to Net 30 — exactly what you'll see on\nRadiant's real invoice AR000025 (issued and due against the same order)."},"1971":{"id":"/manual/selling/customers-54","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save-2","content":"type: tip"},"1972":{"id":"/manual/selling/customers-55","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#save-2","content":"Terms set on the customer are defaults, not handcuffs. You can override the payment terms on a\nsingle order or invoice when a deal calls for it — the customer default just spares you from\nsetting them every time."},"1973":{"id":"/manual/selling/customers-56","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#customer-specific-part-numbers","content":"Here's a small feature that prevents big headaches. Your customer often calls your part by their\ninternal number, not yours. Acme's part is CWH-A36-15 (the Counterweight Hook), but Radiant\nAerospace orders it as 730562. Carbon lets you record that mapping once, on the customer, so:"},"1974":{"id":"/manual/selling/customers-57","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#customer-specific-part-numbers","content":"When Radiant sends a PO referencing 730562, you instantly know it's CWH-A36-15."},"1975":{"id":"/manual/selling/customers-58","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#customer-specific-part-numbers","content":"When you send Radiant a quote, order or packing slip, Carbon can print their number alongside\nyours — so the paperwork matches what the customer expects."},"1976":{"id":"/manual/selling/customers-59","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#customer-specific-part-numbers","content":"This is stored as the customer part number (Carbon's field is customerPartId), and it lives\non the link between a customer and one of your items."},"1977":{"id":"/manual/selling/customers-60","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#customer-specific-part-numbers","content":"type: info"},"1978":{"id":"/manual/selling/customers-61","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#customer-specific-part-numbers","content":"You'll see 730562 again on Radiant's real sales order line in\nSales orders — Carbon carried the customer part number straight\nfrom the customer record onto the order, with no extra typing."},"1979":{"id":"/manual/selling/customers-62","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#reading-a-customer-record","content":"Once a customer is built out, its record is a single screen with everything in tabs. Here's\nRadiant Aerospace as it looks in Acme's system — the Details tab summarizes the company, and\nthe other tabs hold the contacts, locations and payment settings you just created."},"1980":{"id":"/manual/selling/customers-63","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#reading-a-customer-record","content":"That single record is now wired into everything downstream. When you quote, order, ship or invoice\nRadiant, Carbon pulls their contacts, addresses, terms and part-number mappings automatically — you\nenter the relationship once and it follows every transaction."},"1981":{"id":"/manual/selling/customers-64","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#reading-a-customer-record","content":"type: warn"},"1982":{"id":"/manual/selling/customers-65","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#reading-a-customer-record","content":"Avoid creating the same company twice. Duplicate customers split a company's history across two\nrecords, so quotes, orders and invoices no longer add up in one place. Before adding a customer,\nsearch the list — if they're already there (even as a Lead), edit that record rather than making\na new one."},"1983":{"id":"/manual/selling/customers-66","page_id":"/manual/selling/customers","tags":[],"type":"text","url":"/manual/selling/customers#next-steps","content":"You've got a customer with contacts, addresses, terms and part-number mappings. Now put them to\nwork — start quoting and selling."},"1984":{"id":"/manual/selling/quoting","page_id":"/manual/selling/quoting","type":"page","content":"Quoting & estimating","tags":[],"url":"/manual/selling/quoting"},"1985":{"id":"/manual/selling/quoting-0","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting","content":"Build a quote, price it, send it and turn it into an order."},"1986":{"id":"/manual/selling/quoting-1","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#what-a-quote-is-and-isnt","content":"What a quote is (and isn't)"},"1987":{"id":"/manual/selling/quoting-2","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#create-the-quote","content":"Create the quote"},"1988":{"id":"/manual/selling/quoting-3","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#add-a-line","content":"Add a line"},"1989":{"id":"/manual/selling/quoting-4","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"How Carbon prices the line"},"1990":{"id":"/manual/selling/quoting-5","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#configurators-pricing-made-to-order-parts","content":"Configurators: pricing made-to-order parts"},"1991":{"id":"/manual/selling/quoting-6","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#send-the-quote","content":"Send the quote"},"1992":{"id":"/manual/selling/quoting-7","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#convert-a-won-quote-to-a-sales-order","content":"Convert a won quote to a sales order"},"1993":{"id":"/manual/selling/quoting-8","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#recap","content":"Recap"},"1994":{"id":"/manual/selling/quoting-9","page_id":"/manual/selling/quoting","type":"heading","tags":[],"url":"/manual/selling/quoting#next-steps","content":"Next steps"},"1995":{"id":"/manual/selling/quoting-10","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting","content":"A quote is your answer to a customer's \"what would this cost?\" In Carbon you build a\nquote by adding a line for the part and a quantity, and Carbon adds up the cost of the\nmaterials and shop time behind it so you can set a price you're confident in. When the\ncustomer says yes, one click turns the quote into a sales order\n— no re-typing, and the two stay linked forever. This page walks through that whole arc using\nAcme's real quote Q000061: 500 Counterweight Hooks for Radiant Aerospace at\n$73.14 each."},"1996":{"id":"/manual/selling/quoting-11","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting","content":"type: info"},"1997":{"id":"/manual/selling/quoting-12","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting","content":"Where this fits. The quote is the first stop in Carbon's sales flow:\nQuote → Sales Order → Job → Shipment → Invoice.\nBefore you quote, you need a customer to quote to and an\nitem to quote — so if you haven't set those up yet,\nstart there. To see the whole chain end to end, read the 15-minute walkthrough."},"1998":{"id":"/manual/selling/quoting-13","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#what-a-quote-is-and-isnt","content":"A quote is a non-binding price offer. Nothing gets made, bought, or billed because a\nquote exists — it's a proposal. That makes it the safe place to experiment: try different\nquantities, see how the price-per-piece changes, adjust your margin, and send a polished\nPDF to the customer. Only when they accept do you convert it into a sales order, which is\na commitment."},"1999":{"id":"/manual/selling/quoting-14","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#what-a-quote-is-and-isnt","content":"A quote in Carbon has three layers, from the outside in:"},"2000":{"id":"/manual/selling/quoting-15","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#what-a-quote-is-and-isnt","content":"The quote — the document itself, addressed to one customer (Radiant Aerospace), with a\nnumber Carbon assigns automatically (Q000061)."},"2001":{"id":"/manual/selling/quoting-16","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#what-a-quote-is-and-isnt","content":"Lines — one per thing you're pricing. Each line points at an item\nand carries a quantity."},"2002":{"id":"/manual/selling/quoting-17","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#what-a-quote-is-and-isnt","content":"Price breaks — one or more quantities you price within a line. Quoting 100 vs. 500 vs.\n1,000 of the same part usually gives different per-piece prices, and Carbon lets you show\nall three on one line."},"2003":{"id":"/manual/selling/quoting-18","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#create-the-quote","content":"Quotes live in the Sales module. You start a quote by picking the customer, then Carbon\nopens an empty quote with a fresh number for you to fill in."},"2004":{"id":"/manual/selling/quoting-19","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#create-the-quote","content":"Open Sales → Quotes and select New. Carbon shows the list of every quote in the system.\nAcme has 44 of them. The list is your home base — you'll come back here to find, sort and\nfilter quotes by customer or status."},"2005":{"id":"/manual/selling/quoting-20","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#create-the-quote","content":"Choose the customer. Pick Radiant Aerospace from the customer field. Carbon pulls in\neverything it already knows about them — billing address, ship-to location, the contact who\nasked for the quote, currency (USD) and payment terms (Net 30) — so you don't re-key any\nof it. This is why setting up your customer first pays off."},"2006":{"id":"/manual/selling/quoting-21","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#create-the-quote","content":"Save the header. Carbon assigns the next quote number (Q000061) and a revision of 0.\nThe quote opens in Draft status. Draft means it's yours to edit freely; the customer hasn't\nseen it yet."},"2007":{"id":"/manual/selling/quoting-22","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#create-the-quote","content":"type: tip"},"2008":{"id":"/manual/selling/quoting-23","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#create-the-quote","content":"Revisions let you re-quote without losing history. If Radiant comes back asking for a\ndifferent quantity, you bump the quote to revision 1 instead of starting over — the\noriginal price you offered stays on the record."},"2009":{"id":"/manual/selling/quoting-24","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#add-a-line","content":"A blank quote is just a header. The work happens on the lines — one per part you're\npricing. Each line ties the quote to a real item so Carbon\ncan cost it accurately."},"2010":{"id":"/manual/selling/quoting-25","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#add-a-line","content":"Add a line and pick the part. On the quote, choose Add Line, set the line type to\nPart, and select Counterweight Hook (CWH-A36-15). Carbon fills the description and\nthe unit of measure (EA — Each) from the item. You can also capture the customer's own\npart number here — Radiant calls this hook 730562, so it prints on the quote and they\nrecognize it instantly."},"2011":{"id":"/manual/selling/quoting-26","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#add-a-line","content":"Enter the quantity. Type 500. This is the price break you're quoting. If you wanted to\nshow Radiant a price ladder, you'd add more quantities to the same line — say 100, 500 and\n1,000 — and Carbon prices each one."},"2012":{"id":"/manual/selling/quoting-27","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#add-a-line","content":"type: info"},"2013":{"id":"/manual/selling/quoting-28","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#add-a-line","content":"The fulfillment method on the line — here, Make to Order — tells Carbon whether this\npart is pulled from stock or made fresh. For made parts, Carbon can cost the line from the\npart's method (its bill of materials and routing), which is what\nmakes the next step possible."},"2014":{"id":"/manual/selling/quoting-29","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"This is the part that makes Carbon a quoting tool, not just a form. For a Make to Order\npart, Carbon already knows the recipe — what the part is made of and the steps to make it —\nso it can roll up a real cost instead of asking you to guess."},"2015":{"id":"/manual/selling/quoting-30","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"For the Counterweight Hook, the recipe is short. Each hook is flame-cut from 40 lb of\n1-inch A36 steel plate, then runs through three shop operations:"},"2016":{"id":"/manual/selling/quoting-31","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"Carbon multiplies each ingredient by its cost and each operation's time by its\nwork center rate, then adds it all up into a rolled-up cost\nper piece. You don't do the arithmetic — Carbon does, and it re-does it the moment any\ninput changes (a new steel price, a faster operation, a bigger batch)."},"2017":{"id":"/manual/selling/quoting-32","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"You set the price; Carbon shows you the margin. Margin is the gap between what the\nwork costs you and what you charge — the cushion that has to cover overhead and profit.\nType a unit price and Carbon shows the margin live; type a target margin and Carbon\nback-solves the price. Acme set $73.14 each on this line:"},"2018":{"id":"/manual/selling/quoting-33","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"type: tip"},"2019":{"id":"/manual/selling/quoting-34","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"Cost is not price. Carbon tracks the internal cost to make a part separately from the\nprice you quote — on this line the recorded unit cost rounds to fractions of a cent\nagainst a $73.14 price, because most of the value is in the labor and material Carbon rolls\nup behind the scenes. You always control the price; Carbon just keeps the cost honest so\nyour margin is real."},"2020":{"id":"/manual/selling/quoting-35","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"type: warn"},"2021":{"id":"/manual/selling/quoting-36","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#how-carbon-prices-the-line","content":"Carbon's cost rollup is only as good as the part's method. If a\npart has no bill of materials or routing yet, Carbon can't estimate its cost, and you'll be\npricing blind. Build the method first — or quote a known price and refine it later."},"2022":{"id":"/manual/selling/quoting-37","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#configurators-pricing-made-to-order-parts","content":"Some parts aren't one fixed thing — they're a family. A flame-cut plate part might come in\nany thickness, size or grade the customer asks for, and each combination has a different\namount of steel and cutting time, so a different cost. Re-typing a method for every variation\nwould be miserable."},"2023":{"id":"/manual/selling/quoting-38","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#configurators-pricing-made-to-order-parts","content":"A configurator solves this. It's a single item that exposes a few choices — Acme has one\ncalled the Flame Cut Part Configurator (FLAME CONFIG) — and those choices drive the\nmethod and the cost automatically. You quote the configurator, answer its questions, and\nCarbon assembles the right bill of materials, routing and rolled-up cost on the fly."},"2024":{"id":"/manual/selling/quoting-39","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#configurators-pricing-made-to-order-parts","content":"type: info"},"2025":{"id":"/manual/selling/quoting-40","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#configurators-pricing-made-to-order-parts","content":"When you confirm the choices, Carbon generates the line's method and rolls up its cost\nthe same way it does for a standard part — no hand-built recipe required."},"2026":{"id":"/manual/selling/quoting-41","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#configurators-pricing-made-to-order-parts","content":"type: tip"},"2027":{"id":"/manual/selling/quoting-42","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#configurators-pricing-made-to-order-parts","content":"Use a configurator when you sell the same kind of part in many shapes — cut plate,\nmachined bar stock, bent sheet. Use a plain part with a fixed method (like CWH-A36-15)\nwhen the design is settled and you make it the same way every time. Both price the same way\nonce the method exists. Learn more in Methods: BOM & routing."},"2028":{"id":"/manual/selling/quoting-43","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#send-the-quote","content":"When the lines and prices look right, you send the quote to the customer. Carbon generates a\nclean PDF and can email it to the contact on the quote — no copying numbers into a separate\ndocument."},"2029":{"id":"/manual/selling/quoting-44","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#send-the-quote","content":"Review the totals. Check the line prices and the quote total one more time. On Q000061\nthat's a single line: 500 EA × $73.14 = $36,570.00."},"2030":{"id":"/manual/selling/quoting-45","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#send-the-quote","content":"Select Send. Carbon builds the quote PDF, addresses it to Radiant's contact, and records\nthat the quote was sent. The status moves from Draft to Sent — your signal that the\nball is now in the customer's court."},"2031":{"id":"/manual/selling/quoting-46","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#send-the-quote","content":"type: tip"},"2032":{"id":"/manual/selling/quoting-47","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#send-the-quote","content":"Sending also timestamps the quote. If you've set an expiration window, that clock starts\nhere, so the customer knows the price isn't open-ended."},"2033":{"id":"/manual/selling/quoting-48","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#convert-a-won-quote-to-a-sales-order","content":"When Radiant says yes, you don't rebuild anything. From the quote you select Convert to\nOrder and Carbon copies the customer, lines, quantities and prices straight onto a brand-new\nsales order — here, SO000069."},"2034":{"id":"/manual/selling/quoting-49","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#convert-a-won-quote-to-a-sales-order","content":"The two records stay linked. Open J000097 later and you can trace it back through\nSO000069 all the way to the quote you sent — so when someone asks \"what price did we promise\non this?\" the answer is one click away. That traceability is the whole point of entering the\ninformation once."},"2035":{"id":"/manual/selling/quoting-50","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#convert-a-won-quote-to-a-sales-order","content":"type: info"},"2036":{"id":"/manual/selling/quoting-51","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#convert-a-won-quote-to-a-sales-order","content":"The order total ($36,820.00) is a little higher than the quote line total ($36,570.00)\nbecause $250 of shipping was added on the order. Quotes price the work; the order is where\nfreight, taxes and other add-ons get finalized."},"2037":{"id":"/manual/selling/quoting-52","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#convert-a-won-quote-to-a-sales-order","content":"type: warn"},"2038":{"id":"/manual/selling/quoting-53","page_id":"/manual/selling/quoting","tags":[],"type":"text","url":"/manual/selling/quoting#convert-a-won-quote-to-a-sales-order","content":"Converting doesn't close the quote behind your back — it marks it Ordered so you can\nstill see exactly what you offered. A quote that the customer passes on can be marked\nLost instead, which keeps your win/loss history honest for later analysis."},"2039":{"id":"/manual/selling/sales-orders","page_id":"/manual/selling/sales-orders","type":"page","content":"Sales orders","tags":[],"url":"/manual/selling/sales-orders"},"2040":{"id":"/manual/selling/sales-orders-0","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders","content":"Capture demand and drive fulfillment from a sales order."},"2041":{"id":"/manual/selling/sales-orders-1","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#what-a-sales-order-is-made-of","content":"What a sales order is made of"},"2042":{"id":"/manual/selling/sales-orders-2","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#create-a-sales-order","content":"Create a sales order"},"2043":{"id":"/manual/selling/sales-orders-3","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#add-lines","content":"Add lines"},"2044":{"id":"/manual/selling/sales-orders-4","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#choose-a-fulfillment-method-per-line","content":"Choose a fulfillment method per line"},"2045":{"id":"/manual/selling/sales-orders-5","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#how-a-line-spawns-a-job","content":"How a line spawns a job"},"2046":{"id":"/manual/selling/sales-orders-6","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#promised-dates-and-the-due-date","content":"Promised dates and the due date"},"2047":{"id":"/manual/selling/sales-orders-7","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#sales-order-statuses","content":"Sales order statuses"},"2048":{"id":"/manual/selling/sales-orders-8","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#track-shipments-and-invoices","content":"Track shipments and invoices"},"2049":{"id":"/manual/selling/sales-orders-9","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#common-gotchas","content":"Common gotchas"},"2050":{"id":"/manual/selling/sales-orders-10","page_id":"/manual/selling/sales-orders","type":"heading","tags":[],"url":"/manual/selling/sales-orders#next-steps","content":"Next steps"},"2051":{"id":"/manual/selling/sales-orders-11","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders","content":"A sales order (SO) is your customer's commitment to buy: who's ordering, what,\nhow many, when it's due, and at what price. It's the single most important record in\nfulfillment because everything downstream hangs off it — the job\nthat makes the part, the purchase order that buys the\nmaterial, the shipment that sends it, and the\ninvoice that bills for it all point back to this one document.\nEnter the order once and Carbon carries that information everywhere the work goes."},"2052":{"id":"/manual/selling/sales-orders-12","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders","content":"This page follows Acme's real order SO000069 — 500 Counterweight Hooks for Radiant\nAerospace, $36,820, Make to Order — from creation to completion."},"2053":{"id":"/manual/selling/sales-orders-13","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders","content":"type: info"},"2054":{"id":"/manual/selling/sales-orders-14","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders","content":"Where this fits. A sales order usually starts life as a quote\nthe customer accepts. From here, Carbon spawns the job that\nmakes the part, then the order flows on to shipping and the invoice.\nQuote → Sales Order → Job → Shipment → Invoice."},"2055":{"id":"/manual/selling/sales-orders-15","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#what-a-sales-order-is-made-of","content":"Every sales order has two parts:"},"2056":{"id":"/manual/selling/sales-orders-16","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#what-a-sales-order-is-made-of","content":"A header — the facts that apply to the whole order: the customer, the order date,\nthe payment terms, the shipping location, and the customer's\nown purchase-order number (their \"PO reference\")."},"2057":{"id":"/manual/selling/sales-orders-17","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#what-a-sales-order-is-made-of","content":"One or more lines — each line is one thing the customer is buying: an item, a\nquantity, a unit price, a promised date, and a fulfillment method that tells Carbon\nhow you'll deliver it. One order can mix made-to-order parts, stock items, and services\non separate lines."},"2058":{"id":"/manual/selling/sales-orders-18","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#what-a-sales-order-is-made-of","content":"Here's SO000069 as it looks in Carbon once it's complete. Notice the four tabs — every\nsales order organizes its detail the same way."},"2059":{"id":"/manual/selling/sales-orders-19","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#what-a-sales-order-is-made-of","content":"type: tip"},"2060":{"id":"/manual/selling/sales-orders-20","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#what-a-sales-order-is-made-of","content":"The customer PO reference (55557777 here) is the number your customer uses for the\norder on their end. It's not the same as Carbon's SO000069. Capturing it means the\nnumber shows up on the packing slip and invoice, so your customer's accounts-payable team\ncan match your invoice to their purchase order without a phone call."},"2061":{"id":"/manual/selling/sales-orders-21","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"There are two ways an order is born: you convert a quote the customer accepted, or you\nstart a fresh order by hand. Converting is by far the most common — it's how SO000069\nwas created — so start there."},"2062":{"id":"/manual/selling/sales-orders-22","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"When a customer accepts a quote, you don't re-type anything.\nCarbon copies the lines, quantities, prices, and the linked manufacturing\nmethod straight across, and keeps the two records linked so you\ncan always trace an order back to the price you promised."},"2063":{"id":"/manual/selling/sales-orders-23","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"Open the accepted quote. Go to Sales → Quotes and open the quote — for Acme that's\nQ000061. Confirm the line, quantity, and price are what the customer agreed to."},"2064":{"id":"/manual/selling/sales-orders-24","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"Convert to Sales Order. Click Convert to Order (or Finalize) in the top-right\nof the quote. Carbon creates a new sales order — SO000069 — and copies every line over,\nincluding the Make to Order fulfillment method on the Counterweight Hook line."},"2065":{"id":"/manual/selling/sales-orders-25","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"Review the header. The customer, currency, and payment terms come from the quote and the\ncustomer record. Add or confirm the customer PO reference (55557777) and the ship-from\nlocation (Headquarters). Set the order date if it isn't today."},"2066":{"id":"/manual/selling/sales-orders-26","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"type: tip"},"2067":{"id":"/manual/selling/sales-orders-27","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"Because the quote line and the sales-order line share the same internal ID, Carbon links\nthem directly. Open SO000069 and you can jump straight back to Q000061 — handy when a\ncustomer asks \"is this the price you quoted me?\""},"2068":{"id":"/manual/selling/sales-orders-28","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"Not every order comes from a quote — a repeat customer might just email a PO. In that case\nyou create the order directly."},"2069":{"id":"/manual/selling/sales-orders-29","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"New sales order. Go to Sales → Sales Orders and click New. Pick the\ncustomer (Radiant Aerospace). Carbon fills in their default\npayment terms, currency, and ship-to address automatically."},"2070":{"id":"/manual/selling/sales-orders-30","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"Fill in the header. Set the order date, the ship-from location, and type in the\ncustomer's PO reference. Save the header to get an order number."},"2071":{"id":"/manual/selling/sales-orders-31","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#create-a-sales-order","content":"Add the lines. Add one line per item the customer is buying — covered next."},"2072":{"id":"/manual/selling/sales-orders-32","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#add-lines","content":"A line is one thing being sold. To add the Counterweight Hook line, you open the\nLines tab and pick the item — Carbon pulls its description, unit of measure, and a\ndefault price, then you set the quantity and the promised date."},"2073":{"id":"/manual/selling/sales-orders-33","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#add-lines","content":"Each line carries a few fields worth knowing:"},"2074":{"id":"/manual/selling/sales-orders-34","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#add-lines","content":"type: tip"},"2075":{"id":"/manual/selling/sales-orders-35","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#add-lines","content":"Acme's hook sells for $73.14 while its internal unit cost is a fraction of a dollar —\nthat gap is your margin, and Carbon shows it on the line so you can see profitability\nbefore you ever ship. Adding a shipping cost to the line (Acme added $250) bills the\nfreight to the customer too."},"2076":{"id":"/manual/selling/sales-orders-36","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#choose-a-fulfillment-method-per-line","content":"The fulfillment method is the most important choice on a line. It tells Carbon how this\nparticular item gets delivered — and that decision drives everything that happens next. You\nset it per line, so one order can fulfill some items from stock and make others to order."},"2077":{"id":"/manual/selling/sales-orders-37","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#choose-a-fulfillment-method-per-line","content":"The Counterweight Hook line on SO000069 is Make to Order — Acme doesn't keep 500 finished\nhooks on a shelf, so each order is built fresh. That one setting is why a job appears next."},"2078":{"id":"/manual/selling/sales-orders-38","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#choose-a-fulfillment-method-per-line","content":"type: info"},"2079":{"id":"/manual/selling/sales-orders-39","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#choose-a-fulfillment-method-per-line","content":"An item's default fulfillment method comes from its\nreplenishment setting — a Make part defaults to Make to\nOrder, a Buy part to Pull from Stock. You can override the default on any individual\nline."},"2080":{"id":"/manual/selling/sales-orders-40","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#how-a-line-spawns-a-job","content":"When you confirm an order with a Make to Order line, Carbon creates a job — a\nproduction order that carries its own copy of the item's method\n(its bill of materials and routing). The job is the bridge from \"the customer ordered it\" to\n\"the shop floor makes it.\""},"2081":{"id":"/manual/selling/sales-orders-41","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#how-a-line-spawns-a-job","content":"For SO000069, the single line spawned Job J000097:"},"2082":{"id":"/manual/selling/sales-orders-42","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#how-a-line-spawns-a-job","content":"Notice the link runs both ways: the job knows its sales order (SO000069) and the sales\norder's Details tab lists the jobs it created. You never lose the thread between \"what\nwas sold\" and \"what's being made.\""},"2083":{"id":"/manual/selling/sales-orders-43","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#how-a-line-spawns-a-job","content":"type: tip"},"2084":{"id":"/manual/selling/sales-orders-44","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#how-a-line-spawns-a-job","content":"Carbon won't usually create the job until the order is confirmed. Confirming is your\nsignal that the order is real and the shop should commit material and machine time to it —\nso review your lines before you confirm."},"2085":{"id":"/manual/selling/sales-orders-45","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#promised-dates-and-the-due-date","content":"The promised date on a line is the date you've told the customer they'll have the goods.\nCarbon uses it to set the job's due date and to schedule the work backwards from there —\nso the shop knows when each operation has to start. On SO000069 the promised date is\n2026-06-26, which became the due date on job J000097."},"2086":{"id":"/manual/selling/sales-orders-46","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#promised-dates-and-the-due-date","content":"type: warn"},"2087":{"id":"/manual/selling/sales-orders-47","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#promised-dates-and-the-due-date","content":"Promising a date Carbon can't hit is the most common scheduling mistake. If the routing\nneeds more shop time than the days between today and the promised date, the job will be\nlate before it starts. Check the job's schedule after you confirm — and if material has to\nbe purchased first (Acme bought A36 steel on PO000057),\nbuild that lead time into the promise."},"2088":{"id":"/manual/selling/sales-orders-48","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#sales-order-statuses","content":"A sales order moves through a short lifecycle. The status tells you, at a glance, where the\norder is in fulfillment."},"2089":{"id":"/manual/selling/sales-orders-49","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#sales-order-statuses","content":"Status is tracked at the line level too: each line shows how much has been sent and\ninvoiced. SO000069's line shows 500 sent of 500 and 500 invoiced — that's why the whole\norder rolled up to Completed."},"2090":{"id":"/manual/selling/sales-orders-50","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#track-shipments-and-invoices","content":"The remaining two tabs on the sales order are where fulfillment shows up. You don't fill them\nin directly — they're populated as shipments leave and invoices post — but they're how you\nanswer \"did this go out?\" and \"did we bill for it?\""},"2091":{"id":"/manual/selling/sales-orders-51","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#track-shipments-and-invoices","content":"Every time goods leave against the order, a shipment record appears here, with the\nquantity sent and the date. SO000069 has one shipment covering all 500 hooks, sent\n2026-06-11. Each shipment links to the packing slip your customer receives."},"2092":{"id":"/manual/selling/sales-orders-52","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#track-shipments-and-invoices","content":"When you bill the order, the sales invoice pulls its lines straight from what shipped —\nno re-keying — and appears on this tab. SO000069 was billed on invoice AR000025 for\n$36,820 (the $36,570 of goods plus $250 shipping) and marked Paid the same day."},"2093":{"id":"/manual/selling/sales-orders-53","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#track-shipments-and-invoices","content":"type: info"},"2094":{"id":"/manual/selling/sales-orders-54","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#track-shipments-and-invoices","content":"Radiant Aerospace keeps coming back: the same Counterweight Hook runs on SO000070 (1,500\nEA, in progress) and SO000071 (3,000 EA, queued). Each is its own sales order with its\nown job — but they all point back to the same item and method, so Acme prices and makes them\nthe same way every time."},"2095":{"id":"/manual/selling/sales-orders-55","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#common-gotchas","content":"Check the line's fulfillment method. A job is only created for Make to Order lines.\nIf the line is set to Pull from Stock, Carbon reserves inventory instead — no job. Change\nthe method on the line if the item really does need to be made."},"2096":{"id":"/manual/selling/sales-orders-56","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#common-gotchas","content":"Lines copied from a quote carry the quoted price. A line you add by hand uses the item's\ndefault sell price instead, which may differ. When in doubt, convert from the quote rather\nthan re-keying — that's the whole point of the quote-to-order link."},"2097":{"id":"/manual/selling/sales-orders-57","page_id":"/manual/selling/sales-orders","tags":[],"type":"text","url":"/manual/selling/sales-orders#common-gotchas","content":"Yes. A line can be shipped partially — send what's ready now and the rest later. Each\nshipment shows on the Shipments tab, and the line stays open (status To Ship) until the\nfull quantity has gone out. The order only reaches Completed when every line is fully\nshipped and invoiced."},"2098":{"id":"/manual/selling/sales-to-shipment","page_id":"/manual/selling/sales-to-shipment","type":"page","content":"From sales order to shipment","tags":[],"url":"/manual/selling/sales-to-shipment"},"2099":{"id":"/manual/selling/sales-to-shipment-0","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment","content":"Follow an order all the way to a shipped, invoiced job."},"2100":{"id":"/manual/selling/sales-to-shipment-1","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#the-fulfillment-flow-at-a-glance","content":"The fulfillment flow at a glance"},"2101":{"id":"/manual/selling/sales-to-shipment-2","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"Step 1 — A Make-to-Order line creates a job"},"2102":{"id":"/manual/selling/sales-to-shipment-3","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"Step 2 — Track fulfillment on the sales order"},"2103":{"id":"/manual/selling/sales-to-shipment-4","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#step-3--create-the-shipment","content":"Step 3 — Create the shipment"},"2104":{"id":"/manual/selling/sales-to-shipment-5","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#acmes-shipping-methods","content":"Acme's shipping methods"},"2105":{"id":"/manual/selling/sales-to-shipment-6","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#step-4--the-line-is-marked-shipped","content":"Step 4 — The line is marked Shipped"},"2106":{"id":"/manual/selling/sales-to-shipment-7","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"Step 5 — Invoice the order"},"2107":{"id":"/manual/selling/sales-to-shipment-8","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#the-back-half-in-one-table","content":"The back half, in one table"},"2108":{"id":"/manual/selling/sales-to-shipment-9","page_id":"/manual/selling/sales-to-shipment","type":"heading","tags":[],"url":"/manual/selling/sales-to-shipment#next-steps","content":"Next steps"},"2109":{"id":"/manual/selling/sales-to-shipment-10","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment","content":"You've taken the order — now you have to deliver it. This page follows the back half of\nthe sale: how a confirmed sales order turns into a finished, shipped, and invoiced job. It's\na close-up companion to the 15-minute walkthrough, so we'll reuse the\nsame real example — the 500 Counterweight Hooks Acme made for Radiant Aerospace on\nsales order SO000069 — and zoom in on the steps the\nwalkthrough skipped past: the job the order created, tracking\nfulfillment, building the shipment, and raising the invoice."},"2110":{"id":"/manual/selling/sales-to-shipment-11","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment","content":"type: info"},"2111":{"id":"/manual/selling/sales-to-shipment-12","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment","content":"Where this fits. This is the last leg of the selling flow:\nQuote → Sales Order → (make it) → ship it → invoice it.\nIt picks up right after Sales orders, where you confirm\nthe order, and hands off to Accounting, where the invoice\nbecomes revenue. If a line is Make to Order, the manufacturing chapter\n(Jobs) covers actually building it; here we stay on the\nsales side and watch the order get fulfilled."},"2112":{"id":"/manual/selling/sales-to-shipment-13","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#the-fulfillment-flow-at-a-glance","content":"Once a sales order is confirmed, every line has to be fulfilled — Carbon's word for\n\"get the goods to the customer.\" How that happens depends on one setting on each line: the\nfulfillment method (Carbon also calls this the method type)."},"2113":{"id":"/manual/selling/sales-to-shipment-14","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#the-fulfillment-flow-at-a-glance","content":"Make to Order — the part has to be built, so confirming the order creates a job.\nNothing ships until that job produces finished pieces."},"2114":{"id":"/manual/selling/sales-to-shipment-15","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#the-fulfillment-flow-at-a-glance","content":"Make to Stock / Pull from Inventory — the part is already on a shelf, so you skip\nstraight to picking and shipping."},"2115":{"id":"/manual/selling/sales-to-shipment-16","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#the-fulfillment-flow-at-a-glance","content":"Our hero line is Make to Order, which is the longer, more interesting path. Here's the\nwhole chain you're about to walk through:"},"2116":{"id":"/manual/selling/sales-to-shipment-17","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"When you confirm a sales order with a Make to Order line, Carbon doesn't expect the part\nto be sitting in inventory. Instead it spins up a job — a production order that knows\nexactly which order line it's serving — and links the two together. You don't re-type\nanything; the part, the quantity, and the due date all flow from the line into the job."},"2117":{"id":"/manual/selling/sales-to-shipment-18","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"On SO000069, line 1 is 500 Counterweight Hooks set to Make to Order. Confirming the order\ncreated job J000097 for exactly 500 pieces, due 2026-06-26."},"2118":{"id":"/manual/selling/sales-to-shipment-19","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"The link runs both ways. Open the job and you'll see it points back to its source — the\nsales order, the customer, and even the original quote — so anyone on the shop floor knows\nwhy they're making these hooks."},"2119":{"id":"/manual/selling/sales-to-shipment-20","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"type: tip"},"2120":{"id":"/manual/selling/sales-to-shipment-21","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"You don't have to leave the sales order to check on production. The Jobs tab on the SO\nlists every linked job and its live status — for SO000069 it shows J000097 at 500 of 500\ncomplete. From the sales order you always know whether the\nthing you sold actually got made."},"2121":{"id":"/manual/selling/sales-to-shipment-22","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"type: warn"},"2122":{"id":"/manual/selling/sales-to-shipment-23","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-1--a-make-to-order-line-creates-a-job","content":"A Make to Order line can't ship until its job produces finished pieces. If the job is\nstill In Progress, the order line stays open — Carbon won't let you ship parts you haven't\nmade yet. Building that job is the Manufacturing chapter's\njob (pun intended); the rest of this page assumes the pieces are done and in stock."},"2123":{"id":"/manual/selling/sales-to-shipment-24","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"While the job runs, the sales order is your dashboard for \"how close are we to delivering?\"\nEvery line carries three running tallies that Carbon keeps up to date automatically:"},"2124":{"id":"/manual/selling/sales-to-shipment-25","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"Quantity — how many the customer ordered."},"2125":{"id":"/manual/selling/sales-to-shipment-26","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"Quantity shipped — how many have left the building so far."},"2126":{"id":"/manual/selling/sales-to-shipment-27","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"Quantity invoiced — how many you've billed for."},"2127":{"id":"/manual/selling/sales-to-shipment-28","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"These three numbers tell the whole fulfillment story at a glance. When shipped catches up\nto ordered, the line is fully delivered; when invoiced catches up too, the line is fully\nbilled. Carbon also flips two flags — sentComplete and invoicedComplete — to true\nonce a line is fully shipped and fully invoiced, which is how the order knows it's finished."},"2128":{"id":"/manual/selling/sales-to-shipment-29","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"type: info"},"2129":{"id":"/manual/selling/sales-to-shipment-30","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-2--track-fulfillment-on-the-sales-order","content":"These tallies are per line, not just per order. A single sales order can have many\nlines at different stages — one fully shipped, one half shipped, one not started — and\nCarbon tracks each independently. The order as a whole only counts as Completed when\nevery line is fully shipped and invoiced, which is exactly the state SO000069 is in."},"2130":{"id":"/manual/selling/sales-to-shipment-31","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-3--create-the-shipment","content":"A shipment is the record of goods physically leaving your dock. It's where you say \"this\nmuch, of this part, going to this customer, by this carrier.\" Creating one is how you turn\nfinished pieces into a delivery — and it's the event that updates the shipped tally you\njust saw."},"2131":{"id":"/manual/selling/sales-to-shipment-32","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-3--create-the-shipment","content":"You can start a shipment straight from the sales order. Carbon pre-fills it from the order\nso you're confirming, not re-typing."},"2132":{"id":"/manual/selling/sales-to-shipment-33","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-3--create-the-shipment","content":"Open the order and start a shipment. From SO000069, use Ship (or the Shipments\ntab → New Shipment). Carbon creates a shipment pre-filled with the customer (Radiant\nAerospace), the ship-to address, and the open lines from the order."},"2133":{"id":"/manual/selling/sales-to-shipment-34","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-3--create-the-shipment","content":"Pick the finished goods. Set how many of each line you're sending. The Counterweight\nHooks were received into inventory from the completed job, so all 500 are available to pick.\nBecause A36 steel is batch-tracked, Carbon records which batch of finished hooks you're\nshipping — that's the genealogy link that powers traceability\nlater. Enter 500 EA to ship the line in full."},"2134":{"id":"/manual/selling/sales-to-shipment-35","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-3--create-the-shipment","content":"Choose a shipping method. Pick the carrier and service. Acme has 10 shipping methods\nconfigured, from in-house delivery to overnight air (see the table below). Choose the one\nthat matches what you quoted — for a heavy 500-piece steel order, that's typically a freight\nmethod like LTL (Less Than Truckload) rather than a parcel service."},"2135":{"id":"/manual/selling/sales-to-shipment-36","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-3--create-the-shipment","content":"Post the shipment. Posting commits it: Carbon decrements the finished hooks from\ninventory and adds 500 to the line's quantity shipped. A shipment record is created\n(internally sh_7injMjdu1xyZqTVFFrjauv) and linked back to the order."},"2136":{"id":"/manual/selling/sales-to-shipment-37","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#acmes-shipping-methods","content":"A shipping method is just the carrier-and-service option you choose at ship time. Carbon\nships with none preset — you add the ones your shop actually uses in Settings. Acme has\nconfigured these 10:"},"2137":{"id":"/manual/selling/sales-to-shipment-38","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#acmes-shipping-methods","content":"type: tip"},"2138":{"id":"/manual/selling/sales-to-shipment-39","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#acmes-shipping-methods","content":"Shipping cost vs. shipping method are two different things. The method is the carrier\nservice you pick. The cost is what you bill the customer for freight — on SO000069 that's\n$250, set on the order line. The cost rides through to the invoice automatically; you\ndon't add it twice."},"2139":{"id":"/manual/selling/sales-to-shipment-40","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#acmes-shipping-methods","content":"type: warn"},"2140":{"id":"/manual/selling/sales-to-shipment-41","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#acmes-shipping-methods","content":"You can ship a line in more than one go. If you only finish 300 of 500 hooks, ship 300\nnow — Carbon records a partial shipment, sets quantity shipped to 300, and leaves the\nline open for the remaining 200. The line only reads Shipped once the shipped quantity\nreaches the ordered quantity."},"2141":{"id":"/manual/selling/sales-to-shipment-42","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-4--the-line-is-marked-shipped","content":"Posting the shipment is what moves the needle on the order. Carbon adds the shipped quantity\nto the line, and the moment shipped equals ordered, the line's sentComplete flag flips\nto true and the status reads Shipped. For SO000069, posting all 500 finished the\nline in a single shipment."},"2142":{"id":"/manual/selling/sales-to-shipment-43","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-4--the-line-is-marked-shipped","content":"type: info"},"2143":{"id":"/manual/selling/sales-to-shipment-44","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-4--the-line-is-marked-shipped","content":"Shipping and receiving share one chapter because they're mirror images: a shipment is\ngoods going out to a customer, a receipt is goods coming in from a supplier. Same\npicking, batch, and posting mechanics. See\nShipping & receiving for the receiving side."},"2144":{"id":"/manual/selling/sales-to-shipment-45","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"With the goods shipped, you can bill for them. A sales invoice is your request for\npayment. The best part: Carbon builds it from what actually shipped, so the invoice can't\ndrift away from reality. You don't re-key the line — Carbon pulls the part, the quantity,\nand the price straight off the shipped order line."},"2145":{"id":"/manual/selling/sales-to-shipment-46","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"Create the invoice from the order. From SO000069, use Invoice (or the Invoices\ntab). Carbon drafts a sales invoice — AR000025 — pulling line 1 in at the shipped\nquantity (500) and the order's unit price ($73.14)."},"2146":{"id":"/manual/selling/sales-to-shipment-47","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"Check the totals. The line subtotal is 500 × $73.14 = $36,570. The $250 shipping\ncost from the order line carries over, making the invoice total $36,820. Payment terms\n(Net 30) come from the customer record — no need to set them again."},"2147":{"id":"/manual/selling/sales-to-shipment-48","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"Post and send it. Posting the invoice books the revenue and sets the line's\ninvoicedComplete flag to true. Send it to Radiant, and when they pay, mark it Paid\n— which is exactly the state AR000025 ended in, paid the same day it was issued."},"2148":{"id":"/manual/selling/sales-to-shipment-49","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"type: info"},"2149":{"id":"/manual/selling/sales-to-shipment-50","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"Subtotal vs. invoice total. The subtotal ($36,570) is the goods alone. The invoice\ntotal ($36,820) adds the $250 freight. That's why the order total and the invoice total\nmatch but the line subtotal is lower — the difference is shipping, every time."},"2150":{"id":"/manual/selling/sales-to-shipment-51","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sales-to-shipment#step-5--invoice-the-order","content":"Once posted, the invoice is an accounting document, not a sales one — it flows into your\nbooks as accounts receivable and, when paid, recognizes revenue. How that posting works\nis covered in Accounting."},"2151":{"id":"/manual/selling/sales-to-shipment-52","page_id":"/manual/selling/sales-to-shipment","tags":[],"type":"text","url":"/manual/selling/sa